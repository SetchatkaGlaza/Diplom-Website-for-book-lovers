<div class="error-container">
  <div class="error-content">
    <div class="error-number">500</div>
    
    <h1 class="error-title">
      <i class="fas fa-exclamation-triangle"></i>
      Ошибка сервера
    </h1>
    
    <div class="error-message">
      <p>Что-то пошло не так... Наши книги немного запутались.</p>
      <p>Мы уже знаем об этой проблеме и скоро всё исправим!</p>
      
      <% if (message && message !== '') { %>
        <div class="error-details">
          <strong>Детали ошибки:</strong>
          <p><%= message %></p>
        </div>
      <% } %>
    </div>
    
    <div class="error-actions">
      <a href="/" class="btn btn-primary">
        <i class="fas fa-home"></i>
        На главную
      </a>
      
      <a href="javascript:history.back()" class="btn btn-outline">
        <i class="fas fa-arrow-left"></i>
        Вернуться назад
      </a>
      
      <a href="/contact" class="btn btn-outline">
        <i class="fas fa-envelope"></i>
        Сообщить об ошибке
      </a>
    </div>
    
    <div class="error-help">
      <p>Или попробуйте обновить страницу:</p>
      <button onclick="location.reload()" class="btn btn-outline">
        <i class="fas fa-sync-alt"></i>
        Обновить страницу
      </button>
    </div>
  </div>
  
  <div class="error-illustration">
    <div class="stacked-books">
      <div class="book-stack"></div>
      <div class="book-stack"></div>
      <div class="book-stack"></div>
    </div>
  </div>
</div>

<style>
  .error-container {
    min-height: 70vh;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 2rem;
    background: rgba(255, 255, 255, 0.05);
    backdrop-filter: blur(10px);
    -webkit-backdrop-filter: blur(10px);
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: 32px;
    margin: 2rem 0;
    color: white;
    position: relative;
    overflow: hidden;
  }
  
  .error-content {
    max-width: 600px;
    text-align: center;
    z-index: 2;
    position: relative;
  }
  
  .error-number {
    font-size: 12rem;
    font-weight: 900;
    line-height: 1;
    background: linear-gradient(135deg, #ef4444, #dc2626);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    margin-bottom: 1rem;
    text-shadow: 0 10px 30px rgba(239, 68, 68, 0.3);
    animation: shake 0.5s ease-in-out infinite;
  }
  
  @keyframes shake {
    0%, 100% { transform: translateX(0); }
    25% { transform: translateX(-5px); }
    75% { transform: translateX(5px); }
  }
  
  .error-title {
    font-size: 2.5rem;
    margin-bottom: 1.5rem;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 1rem;
  }
  
  .error-title i {
    color: #ef4444;
  }
  
  .error-message {
    font-size: 1.2rem;
    color: rgba(255, 255, 255, 0.9);
    margin-bottom: 2rem;
    line-height: 1.8;
  }
  
  .error-message p {
    margin: 0.5rem 0;
  }
  
  .error-details {
    margin-top: 1rem;
    padding: 1rem;
    background: rgba(0, 0, 0, 0.3);
    border-radius: 12px;
    border-left: 4px solid #ef4444;
    text-align: left;
    font-family: monospace;
    font-size: 0.9rem;
  }
  
  .error-actions {
    display: flex;
    gap: 1rem;
    justify-content: center;
    flex-wrap: wrap;
    margin-bottom: 3rem;
  }
  
  .btn {
    padding: 1rem 2rem;
    border-radius: 50px;
    font-size: 1rem;
    font-weight: 600;
    text-decoration: none;
    transition: all 0.3s;
    display: inline-flex;
    align-items: center;
    gap: 0.75rem;
    border: none;
    cursor: pointer;
  }
  
  .btn-primary {
    background: linear-gradient(135deg, #fbbf24, #f59e0b);
    color: #000;
    box-shadow: 0 5px 15px rgba(251, 191, 36, 0.3);
  }
  
  .btn-primary:hover {
    transform: translateY(-3px);
    box-shadow: 0 8px 25px rgba(251, 191, 36, 0.5);
  }
  
  .btn-outline {
    background: rgba(255, 255, 255, 0.05);
    color: #fff;
    border: 1px solid rgba(255, 255, 255, 0.2);
  }
  
  .btn-outline:hover {
    background: rgba(251, 191, 36, 0.1);
    border-color: #fbbf24;
    transform: translateY(-3px);
  }
  
  .error-help {
    text-align: center;
  }
  
  .error-help p {
    color: rgba(255, 255, 255, 0.7);
    margin-bottom: 1rem;
  }
  
  .error-illustration {
    position: absolute;
    bottom: -50px;
    left: -50px;
    opacity: 0.1;
    z-index: 1;
  }
  
  .stacked-books {
    display: flex;
    gap: 10px;
    transform: rotate(-10deg);
  }
  
  .book-stack {
    width: 80px;
    height: 250px;
    background: linear-gradient(135deg, #ef4444, #dc2626);
    border-radius: 4px 10px 10px 4px;
    position: relative;
  }
  
  .book-stack::before {
    content: '';
    position: absolute;
    top: 10px;
    left: 10px;
    width: 60px;
    height: 230px;
    background: linear-gradient(135deg, #fbbf24, #f59e0b);
    border-radius: 4px;
  }
  
  .book-stack::after {
    content: '';
    position: absolute;
    top: 20px;
    left: 20px;
    width: 40px;
    height: 210px;
    background: linear-gradient(135deg, #3b82f6, #2563eb);
    border-radius: 4px;
  }
  
  .book-stack:nth-child(2) {
    transform: translateY(20px);
  }
  
  .book-stack:nth-child(3) {
    transform: translateY(40px);
  }
  
  @media (max-width: 768px) {
    .error-number {
      font-size: 8rem;
    }
    
    .error-title {
      font-size: 1.8rem;
    }
    
    .error-message {
      font-size: 1rem;
    }
    
    .error-actions {
      flex-direction: column;
    }
    
    .btn {
      width: 100%;
      justify-content: center;
    }
  }
</style>
