    overflow: hidden;
  }
  
  .notification-card:hover {
    transform: translateX(5px);
    background: rgba(255, 255, 255, 0.15);
  }
  
  .notification-card.unread {
    border-left: 4px solid var(--accent);
    background: rgba(245, 158, 11, 0.1);
  }
  
  .notification-icon {
    font-size: 2rem;
    color: var(--accent);
    display: flex;
    align-items: center;
    justify-content: center;
    width: 50px;
  }
  
  .notification-content {
    flex: 1;
    min-width: 0;
  }
  
  .notification-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 0.5rem;
    flex-wrap: wrap;
    gap: 0.5rem;
  }
  
  .notification-header h3 {
    margin: 0;
    font-size: 1.1rem;
    overflow-wrap: anywhere;
  }
  
  .notification-time {
    font-size: 0.85rem;
    opacity: 0.7;
  }
  
  .notification-message {
    margin: 0 0 1rem;
    opacity: 0.9;
    line-height: 1.6;
    overflow-wrap: anywhere;
  }
  
  .notification-link {
    display: inline-flex;
    align-items: center;
