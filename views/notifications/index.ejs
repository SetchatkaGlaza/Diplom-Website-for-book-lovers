<div class="notifications-page">
  <div class="page-header">
    <h1><i class="fas fa-bell"></i> Уведомления</h1>
    <% if (unread > 0) { %>
      <button class="btn btn-primary" id="markAllReadBtn">
        <i class="fas fa-check-double"></i> Отметить все как прочитанные
      </button>
    <% } %>
  </div>

  <div class="notifications-stats">
    <div class="stat-badge"><i class="fas fa-envelope"></i> Всего: <strong><%= total %></strong></div>
    <div class="stat-badge"><i class="fas fa-envelope-open"></i> Непрочитано: <strong><%= unread %></strong></div>
  </div>

  <p class="retention-note"><i class="fas fa-clock"></i> Уведомления старше <%= notificationRetentionDays %> дней удаляются автоматически.</p>

  <% if (notifications && notifications.length > 0) { %>
    <div class="notifications-list">
      <% notifications.forEach(notification => { %>
        <article class="notification-card <%= notification.is_read ? 'read' : 'unread' %>" data-id="<%= notification.id %>">
          <div class="notification-icon">
            <% 
              let icon = 'fa-bell';
              if (notification.type === 'review_moderated') icon = notification.data?.approved ? 'fa-check-circle' : 'fa-times-circle';
              else if (notification.type === 'new_review') icon = 'fa-star';
              else if (notification.type === 'review_liked') icon = notification.data?.type === 'like' ? 'fa-thumbs-up' : 'fa-thumbs-down';
              else if (notification.type === 'book_imported') icon = 'fa-book';
              else if (notification.type === 'system') icon = 'fa-info-circle';
            %>
            <i class="fas <%= icon %>"></i>
          </div>

          <div class="notification-content">
            <div class="notification-header">
              <h3><%= notification.title %></h3>
              <span class="notification-time">
                <%= new Date(notification.createdAt).toLocaleString('ru-RU', {
                  day: 'numeric',
                  month: 'long',
                  hour: '2-digit',
                  minute: '2-digit'
                }) %>
              </span>
            </div>

            <% const notificationPreview = truncateText(notification.message, 220); %>
            <p class="notification-message"><%= notificationPreview.text %></p>
            <% if (notificationPreview.isTruncated) { %>
              <details class="read-more-block"><summary><span class="more-label">Читать дальше</span><span class="less-label">Свернуть</span></summary><p><%= notificationPreview.fullText %></p></details>
            <% } %>

            <% if (notification.link) { %>
              <a href="<%= notification.link %>" class="notification-link">
                <i class="fas fa-arrow-right"></i> Перейти
              </a>
            <% } %>
          </div>

          <div class="notification-actions">
            <% if (!notification.is_read) { %>
              <button class="action-btn mark-read" onclick="markAsRead(<%= notification.id %>)" title="Отметить как прочитанное">
                <i class="fas fa-check"></i>
              </button>
            <% } %>
            <button class="action-btn delete" onclick="deleteNotification(<%= notification.id %>)" title="Удалить">
              <i class="fas fa-trash"></i>
            </button>
          </div>
        </article>
      <% }) %>
    </div>

    <% if (totalPages > 1) { %>
      <div class="pagination notifications-pagination">
        <% if (currentPage > 1) { %>
          <a href="?page=<%= currentPage - 1 %>" class="page-link"><i class="fas fa-chevron-left"></i></a>
        <% } %>
        <% for(let i = 1; i <= totalPages; i++) { %>
          <% if (i === currentPage) { %>
            <span class="page-link active" data-page-number="<%= i %>"><%= i %></span>
          <% } else { %>
            <a href="?page=<%= i %>" class="page-link" data-page-number="<%= i %>"><%= i %></a>
          <% } %>
        <% } %>
        <% if (currentPage < totalPages) { %>
          <a href="?page=<%= currentPage + 1 %>" class="page-link"><i class="fas fa-chevron-right"></i></a>
        <% } %>
      </div>
    <% } %>
  <% } else { %>
    <div class="empty-state">
      <i class="fas fa-bell-slash fa-4x"></i>
      <h2>Нет уведомлений</h2>
      <p>Когда у вас появятся новые уведомления, они будут отображаться здесь</p>
      <a href="/" class="btn btn-primary"><i class="fas fa-home"></i> На главную</a>
    </div>
  <% } %>
</div>

<script>
  async function markAsRead(id) {
    try {
      const response = await fetch(`/notifications/${id}/read`, { method: 'POST', headers: { 'Content-Type': 'application/json' } });
      if (response.ok) location.reload();
    } catch (error) {
      console.error('Ошибка:', error);
    }
  }

  async function deleteNotification(id) {
    if (!confirm('Удалить уведомление?')) return;
    try {
      const response = await fetch(`/notifications/${id}`, { method: 'DELETE' });
      if (response.ok) location.reload();
    } catch (error) {
      console.error('Ошибка:', error);
    }
  }


  (function limitVisibleNotificationsPagination() {
    const pagination = document.querySelector('.notifications-pagination');
    if (!pagination) return;

    const pageLinks = Array.from(pagination.querySelectorAll('[data-page-number]'));
    const activeElement = pagination.querySelector('.page-link.active[data-page-number]');
    const currentPage = activeElement ? Number(activeElement.dataset.pageNumber) : 1;

    const getMaxVisiblePages = () => {
      if (window.innerWidth <= 480) return 3;
      if (window.innerWidth <= 768) return 5;
      return 9;
    };

    const updateVisiblePages = () => {
      const maxVisiblePages = getMaxVisiblePages();
      const half = Math.floor(maxVisiblePages / 2);
      let start = Math.max(1, currentPage - half);
      let end = start + maxVisiblePages - 1;
      const total = pageLinks.length;

      if (end > total) {
        end = total;
        start = Math.max(1, end - maxVisiblePages + 1);
      }

      pageLinks.forEach((link) => {
        const pageNumber = Number(link.dataset.pageNumber);
        link.style.display = (pageNumber >= start && pageNumber <= end) ? '' : 'none';
      });
    };

    updateVisiblePages();
    window.addEventListener('resize', updateVisiblePages);
  })();

  document.getElementById('markAllReadBtn')?.addEventListener('click', async () => {
    try {
      const response = await fetch('/notifications/mark-all-read', { method: 'POST' });
      if (response.ok) location.reload();
    } catch (error) {
      console.error('Ошибка:', error);
    }
  });
</script>

<style>
  .notifications-page { padding: 2rem 0; color: white; }
  .page-header {
    display: flex; justify-content: space-between; align-items: center; gap: 1rem;
    margin-bottom: 1.5rem; padding: 1rem 1.5rem;
    background: rgba(255,255,255,.1); border: 1px solid rgba(255,255,255,.2);
    border-radius: var(--radius-lg); backdrop-filter: blur(10px);
  }
  .page-header h1 { display:flex; align-items:center; gap:.75rem; margin:0; }
  .notifications-stats { display:flex; gap:1rem; margin-bottom:1rem; flex-wrap:wrap; }
  .stat-badge { padding:.5rem 1rem; background: rgba(255,255,255,.1); border-radius: 50px; }
  .retention-note { margin: 0 0 1.25rem; color: rgba(255,255,255,.82); }

  .notifications-list { display:grid; gap: 1rem; }
  .notification-card {
    display:grid; grid-template-columns: 54px 1fr auto; gap: 1rem;
    padding: 1.25rem; border-radius: var(--radius-lg);
    background: rgba(255,255,255,.1); border: 1px solid rgba(255,255,255,.2);
    backdrop-filter: blur(10px);
  }
  .notification-card.unread { border-left: 4px solid var(--accent); background: rgba(245,158,11,.12); }
  .notification-icon { font-size:1.6rem; color: var(--accent); display:grid; place-items:center; }
  .notification-header { display:flex; justify-content:space-between; gap:.75rem; align-items:flex-start; flex-wrap:wrap; }
  .notification-header h3 { margin:0; }
  .notification-time { font-size:.85rem; opacity:.75; white-space: nowrap; }
  .notification-message { margin:.5rem 0 .75rem; line-height:1.55; }

  .read-more-block summary { color: var(--accent); cursor:pointer; font-weight:700; margin-bottom:.5rem; }
  .read-more-block p { margin: .4rem 0 0; }

  .notification-link {
    display:inline-flex; gap:.5rem; align-items:center; text-decoration:none; font-weight:700;
    color:#312e81; background: linear-gradient(135deg, #fde68a, #f59e0b);
    border-radius:999px; padding:.45rem .85rem;
  }
  .notification-link:hover { transform: translateX(4px); background: linear-gradient(135deg, #fef3c7, #fbbf24); }
  body.theme-dark .notification-link { color: #1e1b4b; }

  .notification-actions { display:flex; flex-direction:column; gap:.5rem; }
  .action-btn {
    width: 36px; height: 36px; border-radius: 50%; border: none;
    background: rgba(255,255,255,.14); color: white; cursor: pointer;
  }
  .action-btn.mark-read:hover { background: var(--success); }
  .action-btn.delete:hover { background: var(--danger); }

  .notifications-pagination { margin-top: 1.75rem; }

  .empty-state {
    text-align:center; padding: 4rem 2rem; border-radius: var(--radius-lg);
    background: rgba(255,255,255,.1); border: 1px solid rgba(255,255,255,.2);
  }

  @media (max-width: 992px) {
    .notification-card { grid-template-columns: 44px 1fr; }
    .notification-actions { flex-direction: row; }
  }

  @media (max-width: 768px) {
    .notifications-page { padding: 1rem 0; }
    .page-header { flex-direction: column; align-items: flex-start; }
    .notification-card { grid-template-columns: 1fr; }
    .notification-icon { justify-content: flex-start; }
    .notification-actions { align-self: flex-end; }
    .notification-time { white-space: normal; }
  }
  .notifications-list {
  max-height: none !important;
}
</style>
