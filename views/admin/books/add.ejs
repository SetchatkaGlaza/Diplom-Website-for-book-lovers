<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/cropperjs@1.6.2/dist/cropper.min.css">
<div class="admin-book-form">
  <div class="admin-header">
    <h1><i class="fas fa-plus-circle"></i> Добавление книги</h1>
    <a href="/admin/books" class="btn btn-outline">
      <i class="fas fa-arrow-left"></i> Назад к списку
    </a>
  </div>
  
  <% if (errors && errors.length > 0) { %>
    <div class="alert alert-danger">
      <ul>
        <% errors.forEach(error => { %>
          <li><%= error.msg %></li>
        <% }) %>
      </ul>
    </div>
  <% } %>
  
  <form action="/admin/books/add" method="POST" enctype="multipart/form-data" class="book-form">
    <div class="form-grid">
      <div class="form-main">
        <div class="form-group">
          <label for="title">Название *</label>
          <input type="text" id="title" name="title" value="<%= formData ? formData.title : '' %>" required>
        </div>
        
        <div class="form-group">
          <label for="author">Автор *</label>
          <input type="text" id="author" name="author" value="<%= formData ? formData.author : '' %>" required>
        </div>
        
        <div class="form-row">
          <div class="form-group">
            <label for="year">Год издания</label>
            <input type="number" id="year" name="year" value="<%= formData ? formData.year : '' %>" min="1000" max="2026">
          </div>
          
          <div class="form-group">
            <label for="pages">Количество страниц</label>
            <input type="number" id="pages" name="pages" value="<%= formData ? formData.pages : '' %>" min="1">
          </div>
        </div>
        
        <div class="form-group">
          <label for="publisher">Издательство</label>
          <input type="text" id="publisher" name="publisher" value="<%= formData ? formData.publisher : '' %>">
        </div>
        
        <div class="form-group">
          <label for="genre_id">Жанр</label>
          <select id="genre_id" name="genre_id">
            <option value="">Без жанра</option>
            <% genres.forEach(genre => { %>
              <option value="<%= genre.id %>" <%= formData && formData.genre_id == genre.id ? 'selected' : '' %>>
                <%= genre.name %>
              </option>
            <% }) %>
          </select>
        </div>
        
        <div class="form-group">
          <label for="isbn">ISBN</label>
          <input type="text" id="isbn" name="isbn" value="<%= formData ? formData.isbn : '' %>">
        </div>
        
        <div class="form-group">
          <label for="description">Описание</label>
          <textarea id="description" name="description" rows="8"><%= formData ? formData.description : '' %></textarea>
        </div>
      </div>
      
      <div class="form-sidebar">
        <div class="form-group">
          <label for="cover">Обложка книги</label>
          <div class="cover-upload">
            <input type="file" id="cover" name="cover" accept="image/jpeg,image/png,image/webp">
            <div class="cover-preview">
              <img src="/images/covers/default-book-cover.jpg" alt="Preview" id="cover-preview">
            </div>
          </div>
          
          <div class="cover-requirements">
            <p><i class="fas fa-info-circle"></i> <strong>Требования к изображению:</strong></p>
            <ul>
              <li>Минимальный размер: 200x300 пикселей</li>
              <li>Любое большое изображение автоматически подгоняется</li>
              <li>Соотношение сторон: 2:3 (настраивается перед загрузкой)</li>
              <li>Форматы: JPG, PNG, WEBP</li>
              <li>Максимальный размер файла: 5 МБ</li>
            </ul>
          </div>
          
          <div class="cover-example">
            <p><i class="fas fa-check-circle" style="color: #10b981;"></i> <strong>Пример правильного изображения:</strong></p>
            <div style="display: flex; gap: 1rem; align-items: center; background: rgba(255,255,255,0.1); padding: 0.5rem; border-radius: var(--admin-radius);">
              <div style="width: 60px; height: 90px; background: linear-gradient(135deg, #667eea, #764ba2); border-radius: 4px;"></div>
              <div>
                <p style="margin: 0;">300x450 пикселей</p>
                <p style="margin: 0; opacity: 0.7;">пропорции 2:3</p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
    
    <div class="form-actions">
      <button type="submit" class="btn btn-primary btn-large">
        <i class="fas fa-save"></i> Сохранить книгу
      </button>
    </div>
  </form>
</div>

<div id="coverCropModal" class="cover-crop-modal" style="display:none;">
  <div class="cover-crop-content">
    <h3>Настройка обложки</h3>
    <div class="cover-crop-area"><img id="coverCropImage" alt="Crop cover"></div>
    <div class="cover-crop-actions">
      <button type="button" class="btn btn-outline" id="coverZoomOut">-</button>
      <button type="button" class="btn btn-outline" id="coverZoomIn">+</button>
      <button type="button" class="btn btn-outline" id="coverCancelCrop">Отмена</button>
      <button type="button" class="btn btn-primary" id="coverApplyCrop">Применить</button>
    </div>
  </div>
</div>

<style>
  .cover-crop-modal { position: fixed; inset: 0; background: rgba(0,0,0,.75); z-index: 9999; display: flex; align-items: center; justify-content: center; }
  .cover-crop-content { width: min(760px,95vw); background: #111827; padding: 1rem; border-radius: 12px; color: #fff; }
  .cover-crop-area { max-height: 65vh; overflow: hidden; }
  .cover-crop-area img { max-width: 100%; display: block; }
  .cover-crop-actions { margin-top: 1rem; display:flex; gap:.75rem; justify-content:flex-end; flex-wrap: wrap; }
</style>

<script src="https://cdn.jsdelivr.net/npm/cropperjs@1.6.2/dist/cropper.min.js"></script>
<script>
  const coverInput = document.getElementById('cover');
  const coverPreview = document.getElementById('cover-preview');
  const coverCropModal = document.getElementById('coverCropModal');
  const coverCropImage = document.getElementById('coverCropImage');
  let coverCropper = null;

  coverInput.addEventListener('change', function(e) {
    const file = e.target.files[0];
    if (!file) return;
    coverCropImage.src = URL.createObjectURL(file);
    coverCropModal.style.display = 'flex';
    if (coverCropper) coverCropper.destroy();
    coverCropper = new Cropper(coverCropImage, { aspectRatio: 2 / 3, viewMode: 1, dragMode: 'move', autoCropArea: 1, background: false });
  });

  document.getElementById('coverZoomIn').addEventListener('click', () => coverCropper && coverCropper.zoom(0.1));
  document.getElementById('coverZoomOut').addEventListener('click', () => coverCropper && coverCropper.zoom(-0.1));
  document.getElementById('coverCancelCrop').addEventListener('click', () => {
    coverCropModal.style.display = 'none';
    if (coverCropper) coverCropper.destroy();
    coverCropper = null;
    coverInput.value = '';
  });
  document.getElementById('coverApplyCrop').addEventListener('click', () => {
    if (!coverCropper) return;
    coverCropper.getCroppedCanvas({ width: 600, height: 900 }).toBlob((blob) => {
      if (!blob) return;
      const file = new File([blob], `cover-cropped-${Date.now()}.jpg`, { type: 'image/jpeg' });
      const dt = new DataTransfer();
      dt.items.add(file);
      coverInput.files = dt.files;
      coverPreview.src = URL.createObjectURL(file);
      coverCropModal.style.display = 'none';
      coverCropper.destroy();
      coverCropper = null;
    }, 'image/jpeg', 0.9);
  });
</script>
