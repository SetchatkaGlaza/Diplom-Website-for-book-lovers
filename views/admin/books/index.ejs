<div class="admin-books">
  <div class="admin-header">
    <h1><i class="fas fa-book"></i> Управление книгами</h1>
    <a href="/admin/books/add" class="btn btn-primary">
      <i class="fas fa-plus"></i> Добавить книгу
    </a>
    <link rel="stylesheet" href="/css/admin.css">
  </div>

  <div class="table-search">
    <form action="/admin/books" method="GET" style="display: flex; gap: 1rem; width: 100%; flex-wrap: wrap;">
      <input type="text" name="search" placeholder="Поиск по названию или автору" value="<%= search || '' %>">
      <button type="submit" class="btn btn-primary"><i class="fas fa-search"></i> Найти</button>
      <% if (search) { %>
        <a href="/admin/books" class="btn btn-outline"><i class="fas fa-times"></i> Сбросить</a>
      <% } %>
    </form>
  </div>

  <div class="table-stats">
    <div class="stat-pill"><i class="fas fa-book"></i><span><%= totalBooks %></span> книг всего</div>
  </div>

  <div class="table-responsive simple-table-wrap">
    <table class="modern-table simple-books-table">
      <thead>
        <tr>
          <th style="width: 60px;">ID</th>
          <th>Название</th>
          <th>Автор</th>
          <th style="width: 140px;">Жанр</th>
          <th style="width: 90px;">Год</th>
          <th style="width: 90px;">Рейтинг</th>
          <th style="width: 100px;">Рецензий</th>
          <th style="width: 100px;">На полках</th>
          <th style="width: 180px;">Действия</th>
        </tr>
      </thead>
      <tbody>
        <% if (books && books.length > 0) { %>
          <% books.forEach(book => { %>
            <tr>
              <td><%= book.id %></td>
              <td><a href="/books/<%= book.id %>" target="_blank" rel="noopener"><%= book.title %></a></td>
              <td><%= book.author %></td>
              <td><%= book.genre ? book.genre.name : '–' %></td>
              <td><%= book.year || '–' %></td>
              <td><%= book.avgRating > 0 ? book.avgRating : '–' %></td>
              <td><%= book.reviewsCount || 0 %></td>
              <td><%= book.inUserBooks || 0 %></td>
              <td>
                <div class="action-buttons">
                  <a href="/books/<%= book.id %>" class="action-btn view" target="_blank" title="Просмотр"><i class="fas fa-eye"></i></a>
                  <a href="/admin/books/<%= book.id %>/edit" class="action-btn edit" title="Редактировать"><i class="fas fa-edit"></i></a>
                  <form action="/admin/books/<%= book.id %>?_method=DELETE" method="POST" style="display: inline;">
                    <button type="submit" class="action-btn delete" onclick="return confirm('Удалить книгу? Это также удалит все рецензии.')" title="Удалить">
                      <i class="fas fa-trash"></i>
                    </button>
                  </form>
                </div>
              </td>
            </tr>
          <% }) %>
        <% } else { %>
          <tr>
            <td colspan="9" style="text-align:center; padding:2rem;">Книги не найдены</td>
          </tr>
        <% } %>
      </tbody>
    </table>
  </div>

  <% if (totalPages > 1) { %>
    <div class="table-pagination">
      <% if (currentPage > 1) { %>
        <a href="?page=<%= currentPage - 1 %><%= search ? '&search=' + search : '' %>" class="pagination-btn"><i class="fas fa-chevron-left"></i></a>
      <% } %>
      <% for(let i = 1; i <= totalPages; i++) { %>
        <% if (i === currentPage) { %>
          <span class="pagination-btn active" data-page-number="<%= i %>"><%= i %></span>
        <% } else { %>
          <a href="?page=<%= i %><%= search ? '&search=' + search : '' %>" class="pagination-btn" data-page-number="<%= i %>"><%= i %></a>
        <% } %>
      <% } %>
      <% if (currentPage < totalPages) { %>
        <a href="?page=<%= currentPage + 1 %><%= search ? '&search=' + search : '' %>" class="pagination-btn"><i class="fas fa-chevron-right"></i></a>
      <% } %>
    </div>
  <% } %>
</div>

<script>
  (function limitVisibleAdminBooksPagination() {
    const pagination = document.querySelector('.table-pagination');
    if (!pagination) return;

    const pageLinks = Array.from(pagination.querySelectorAll('[data-page-number]'));
    const activeElement = pagination.querySelector('.pagination-btn.active[data-page-number]');
    const currentPage = activeElement ? Number(activeElement.dataset.pageNumber) : 1;

    const getMaxVisiblePages = () => {
      if (window.innerWidth <= 480) return 3;
      if (window.innerWidth <= 768) return 5;
      return 9;
    };

    const updateVisiblePages = () => {
      const maxVisiblePages = getMaxVisiblePages();
      const half = Math.floor(maxVisiblePages / 2);
      let start = Math.max(1, currentPage - half);
      let end = start + maxVisiblePages - 1;
      const total = pageLinks.length;

      if (end > total) {
        end = total;
        start = Math.max(1, end - maxVisiblePages + 1);
      }

      pageLinks.forEach((link) => {
        const pageNumber = Number(link.dataset.pageNumber);
        link.style.display = (pageNumber >= start && pageNumber <= end) ? '' : 'none';
      });
    };

    updateVisiblePages();
    window.addEventListener('resize', updateVisiblePages);
  })();
</script>

<style>
  .simple-table-wrap { padding: 0; }
  .simple-books-table { width: 100%; table-layout: auto; }
  .simple-books-table th, .simple-books-table td { padding: 10px 8px; vertical-align: middle; }
  .simple-books-table tr { height: 52px; }
  .simple-books-table td { word-break: break-word; }
  .simple-books-table a { color: white; text-decoration: underline; text-underline-offset: 2px; }
</style>
<style>
  .simple-books-table .action-buttons {
    flex-wrap: nowrap;
    justify-content: flex-start;
  }

  .simple-books-table .action-buttons form {
    display: inline-flex !important;
    width: auto;
    flex: 0 0 auto;
  }

  .simple-books-table .action-btn {
    width: 36px;
    min-width: 36px;
    height: 36px;
    flex: 0 0 36px;
    padding: 0;
  }

  @media (max-width: 768px) {
    .simple-books-table .action-buttons,
    .simple-books-table .action-buttons > *,
    .simple-books-table .action-buttons form,
    .simple-books-table .action-btn {
      width: auto;
    }

    .simple-books-table .action-buttons {
      gap: 0.4rem;
    }
  }
</style>
