<div class="admin-books books-admin-page">
  <link rel="stylesheet" href="/css/admin.css">

  <div class="admin-header books-admin-header">
    <h1><i class="fas fa-book"></i> Управление книгами</h1>
    <a href="/admin/books/add" class="btn btn-primary">
      <i class="fas fa-plus"></i> Добавить книгу
    </a>
  </div>

  <div class="table-search">
    <form action="/admin/books" method="GET" class="books-search-form">
      <input type="text" name="search" placeholder="Поиск по названию или автору" value="<%= search || '' %>">
      <button type="submit" class="btn btn-primary"><i class="fas fa-search"></i> Найти</button>
      <% if (search) { %>
        <a href="/admin/books" class="btn btn-outline"><i class="fas fa-times"></i> Сбросить</a>
      <% } %>
    </form>
  </div>

  <div class="table-stats">
    <div class="stat-pill"><i class="fas fa-book"></i><span><%= totalBooks %></span> книг всего</div>
  </div>

  <div class="books-table-card">
    <div class="table-responsive books-table-wrap">
      <table class="modern-table books-table">
        <thead>
          <tr>
            <th>ID</th>
            <th>Название</th>
            <th>Автор</th>
            <th>Жанр</th>
            <th>Год</th>
            <th>Рейтинг</th>
            <th>Рецензий</th>
            <th>На полках</th>
            <th>Действия</th>
          </tr>
        </thead>
        <tbody>
          <% if (books && books.length > 0) { %>
            <% books.forEach(book => { %>
              <tr>
                <td><%= book.id %></td>
                <td class="title-cell"><a href="/books/<%= book.id %>" target="_blank" rel="noopener"><%= book.title %></a></td>
                <td><%= book.author %></td>
                <td><%= book.genre ? book.genre.name : '–' %></td>
                <td><%= book.year || '–' %></td>
                <td><%= book.avgRating > 0 ? book.avgRating : '–' %></td>
                <td><%= book.reviewsCount || 0 %></td>
                <td><%= book.inUserBooks || 0 %></td>
                <td>
                  <div class="action-buttons">
                    <a href="/books/<%= book.id %>" class="action-btn view" target="_blank" title="Просмотр"><i class="fas fa-eye"></i></a>
                    <a href="/admin/books/<%= book.id %>/edit" class="action-btn edit" title="Редактировать"><i class="fas fa-edit"></i></a>
                    <form action="/admin/books/<%= book.id %>?_method=DELETE" method="POST" class="delete-form-inline">
                      <button type="submit" class="action-btn delete" onclick="return confirm('Удалить книгу? Это также удалит все рецензии.')" title="Удалить">
                        <i class="fas fa-trash"></i>
                      </button>
                    </form>
                  </div>
                </td>
              </tr>
            <% }) %>
          <% } else { %>
            <tr>
              <td colspan="9" class="books-empty">Книги не найдены</td>
            </tr>
          <% } %>
        </tbody>
      </table>
    </div>
  </div>

  <% if (totalPages > 1) { %>
    <div class="pagination books-pagination">
      <% if (currentPageNum > 1) { %>
        <a href="?page=<%= currentPageNum - 1 %><%= search ? '&search=' + search : '' %>" class="page-link"><i class="fas fa-chevron-left"></i></a>
      <% } %>

      <% for(let i = 1; i <= totalPages; i++) { %>
        <% if (i === currentPageNum) { %>
          <span class="page-link active" data-page-number="<%= i %>"><%= i %></span>
        <% } else { %>
          <a href="?page=<%= i %><%= search ? '&search=' + search : '' %>" class="page-link" data-page-number="<%= i %>"><%= i %></a>
        <% } %>
      <% } %>

      <% if (currentPageNum < totalPages) { %>
        <a href="?page=<%= currentPageNum + 1 %><%= search ? '&search=' + search : '' %>" class="page-link"><i class="fas fa-chevron-right"></i></a>
      <% } %>
    </div>
  <% } %>
</div>

<script>
  (function limitVisiblePagination() {
    const pagination = document.querySelector('.books-pagination');
    if (!pagination) return;

    const pageLinks = Array.from(pagination.querySelectorAll('[data-page-number]'));
    const activeElement = pagination.querySelector('.page-link.active[data-page-number]');
    const currentPage = activeElement ? Number(activeElement.dataset.pageNumber) : 1;

    const getMaxVisiblePages = () => {
      if (window.innerWidth <= 480) return 3;
      if (window.innerWidth <= 768) return 5;
      return 9;
    };

    const updateVisiblePages = () => {
      const maxVisiblePages = getMaxVisiblePages();
      const half = Math.floor(maxVisiblePages / 2);
      let start = Math.max(1, currentPage - half);
      let end = start + maxVisiblePages - 1;
      const total = pageLinks.length;

      if (end > total) {
        end = total;
        start = Math.max(1, end - maxVisiblePages + 1);
      }

      pageLinks.forEach((link) => {
        const pageNumber = Number(link.dataset.pageNumber);
        link.style.display = (pageNumber >= start && pageNumber <= end) ? '' : 'none';
      });
    };

    updateVisiblePages();
    window.addEventListener('resize', updateVisiblePages);
  })();
</script>

<style>
  .books-admin-page { max-width: 1700px; margin: 0 auto; }
  .books-admin-header { align-items: center; }
  .books-search-form { display: flex; gap: 1rem; width: 100%; flex-wrap: wrap; }

  .books-table-card {
    border: 1px solid var(--admin-card-border);
    border-radius: var(--admin-radius-lg);
    background: rgba(255, 255, 255, 0.08);
    overflow: hidden;
  }

  .books-table-wrap {
    margin: 0;
    border: 0;
    border-radius: 0;
    background: transparent;
    padding: 0;
    overflow-x: auto;
  }

  .books-table { min-width: 1180px; table-layout: fixed; }
  .books-table th:nth-child(1) { width: 70px; }
  .books-table th:nth-child(2) { width: 23%; }
  .books-table th:nth-child(3) { width: 18%; }
  .books-table th:nth-child(4) { width: 14%; }
  .books-table th:nth-child(5) { width: 85px; }
  .books-table th:nth-child(6) { width: 95px; }
  .books-table th:nth-child(7) { width: 100px; }
  .books-table th:nth-child(8) { width: 100px; }
  .books-table th:nth-child(9) { width: 150px; }

  .books-table td, .books-table th { vertical-align: middle; }
  .books-table .title-cell a {
    color: white;
    text-decoration: underline;
    text-underline-offset: 2px;
    word-break: break-word;
  }

  .delete-form-inline { display: inline-flex; }

  .books-table .action-buttons {
    width: auto;
    display: flex;
    flex-wrap: nowrap;
    gap: 0.5rem;
  }

  .books-table .action-buttons > *,
  .books-table .action-buttons .action-btn,
  .books-table .action-buttons form {
    width: 36px !important;
    min-width: 36px;
    max-width: 36px;
    flex: 0 0 36px;
  }

  .books-table .action-buttons form {
    display: inline-flex;
  }
  .books-empty { text-align:center; padding:2rem; }

  .books-pagination { margin-top: 1.2rem; flex-wrap: nowrap; overflow-x: auto; padding-bottom: 0.2rem; }
  .books-pagination .page-link { flex: 0 0 auto; }

  .books-table tbody tr,
  .books-table tbody tr:hover,
  .books-table tbody tr:focus-within {
    transform: none !important;
    transition: none !important;
    background: inherit !important;
    box-shadow: none !important;
  }

  .books-pagination .page-link,
  .books-pagination .page-link:hover,
  .books-pagination .page-link:focus,
  .books-pagination .page-link:active,
  .books-pagination .page-link.active {
    transform: none !important;
    transition: none !important;
    box-shadow: none !important;
  }

  .books-pagination .page-link:hover,
  .books-pagination .page-link:focus,
  .books-pagination .page-link:active {
    background: var(--admin-card-bg) !important;
    border-color: var(--admin-card-border) !important;
  }


  @media (max-width: 992px) {
    .books-admin-page { max-width: 100%; }
    .books-table { min-width: 1040px; }
  }

  @media (max-width: 768px) {
    .books-search-form input,
    .books-search-form .btn { width: 100%; }
    .books-table-wrap { border-top: 1px solid rgba(255,255,255,.08); }
  }
</style>
