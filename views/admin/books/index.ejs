<div class="admin-books">
  <div class="admin-header">
    <h1><i class="fas fa-book"></i> Управление книгами</h1>
    <a href="/admin/books/add" class="btn btn-primary">
      <i class="fas fa-plus"></i> Добавить книгу
    </a>
    <link rel="stylesheet" href="/css/admin.css">
  </div>
  
  <!-- Поиск -->
  <div class="table-search">
    <form action="/admin/books" method="GET" style="display: flex; gap: 1rem; width: 100%;">
      <input type="text" name="search" placeholder="🔍 Поиск по названию или автору..." value="<%= search || '' %>">
      <button type="submit" class="btn btn-primary">
        <i class="fas fa-search"></i> Найти
      </button>
      <% if (search) { %>
        <a href="/admin/books" class="btn btn-outline">
          <i class="fas fa-times"></i> Сбросить
        </a>
      <% } %>
    </form>
  </div>
  
  <!-- Статистика -->
  <div class="table-stats">
    <div class="stat-pill">
      <i class="fas fa-book"></i>
      <span><%= totalBooks %></span> книг всего
    </div>
  </div>
  
  <!-- Таблица книг -->
  <div class="table-responsive">
    <table class="modern-table">
      <thead>
        <tr>
          <th><i class="fas fa-image"></i> Обложка</th>
          <th><i class="fas fa-heading"></i> Название</th>
          <th><i class="fas fa-user"></i> Автор</th>
          <th><i class="fas fa-tag"></i> Жанр</th>
          <th><i class="fas fa-calendar"></i> Год</th>
          <th><i class="fas fa-star"></i> Рейтинг</th>
          <th><i class="fas fa-comment"></i> Рецензий</th>
          <th><i class="fas fa-users"></i> На полках</th>
          <th><i class="fas fa-cog"></i> Действия</th>
        </tr>
      </thead>
      <tbody>
        <% if (books && books.length > 0) { %>
          <% books.forEach(book => { %>
            <tr>
              <td>
                <img src="/images/covers/<%= book.cover_image %>" alt="<%= book.title %>" class="table-cover">
              </td>
              <td class="truncate-text" title="<%= book.title %>"><%= book.title %></td>
              <td><%= book.author %></td>
              <td>
                <% if (book.genre) { %>
                  <span class="badge badge-info"><%= book.genre.name %></span>
                <% } else { %>
                  <span class="badge" style="background: rgba(255,255,255,0.1);">—</span>
                <% } %>
              </td>
              <td><%= book.year || '—' %></td>
              <td>
                <div class="table-rating">
                  <% if (book.avgRating > 0) { %>
                    <i class="fas fa-star"></i>
                    <span class="table-rating-value"><%= book.avgRating %></span>
                  <% } else { %>
                    <span style="opacity:0.5;">нет</span>
                  <% } %>
                </div>
              </td>
              <td><%= book.reviewsCount || 0 %></td>
              <td><%= book.inUserBooks || 0 %></td>
              <td>
                <div class="action-buttons">
                  <a href="/books/<%= book.id %>" class="action-btn view" target="_blank" title="Просмотр">
                    <i class="fas fa-eye"></i>
                  </a>
                  <a href="/admin/books/<%= book.id %>/edit" class="action-btn edit" title="Редактировать">
                    <i class="fas fa-edit"></i>
                  </a>
                  <form action="/admin/books/<%= book.id %>?_method=DELETE" method="POST" style="display: inline;">
                    <button type="submit" class="action-btn delete" onclick="return confirm('Удалить книгу? Это также удалит все рецензии.')" title="Удалить">
                      <i class="fas fa-trash"></i>
                    </button>
                  </form>
                </div>
              </td>
            </tr>
          <% }) %>
        <% } else { %>
          <tr>
            <td colspan="9" style="text-align: center; padding: 3rem;">
              <i class="fas fa-book" style="font-size: 3rem; opacity: 0.3; margin-bottom: 1rem; display: block;"></i>
              <h3>Книги не найдены</h3>
              <p style="opacity: 0.7;">Попробуйте изменить параметры поиска или <a href="/admin/books/add">добавьте первую книгу</a></p>
            </td>
          </tr>
        <% } %>
      </tbody>
    </table>
  </div>
  
  <!-- Пагинация -->
  <% if (totalPages > 1) { %>
    <div class="table-pagination">
      <% if (currentPage > 1) { %>
        <a href="?page=<%= currentPage - 1 %><%= search ? '&search=' + search : '' %>" class="pagination-btn">
          <i class="fas fa-chevron-left"></i>
        </a>
      <% } %>
      
      <% for(let i = 1; i <= totalPages; i++) { %>
        <% if (i === currentPage) { %>
          <span class="pagination-btn active"><%= i %></span>
        <% } else { %>
          <a href="?page=<%= i %><%= search ? '&search=' + search : '' %>" class="pagination-btn"><%= i %></a>
        <% } %>
      <% } %>
      
      <% if (currentPage < totalPages) { %>
        <a href="?page=<%= currentPage + 1 %><%= search ? '&search=' + search : '' %>" class="pagination-btn">
          <i class="fas fa-chevron-right"></i>
        </a>
      <% } %>
    </div>
  <% } %>
</div>