<div class="admin-import">
  <div class="admin-header">
    <h1><i class="fas fa-file-upload"></i> Импорт книг</h1>
    <div>
      <a href="/admin/import/template?type=csv" class="btn btn-outline">
        <i class="fas fa-download"></i> CSV шаблон
      </a>
      <a href="/admin/import/template?type=json" class="btn btn-outline">
        <i class="fas fa-download"></i> JSON шаблон
      </a>
      <a href="/admin/books" class="btn btn-outline">
        <i class="fas fa-arrow-left"></i> Назад
      </a>
    </div>
  </div>
  
  <div class="import-container">
    <div class="import-card">
      <div class="import-icon">
        <i class="fas fa-cloud-upload-alt"></i>
      </div>
      <h2>Загрузите файл с книгами</h2>
      <p>Поддерживаемые форматы: CSV, JSON</p>
      
      <form action="/admin/import" method="POST" enctype="multipart/form-data" class="import-form">
        <div class="form-group file-upload">
          <input type="file" id="file" name="file" accept=".csv,.json" required>
          <label for="file" class="file-label">
            <i class="fas fa-folder-open"></i>
            <span id="file-name">Выберите файл</span>
          </label>
        </div>
        
        <div class="form-row">
          <div class="form-group">
            <label for="delimiter">Разделитель (для CSV)</label>
            <select id="delimiter" name="delimiter">
              <option value=",">Запятая (,)</option>
              <option value=";">Точка с запятой (;)</option>
              <option value="\t">Табуляция</option>
            </select>
          </div>
          
          <div class="form-group">
            <label for="default_genre">Жанр по умолчанию</label>
            <select id="default_genre" name="default_genre">
              <option value="">Без жанра</option>
              <% genres.forEach(genre => { %>
                <option value="<%= genre.id %>"><%= genre.name %></option>
              <% }) %>
            </select>
          </div>
        </div>
        
        <div class="checkbox-group">
          <label class="checkbox-label">
            <input type="checkbox" name="create_genres" checked>
            <span>Создавать новые жанры автоматически</span>
          </label>
          
          <label class="checkbox-label">
            <input type="checkbox" name="skip_duplicates" checked>
            <span>Пропускать дубликаты (по названию и автору)</span>
          </label>
        </div>
        
        <div class="mapping-section">
          <h3>Соответствие полей</h3>
          <p class="mapping-hint">Укажите названия столбцов в вашем файле</p>
          
          <div class="mapping-grid">
            <div class="form-group">
              <label>Название *</label>
              <input type="text" name="field_title" value="title" placeholder="title">
            </div>
            
            <div class="form-group">
              <label>Автор *</label>
              <input type="text" name="field_author" value="author" placeholder="author">
            </div>
            
            <div class="form-group">
              <label>Описание</label>
              <input type="text" name="field_description" value="description" placeholder="description">
            </div>
            
            <div class="form-group">
              <label>Год</label>
              <input type="text" name="field_year" value="year" placeholder="year">
            </div>
            
            <div class="form-group">
              <label>Страницы</label>
              <input type="text" name="field_pages" value="pages" placeholder="pages">
            </div>
            
            <div class="form-group">
              <label>Издательство</label>
              <input type="text" name="field_publisher" value="publisher" placeholder="publisher">
            </div>
            
            <div class="form-group">
              <label>ISBN</label>
              <input type="text" name="field_isbn" value="isbn" placeholder="isbn">
            </div>
            
            <div class="form-group">
              <label>Жанр</label>
              <input type="text" name="field_genre" value="genre" placeholder="genre">
            </div>
          </div>
        </div>
        
        <div class="form-actions">
          <button type="submit" class="btn btn-primary btn-large">
            <i class="fas fa-upload"></i> Начать импорт
          </button>
        </div>
      </form>
    </div>
    
    <div class="import-info">
      <h3><i class="fas fa-info-circle"></i> Информация</h3>
      <ul>
        <li>Максимальный размер файла: 10MB</li>
        <li>Поддерживается UTF-8 кодировка</li>
        <li>Обязательные поля: название, автор</li>
        <li>Для CSV первая строка должна содержать заголовки</li>
        <li>Для JSON ожидается массив объектов или объект с полем "books"</li>
      </ul>
      
      <h3><i class="fas fa-eye"></i> Пример CSV</h3>
      <pre>title,author,description,year,pages,publisher,isbn,genre
Война и мир,Лев Толстой,Великий роман...,1869,1300,АСТ,978-5-17-123456-7,Роман</pre>
      
      <h3><i class="fas fa-eye"></i> Пример JSON</h3>
      <pre>{
  "books": [
    {
      "title": "Война и мир",
      "author": "Лев Толстой",
      "year": 1869
    }
  ]
}</pre>
    </div>
  </div>
</div>

<script>
  // Отображение имени выбранного файла
  document.getElementById('file').addEventListener('change', function(e) {
    const fileName = e.target.files[0] ? e.target.files[0].name : 'Файл не выбран';
    document.getElementById('file-name').textContent = fileName;
  });
</script>

