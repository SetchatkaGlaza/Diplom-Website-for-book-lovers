<div class="messages-page">
  <!-- Заголовок -->
  <div class="page-header">
    <div class="header-title">
      <h1><i class="fas fa-envelope"></i> Сообщения с сайта</h1>
      <p class="text-muted">Управление входящими сообщениями от пользователей</p>
    </div>
    <div class="header-actions">
      <button class="btn btn-outline" id="refreshMessages">
        <i class="fas fa-sync-alt"></i> Обновить
      </button>
    </div>
  </div>

  <!-- Статистика -->
  <div class="stats-grid">
    <div class="stat-card">
      <div class="stat-icon" style="background: linear-gradient(135deg, #3b82f6, #2563eb);">
        <i class="fas fa-envelope"></i>
      </div>
      <div class="stat-content">
        <span class="stat-value"><%= stats.total %></span>
        <span class="stat-label">Всего сообщений</span>
      </div>
    </div>
    
    <div class="stat-card">
      <div class="stat-icon" style="background: linear-gradient(135deg, #f59e0b, #d97706);">
        <i class="fas fa-clock"></i>
      </div>
      <div class="stat-content">
        <span class="stat-value"><%= stats.unread %></span>
        <span class="stat-label">Непрочитанных</span>
      </div>
    </div>
    
    <div class="stat-card">
      <div class="stat-icon" style="background: linear-gradient(135deg, #10b981, #059669);">
        <i class="fas fa-check-circle"></i>
      </div>
      <div class="stat-content">
        <span class="stat-value"><%= stats.replied %></span>
        <span class="stat-label">Отвеченных</span>
      </div>
    </div>
    
    <div class="stat-card">
      <div class="stat-icon" style="background: linear-gradient(135deg, #8b5cf6, #7c3aed);">
        <i class="fas fa-archive"></i>
      </div>
      <div class="stat-content">
        <span class="stat-value"><%= stats.archived %></span>
        <span class="stat-label">В архиве</span>
      </div>
    </div>
  </div>

  <!-- Фильтры и поиск -->
  <div class="filters-bar">
    <div class="filter-tabs">
      <a href="?filter=all" class="filter-tab <%= currentFilter === 'all' ? 'active' : '' %>">
        <i class="fas fa-inbox"></i> Все
        <span class="badge"><%= stats.total %></span>
      </a>
      <a href="?filter=unread" class="filter-tab <%= currentFilter === 'unread' ? 'active' : '' %>">
        <i class="fas fa-clock"></i> Непрочитанные
        <span class="badge"><%= stats.unread %></span>
      </a>
      <a href="?filter=replied" class="filter-tab <%= currentFilter === 'replied' ? 'active' : '' %>">
        <i class="fas fa-check-circle"></i> Отвеченные
        <span class="badge"><%= stats.replied %></span>
      </a>
      <a href="?filter=archived" class="filter-tab <%= currentFilter === 'archived' ? 'active' : '' %>">
        <i class="fas fa-archive"></i> Архив
        <span class="badge"><%= stats.archived %></span>
      </a>
    </div>
    
    <form action="/admin/messages" method="GET" class="search-form">
      <input type="hidden" name="filter" value="<%= currentFilter %>">
      <div class="search-input-group">
        <i class="fas fa-search"></i>
        <input 
          type="text" 
          name="search" 
          placeholder="Поиск по имени, email или сообщению..." 
          value="<%= search || '' %>"
        >
        <button type="submit" class="btn btn-primary">Найти</button>
        <% if (search) { %>
          <a href="/admin/messages?filter=<%= currentFilter %>" class="btn btn-outline">
            <i class="fas fa-times"></i> Сбросить
          </a>
        <% } %>
      </div>
    </form>
  </div>

  <!-- Таблица сообщений -->
  <div class="messages-table-container">
    <% if (messages.length > 0) { %>
      <table class="messages-table">
        <thead>
          <tr>
            <th>Статус</th>
            <th>Дата</th>
            <th>Отправитель</th>
            <th>Тема</th>
            <th>Сообщение</th>
            <th>Действия</th>
          </tr>
        </thead>
        <tbody>
          <% messages.forEach(msg => { %>
            <tr class="<%= !msg.is_read ? 'unread' : '' %> <%= msg.is_archived ? 'archived' : '' %>">
              <td>
                <% if (!msg.is_read) { %>
                  <span class="status-badge unread" title="Новое сообщение">
                    <i class="fas fa-circle"></i>
                  </span>
                <% } else if (msg.is_replied) { %>
                  <span class="status-badge replied" title="Отвечено">
                    <i class="fas fa-check-circle"></i>
                  </span>
                <% } else { %>
                  <span class="status-badge read" title="Прочитано">
                    <i class="fas fa-circle"></i>
                  </span>
                <% } %>
              </td>
              <td class="date-cell">
                <div class="date-main"><%= new Date(msg.createdAt).toLocaleDateString('ru-RU') %></div>
                <div class="date-time"><%= new Date(msg.createdAt).toLocaleTimeString('ru-RU', { hour: '2-digit', minute: '2-digit' }) %></div>
              </td>
              <td>
                <div class="sender-info">
                  <div class="sender-name"><%= msg.name %></div>
                  <div class="sender-email"><%= msg.email %></div>
                </div>
              </td>
              <td class="subject-cell">
                <div class="subject"><%= msg.subject || 'Новое сообщение' %></div>
              </td>
              <td class="message-preview">
                <div class="preview-text">
                  <%= msg.message.length > 100 ? msg.message.substring(0, 100) + '...' : msg.message %>
                </div>
              </td>
              <td class="actions-cell">
                <a href="/admin/messages/<%= msg.id %>" class="btn-icon btn-view" title="Просмотреть">
                  <i class="fas fa-eye"></i>
                </a>
                <% if (!msg.is_archived) { %>
                  <form action="/admin/messages/<%= msg.id %>/archive" method="POST" class="inline-form">
                    <button type="submit" class="btn-icon btn-archive" title="В архив" onclick="return confirm('Переместить в архив?')">
                      <i class="fas fa-archive"></i>
                    </button>
                  </form>
                <% } else { %>
                  <form action="/admin/messages/<%= msg.id %>/restore" method="POST" class="inline-form">
                    <button type="submit" class="btn-icon btn-restore" title="Восстановить">
                      <i class="fas fa-trash-restore"></i>
                    </button>
                  </form>
                <% } %>
                <form action="/admin/messages/<%= msg.id %>?_method=DELETE" method="POST" class="inline-form">
                  <button type="submit" class="btn-icon btn-delete" title="Удалить" onclick="return confirm('Удалить сообщение навсегда?')">
                    <i class="fas fa-trash"></i>
                  </button>
                </form>
              </td>
            </tr>
          <% }) %>
        </tbody>
      </table>
      
      <!-- Пагинация -->
      <% if (totalPages > 1) { %>
        <div class="pagination">
          <% if (currentPage > 1) { %>
            <a href="?filter=<%= currentFilter %><%= search ? '&search=' + search : '' %>&page=<%= currentPage - 1 %>" class="page-link">
              <i class="fas fa-chevron-left"></i>
            </a>
          <% } %>
          
          <% for(let i = 1; i <= totalPages; i++) { %>
            <% if (i === currentPage) { %>
              <span class="page-link active"><%= i %></span>
            <% } else { %>
              <a href="?filter=<%= currentFilter %><%= search ? '&search=' + search : '' %>&page=<%= i %>" class="page-link"><%= i %></a>
            <% } %>
          <% } %>
          
          <% if (currentPage < totalPages) { %>
            <a href="?filter=<%= currentFilter %><%= search ? '&search=' + search : '' %>&page=<%= currentPage + 1 %>" class="page-link">
              <i class="fas fa-chevron-right"></i>
            </a>
          <% } %>
        </div>
      <% } %>
      
    <% } else { %>
      <div class="empty-state">
        <i class="fas fa-envelope-open fa-4x"></i>
        <h3>Нет сообщений</h3>
        <p>Здесь появятся сообщения от пользователей</p>
      </div>
    <% } %>
  </div>
</div>

<script>
  // Обновление статистики в реальном времени
  document.getElementById('refreshMessages')?.addEventListener('click', function() {
    location.reload();
  });
</script>

<style>
  .messages-page {
    padding: 1.5rem;
  }
  
  .page-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 2rem;
  }
  
  .header-title h1 {
    font-size: 2rem;
    margin-bottom: 0.25rem;
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }
  
  .text-muted {
    opacity: 0.7;
    font-size: 0.9rem;
  }
  
  .stats-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1rem;
    margin-bottom: 2rem;
  }
  
  .stat-card {
    display: flex;
    align-items: center;
    gap: 1rem;
    padding: 1.5rem;
    background: rgba(255, 255, 255, 0.05);
    backdrop-filter: blur(10px);
    -webkit-backdrop-filter: blur(10px);
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: var(--radius-lg);
  }
  
  .stat-icon {
    width: 50px;
    height: 50px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1.5rem;
    color: white;
  }
  
  .stat-content {
    flex: 1;
  }
  
  .stat-value {
    display: block;
    font-size: 1.8rem;
    font-weight: 700;
    line-height: 1.2;
  }
  
  .stat-label {
    opacity: 0.7;
    font-size: 0.8rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }
  
  .filters-bar {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 2rem;
    flex-wrap: wrap;
    gap: 1rem;
  }
  
  .filter-tabs {
    display: flex;
    gap: 0.5rem;
    flex-wrap: wrap;
  }
  
  .filter-tab {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.5rem 1rem;
    border-radius: var(--radius-lg);
    background: rgba(255, 255, 255, 0.05);
    color: white;
    text-decoration: none;
    transition: var(--transition);
  }
  
  .filter-tab:hover,
  .filter-tab.active {
    background: linear-gradient(135deg, var(--accent), var(--secondary));
  }
  
  .filter-tab .badge {
    background: rgba(255, 255, 255, 0.2);
    padding: 0.2rem 0.5rem;
    border-radius: var(--radius-sm);
    font-size: 0.7rem;
  }
  
  .search-form {
    flex: 1;
    max-width: 500px;
  }
  
  .search-input-group {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    background: rgba(255, 255, 255, 0.05);
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: var(--radius-lg);
    padding: 0.25rem 0.25rem 0.25rem 1rem;
  }
  
  .search-input-group i {
    opacity: 0.5;
  }
  
  .search-input-group input {
    flex: 1;
    padding: 0.5rem;
    background: transparent;
    border: none;
    color: white;
    outline: none;
  }
  
  .search-input-group input::placeholder {
    color: rgba(255, 255, 255, 0.5);
  }
  
  .messages-table-container {
    background: rgba(255, 255, 255, 0.03);
    border-radius: var(--radius-lg);
    overflow: hidden;
  }
  
  .messages-table {
    width: 100%;
    border-collapse: collapse;
  }
  
  .messages-table th {
    text-align: left;
    padding: 1rem;
    background: rgba(0, 0, 0, 0.3);
    font-weight: 600;
    color: var(--accent);
    border-bottom: 1px solid rgba(255, 255, 255, 0.1);
  }
  
  .messages-table td {
    padding: 1rem;
    border-bottom: 1px solid rgba(255, 255, 255, 0.05);
  }
  
  .messages-table tr:hover {
    background: rgba(255, 255, 255, 0.05);
  }
  
  .messages-table tr.unread {
    background: rgba(59, 130, 246, 0.1);
    font-weight: 500;
  }
  
  .messages-table tr.unread:hover {
    background: rgba(59, 130, 246, 0.15);
  }
  
  .messages-table tr.archived {
    opacity: 0.6;
  }
  
  .status-badge {
    display: inline-flex;
    align-items: center;
    justify-content: center;
  }
  
  .status-badge.unread i {
    color: #3b82f6;
    font-size: 0.8rem;
    animation: pulse 2s infinite;
  }
  
  .status-badge.replied i {
    color: #10b981;
    font-size: 1rem;
  }
  
  .status-badge.read i {
    color: #6b7280;
    font-size: 0.6rem;
  }
  
  @keyframes pulse {
    0% { opacity: 1; }
    50% { opacity: 0.5; }
    100% { opacity: 1; }
  }
  
  .date-cell {
    white-space: nowrap;
  }
  
  .date-main {
    font-weight: 500;
  }
  
  .date-time {
    font-size: 0.8rem;
    opacity: 0.6;
  }
  
  .sender-info {
    display: flex;
    flex-direction: column;
  }
  
  .sender-name {
    font-weight: 600;
    margin-bottom: 0.1rem;
  }
  
  .sender-email {
    font-size: 0.8rem;
    opacity: 0.6;
  }
  
  .subject-cell {
    max-width: 200px;
  }
  
  .subject {
    font-weight: 500;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }
  
  .message-preview {
    max-width: 300px;
  }
  
  .preview-text {
    opacity: 0.8;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }
  
  .actions-cell {
    display: flex;
    gap: 0.5rem;
    white-space: nowrap;
  }
  
  .btn-icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 36px;
    height: 36px;
    border-radius: 50%;
    border: none;
    cursor: pointer;
    transition: var(--transition);
    color: white;
    text-decoration: none;
  }
  
  .btn-view {
    background: #3b82f6;
  }
  
  .btn-view:hover {
    background: #2563eb;
    transform: scale(1.1);
  }
  
  .btn-archive {
    background: #8b5cf6;
  }
  
  .btn-archive:hover {
    background: #7c3aed;
    transform: scale(1.1);
  }
  
  .btn-restore {
    background: #10b981;
  }
  
  .btn-restore:hover {
    background: #059669;
    transform: scale(1.1);
  }
  
  .btn-delete {
    background: #ef4444;
  }
  
  .btn-delete:hover {
    background: #dc2626;
    transform: scale(1.1);
  }
  
  .inline-form {
    display: inline;
  }
  
  .empty-state {
    text-align: center;
    padding: 4rem 2rem;
    color: white;
  }
  
  .empty-state i {
    opacity: 0.3;
    margin-bottom: 1rem;
  }
  
  .empty-state h3 {
    margin-bottom: 0.5rem;
    font-size: 1.5rem;
  }
  
  .empty-state p {
    opacity: 0.6;
  }
  
  @media (max-width: 1200px) {
    .stats-grid {
      grid-template-columns: repeat(2, 1fr);
    }
    
    .messages-table {
      font-size: 0.9rem;
    }
  }
  
  @media (max-width: 768px) {
    .stats-grid {
      grid-template-columns: 1fr;
    }
    
    .filters-bar {
      flex-direction: column;
      align-items: stretch;
    }
    
    .search-form {
      max-width: none;
    }
    
    .messages-table th,
    .messages-table td {
      padding: 0.5rem;
    }
    
    .date-time,
    .sender-email,
    .preview-text {
      display: none;
    }
  }
</style>