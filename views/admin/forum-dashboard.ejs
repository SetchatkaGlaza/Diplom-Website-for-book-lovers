<div class="forum-admin-page">
  <header class="admin-header">
    <h1><i class="fas fa-comments"></i> Форум: обзор</h1>
    <div class="header-actions">
      <a href="/admin/forum/moderation" class="btn btn-primary"><i class="fas fa-shield-alt"></i> Модерация</a>
      <a href="/admin/forum/topics" class="btn btn-outline"><i class="fas fa-list-ul"></i> Все топики</a>
      <a href="/admin/forum/categories" class="btn btn-outline"><i class="fas fa-folder"></i> Категории</a>
    </div>
  </header>

  <section class="stats-cards forum-stats-grid">
    <article class="stat-card primary">
      <i class="fas fa-list stat-icon"></i>
      <div class="stat-content"><div class="stat-value"><%= stats.totalCategories %></div><div class="stat-label">Категорий</div></div>
    </article>
    <article class="stat-card success">
      <i class="fas fa-check-circle stat-icon"></i>
      <div class="stat-content"><div class="stat-value"><%= stats.activeCategories %></div><div class="stat-label">Активных категорий</div></div>
    </article>
    <article class="stat-card info">
      <i class="fas fa-comments stat-icon"></i>
      <div class="stat-content"><div class="stat-value"><%= stats.totalTopics %></div><div class="stat-label">Всего тем</div></div>
    </article>
    <article class="stat-card warning">
      <i class="fas fa-clock stat-icon"></i>
      <div class="stat-content"><div class="stat-value"><%= stats.pendingTopics %></div><div class="stat-label">Тем на модерации</div></div>
    </article>
    <article class="stat-card info">
      <i class="fas fa-comment-dots stat-icon"></i>
      <div class="stat-content"><div class="stat-value"><%= stats.totalPosts %></div><div class="stat-label">Всего сообщений</div></div>
    </article>
    <article class="stat-card warning">
      <i class="fas fa-hourglass-half stat-icon"></i>
      <div class="stat-content"><div class="stat-value"><%= stats.pendingPosts %></div><div class="stat-label">Сообщений на модерации</div></div>
    </article>
  </section>

  <section class="forum-admin-grid">
    <div class="admin-card">
      <h2><i class="fas fa-fire"></i> Быстрые метрики</h2>
      <ul class="metric-list">
        <li><span>Одобренные темы</span><strong><%= stats.moderatedTopics %></strong></li>
        <li><span>Закреплённые темы</span><strong><%= stats.pinnedTopics %></strong></li>
        <li><span>Закрытые темы</span><strong><%= stats.lockedTopics %></strong></li>
        <li><span>Всего на модерации</span><strong><%= stats.pendingTopics + stats.pendingPosts %></strong></li>
      </ul>
    </div>

    <div class="admin-card">
      <h2><i class="fas fa-compass"></i> Быстрые действия</h2>
      <div class="quick-actions">
        <a class="quick-action" href="/admin/forum/moderation?tab=topics"><i class="fas fa-check-double"></i> Проверить темы</a>
        <a class="quick-action" href="/admin/forum/moderation?tab=posts"><i class="fas fa-comment-medical"></i> Проверить сообщения</a>
        <a class="quick-action" href="/admin/forum/topics"><i class="fas fa-thumbtack"></i> Управлять топиками</a>
        <a class="quick-action" href="/admin/forum/categories"><i class="fas fa-layer-group"></i> Настроить категории</a>
        <a class="quick-action" href="/forum" target="_blank"><i class="fas fa-external-link-alt"></i> Открыть форум</a>
      </div>
    </div>
  </section>

  <section class="forum-admin-grid">
    <div class="admin-card">
      <h2><i class="fas fa-stream"></i> Последние темы</h2>
      <% if (recentTopics.length) { %>
        <ul class="activity-list">
          <% recentTopics.forEach(topic => { %>
            <li>
              <a href="/forum/topic/<%= topic.id %>" target="_blank"><%= topic.title %></a>
              <small><%= topic.user ? topic.user.name : 'Без автора' %> • <%= topic.category ? topic.category.name : 'Без категории' %></small>
            </li>
          <% }) %>
        </ul>
      <% } else { %>
        <p class="muted">Тем пока нет.</p>
      <% } %>
    </div>

    <div class="admin-card">
      <h2><i class="fas fa-comment"></i> Последние сообщения</h2>
      <% if (recentPosts.length) { %>
        <ul class="activity-list">
          <% recentPosts.forEach(post => { %>
            <li>
              <a href="/forum/topic/<%= post.topic ? post.topic.id : '' %>#post-<%= post.id %>" target="_blank"><%= post.topic ? post.topic.title : 'Без темы' %></a>
              <small><%= post.user ? post.user.name : 'Без автора' %> • <%= new Date(post.createdAt).toLocaleString('ru-RU') %></small>
            </li>
          <% }) %>
        </ul>
      <% } else { %>
        <p class="muted">Сообщений пока нет.</p>
      <% } %>
    </div>
  </section>
</div>
