<div class="admin-forum-moderation">
  <div class="admin-header">
    <h1><i class="fas fa-shield-alt"></i> Модерация форума</h1>
    <div class="header-actions">
      <span class="badge"><%= stats ? stats.topicsPending : 0 %> тем | <%= stats ? stats.postsPending : 0 %> сообщений</span>
      <a href="/admin/forum/categories" class="btn btn-outline">
        <i class="fas fa-folder"></i> Управление категориями
      </a>
      <a href="/admin/forum/moderation" class="btn btn-primary">
        <i class="fas fa-sync-alt"></i> Обновить
      </a>
    </div>
  </div>
  
  <!-- Темы на модерацию -->
  <div class="moderation-section">
    <h2><i class="fas fa-comments"></i> Новые темы (<%= pendingTopics.length %>)</h2>
    
    <% if (pendingTopics && pendingTopics.length > 0) { %>
      <div class="moderation-list">
        <% pendingTopics.forEach(topic => { %>
          <div class="moderation-item">
            <div class="item-content">
              <h3>
                <%= topic.title %>
                <% if (topic.category) { %>
                  <span class="category-badge">[<%= topic.category.name %>]</span>
                <% } %>
              </h3>
              <p class="item-meta">
                <strong>Автор:</strong> 
                <a href="/profile/<%= topic.user.id %>" target="_blank">
                  <img src="/images/avatars/<%= topic.user.avatar %>" alt="<%= topic.user.name %>" class="mini-avatar">
                  <%= topic.user.name %>
                </a> • 
                <strong>Email:</strong> <%= topic.user.email %> • 
                <strong>Дата:</strong> <%= new Date(topic.createdAt).toLocaleString('ru-RU') %>
              </p>
              <div class="item-preview" id="preview-topic-<%= topic.id %>" style="display: none;">
                <div class="preview-content">
                  <h4>Содержание:</h4>
                  <%= topic.content.replace(/\n/g, '<br>') %>
                </div>
              </div>
            </div>
            <div class="item-actions">
              <button class="action-btn preview" onclick="togglePreview('topic', <%= topic.id %>)" title="Предпросмотр">
                <i class="fas fa-eye"></i>
              </button>
              <form action="/admin/forum/topic/<%= topic.id %>/approve" method="POST" class="inline-form">
                <button type="submit" class="action-btn approve" title="Одобрить" onclick="return confirm('Одобрить тему?')">
                  <i class="fas fa-check"></i>
                </button>
              </form>
              <button class="action-btn reject" onclick="showRejectForm('topic', <%= topic.id %>)" title="Отклонить">
                <i class="fas fa-times"></i>
              </button>
            </div>
            
            <div class="reject-form" id="reject-form-topic-<%= topic.id %>" style="display: none;">
              <form action="/admin/forum/topic/<%= topic.id %>/reject" method="POST">
                <div class="form-group">
                  <label for="reason-topic-<%= topic.id %>">Причина отклонения:</label>
                  <textarea id="reason-topic-<%= topic.id %>" name="reason" rows="3" required 
                            placeholder="Укажите причину отказа (будет отправлена автору)"></textarea>
                </div>
                <div class="form-actions">
                  <button type="submit" class="btn btn-danger">Отправить</button>
                  <button type="button" class="btn btn-outline" onclick="hideRejectForm('topic', <%= topic.id %>)">Отмена</button>
                </div>
              </form>
            </div>
          </div>
        <% }) %>
      </div>
      
      <!-- Пагинация -->
      <% if (totalPages > 1) { %>
        <div class="pagination">
          <% if (currentPage > 1) { %>
            <a href="?page=<%= currentPage - 1 %>" class="page-link">
              <i class="fas fa-chevron-left"></i>
            </a>
          <% } %>
          
          <% for(let i = 1; i <= totalPages; i++) { %>
            <% if (i === currentPage) { %>
              <span class="page-link active"><%= i %></span>
            <% } else { %>
              <a href="?page=<%= i %>" class="page-link"><%= i %></a>
            <% } %>
          <% } %>
          
          <% if (currentPage < totalPages) { %>
            <a href="?page=<%= currentPage + 1 %>" class="page-link">
              <i class="fas fa-chevron-right"></i>
            </a>
          <% } %>
        </div>
      <% } %>
      
    <% } else { %>
      <div class="empty-state">
        <i class="fas fa-check-circle fa-4x"></i>
        <h3>Нет новых тем</h3>
        <p>Все темы проверены</p>
      </div>
    <% } %>
  </div>
  
</div>

<script>
  function togglePreview(type, id) {
    const preview = document.getElementById(`preview-${type}-${id}`);
    if (preview) {
      preview.style.display = preview.style.display === 'none' ? 'block' : 'none';
    }
  }
  
  function showRejectForm(type, id) {
    // Скрываем все открытые формы
    document.querySelectorAll('.reject-form').forEach(form => {
      form.style.display = 'none';
    });
    
    const form = document.getElementById(`reject-form-${type}-${id}`);
    if (form) {
      form.style.display = 'block';
    }
  }
  
  function hideRejectForm(type, id) {
    const form = document.getElementById(`reject-form-${type}-${id}`);
    if (form) {
      form.style.display = 'none';
    }
  }
</script>

