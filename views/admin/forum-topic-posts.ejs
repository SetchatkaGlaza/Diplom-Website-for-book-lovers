<div class="forum-admin-page">
  <header class="admin-header">
    <h1><i class="fas fa-comments"></i> Сообщения топика</h1>
    <div class="header-actions">
      <a href="/admin/forum/topics" class="btn btn-outline"><i class="fas fa-arrow-left"></i> К списку топиков</a>
      <a href="/admin/forum/appeals" class="btn btn-outline"><i class="fas fa-inbox"></i> Обращения</a>
      <a href="/forum/topic/<%= topic.id %>" class="btn btn-outline" target="_blank"><i class="fas fa-external-link-alt"></i> Открыть на сайте</a>
    </div>
  </header>

  <section class="admin-card">
    <h2 class="forum-topic-heading"><%= topic.title %></h2>
    <p class="item-meta">
      <span><strong>Категория:</strong> <%= topic.category ? topic.category.name : '–' %></span>
      <span><strong>Автор:</strong> <%= topic.user ? topic.user.name : '–' %></span>
      <span><strong>Статус:</strong> <%= topic.is_locked ? 'Закрыт' : 'Открыт' %>, <%= topic.is_pinned ? 'Закреплён' : 'Обычный' %></span>
    </p>

    <div class="moderation-actions">
      <form action="/admin/forum/topic/<%= topic.id %>/pin" method="POST">
        <button class="btn btn-outline" type="submit"><i class="fas fa-thumbtack"></i> <%= topic.is_pinned ? 'Открепить' : 'Закрепить' %></button>
      </form>
      <form action="/admin/forum/topic/<%= topic.id %>/lock" method="POST">
        <button class="btn btn-outline" type="submit"><i class="fas fa-lock"></i> <%= topic.is_locked ? 'Открыть' : 'Закрыть' %></button>
      </form>
    </div>
  </section>

  <section class="admin-card">
    <h2>Все сообщения (<%= posts.length %>)</h2>
    <% if (posts.length) { %>
      <div class="moderation-list">
        <% posts.forEach((post, index) => { %>
          <article class="moderation-item">
            <p class="item-meta">
              <span><strong>#<%= index + 1 %></strong></span>
              <span><strong>Автор:</strong> <%= post.user ? post.user.name : 'Неизвестно' %></span>
              <span><strong>Email:</strong> <%= post.user ? post.user.email : '–' %></span>
              <span><strong>Дата:</strong> <%= new Date(post.createdAt).toLocaleString('ru-RU') %></span>
            </p>
            <% const postPreview = truncateText(post.content, 260); %>
            <div class="content-preview"><%= postPreview.text %></div>

            <form action="/admin/forum/post/<%= post.id %>/delete" method="POST" class="reject-form-inline delete-post-form">
              <input
                type="text"
                name="reason"
                required
                minlength="5"
                maxlength="500"
                placeholder="Причина удаления (минимум 5 символов)"
              >
              <button type="submit" class="btn btn-danger" disabled><i class="fas fa-trash"></i> Удалить сообщение</button>
            </form>
          </article>
        <% }) %>
      </div>
    <% } else { %>
      <p class="muted">В топике нет сообщений.</p>
    <% } %>
  </section>
</div>

<script>
  document.querySelectorAll('.delete-post-form').forEach((form) => {
    const reasonInput = form.querySelector('input[name="reason"]');
    const submitButton = form.querySelector('button[type="submit"]');
    const minLength = Number(reasonInput?.getAttribute('minlength')) || 5;

    const updateSubmitState = () => {
      const canSubmit = reasonInput.value.trim().length >= minLength;
      submitButton.disabled = !canSubmit;
    };

    updateSubmitState();
    reasonInput.addEventListener('input', updateSubmitState);

    form.addEventListener('submit', (event) => {
      updateSubmitState();

      if (submitButton.disabled) {
        event.preventDefault();
        reasonInput.reportValidity();
        return;
      }

      if (!confirm('Удалить это сообщение?')) {
        event.preventDefault();
      }
    });
  });
</script>
