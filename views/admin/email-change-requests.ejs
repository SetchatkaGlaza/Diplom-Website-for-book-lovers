<div class="admin-users">
  <div class="page-header"><h1><i class="fas fa-envelope-open-text"></i> Запросы на смену email</h1></div>
  <div style="display:flex;gap:.75rem;margin-bottom:1rem;">
    <a href="/admin/email-change-requests?status=pending" class="btn btn-outline">Ожидают</a>
    <a href="/admin/email-change-requests?status=approved" class="btn btn-outline">Одобрены</a>
    <a href="/admin/email-change-requests?status=rejected" class="btn btn-outline">Отклонены</a>
  </div>

  <% if (!requests || requests.length === 0) { %>
    <div class="users-table-card">Нет запросов в этом статусе.</div>
  <% } %>

  <% requests.forEach(item => { %>
    <div class="users-table-card" style="margin-bottom:1rem;">
      <p><strong>Пользователь:</strong> <%= item.user?.name %> (#<%= item.user?.id %>)</p>
      <p><strong>Текущий email:</strong> <%= item.current_email %></p>
      <p><strong>Новый email:</strong> <%= item.new_email %></p>
      <p><strong>Причина:</strong> <%= item.reason %></p>
      <p><strong>Статус:</strong> <%= item.status %></p>
      <% if (item.admin_note) { %><p><strong>Комментарий администратора:</strong> <%= item.admin_note %></p><% } %>

      <% if (item.status === 'pending') { %>
        <form action="/admin/email-change-requests/<%= item.id %>/resolve" method="POST" style="display:flex;gap:.5rem;flex-wrap:wrap;align-items:flex-end;">
          <div class="form-group" style="margin:0;min-width:280px;">
            <label for="note-<%= item.id %>">Комментарий (необязательно)</label>
            <textarea id="note-<%= item.id %>" name="admin_note" rows="3" maxlength="1000" placeholder="Причина решения"></textarea>
          </div>
          <button type="submit" name="action" value="approve" class="btn btn-success">Одобрить и сменить email</button>
          <button type="submit" name="action" value="reject" class="btn btn-danger">Отклонить</button>
        </form>
      <% } %>
    </div>
  <% }) %>
</div>
