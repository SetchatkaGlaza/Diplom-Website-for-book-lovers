<div class="forum-admin-page">
  <header class="admin-header">
    <h1><i class="fas fa-folder-open"></i> Форум: категории</h1>
    <div class="header-actions">
      <a href="/admin/forum" class="btn btn-outline"><i class="fas fa-chart-line"></i> Обзор</a>
      <a href="/admin/forum/topics" class="btn btn-outline"><i class="fas fa-list-ul"></i> Все топики</a>
      <a href="/admin/forum/appeals" class="btn btn-outline"><i class="fas fa-inbox"></i> Обращения</a>
      <a href="/admin/forum/moderation" class="btn btn-outline"><i class="fas fa-shield-alt"></i> Модерация</a>
    </div>
  </header>

  <section class="admin-card">
    <h2>Создать категорию</h2>
    <form action="/admin/forum/categories" method="POST" class="category-form">
      <div class="form-row">
        <div class="form-group">
          <label for="name">Название</label>
          <input id="name" name="name" type="text" minlength="3" required>
        </div>
        <div class="form-group">
          <label for="icon">Иконка (fa-...)</label>
          <input id="icon" name="icon" type="text" value="fa-comments">
        </div>
        <div class="form-group">
          <label for="sort_order">Порядок</label>
          <input id="sort_order" name="sort_order" type="number" value="0">
        </div>
      </div>
      <div class="form-group">
        <label for="description">Описание</label>
        <textarea id="description" name="description" rows="3"></textarea>
      </div>
      <button class="btn btn-primary" type="submit"><i class="fas fa-plus"></i> Добавить</button>
    </form>
  </section>

  <section class="admin-card">
    <h2>Существующие категории</h2>
    <% if (categories.length) { %>
      <div class="table-responsive">
        <table class="modern-table">
          <thead>
            <tr>
              <th>Порядок</th>
              <th>Категория</th>
              <th>Темы</th>
              <th>Одобрено</th>
              <th>Статус</th>
              <th>Действия</th>
            </tr>
          </thead>
          <tbody>
            <% categories.forEach(category => { %>
              <tr>
                <td><%= category.sort_order %></td>
                <td>
                  <strong><i class="fas <%= category.icon %>"></i> <%= category.name %></strong>
                  <div class="muted"><%= category.description || 'Без описания' %></div>
                </td>
                <td><%= category.topicsCount %></td>
                <td><%= category.moderatedTopicsCount %></td>
                <td>
                  <% if (category.is_active) { %>
                    <span class="badge badge-success">Активна</span>
                  <% } else { %>
                    <span class="badge badge-danger">Скрыта</span>
                  <% } %>
                </td>
                <td>
                  <div class="action-buttons">
                    <button class="action-btn edit" onclick='openEditModal(<%- JSON.stringify(category) %>)'>
                      <i class="fas fa-edit"></i>
                    </button>
                    <% if (!category.topicsCount) { %>
                      <form action="/admin/forum/categories/<%= category.id %>?_method=DELETE" method="POST" class="inline-form">
                        <button class="action-btn delete" type="submit" onclick="return confirm('Удалить категорию без тем?')">
                          <i class="fas fa-trash"></i>
                        </button>
                      </form>
                    <% } %>
                  </div>
                </td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
    <% } else { %>
      <p class="muted">Пока нет категорий форума.</p>
    <% } %>
  </section>
</div>

<div id="editCategoryModal" class="modal" style="display:none;">
  <div class="modal-content">
    <h2>Редактировать категорию</h2>
    <form id="editCategoryForm" method="POST" class="category-form">
      <div class="form-row">
        <div class="form-group">
          <label for="edit-name">Название</label>
          <input id="edit-name" name="name" type="text" minlength="3" required>
        </div>
        <div class="form-group">
          <label for="edit-icon">Иконка</label>
          <input id="edit-icon" name="icon" type="text" required>
        </div>
        <div class="form-group">
          <label for="edit-sort_order">Порядок</label>
          <input id="edit-sort_order" name="sort_order" type="number" required>
        </div>
      </div>
      <div class="form-group">
        <label for="edit-description">Описание</label>
        <textarea id="edit-description" name="description" rows="3"></textarea>
      </div>
      <label class="checkbox-label">
        <input id="edit-is_active" name="is_active" type="checkbox">
        <span>Категория активна</span>
      </label>
      <div class="form-actions">
        <button class="btn btn-primary" type="submit">Сохранить</button>
        <button class="btn btn-outline" type="button" onclick="closeEditModal()">Отмена</button>
      </div>
    </form>
  </div>
</div>

<script>
  const modal = document.getElementById('editCategoryModal');
  const editForm = document.getElementById('editCategoryForm');

  function openEditModal(category) {
    document.getElementById('edit-name').value = category.name || '';
    document.getElementById('edit-icon').value = category.icon || 'fa-comments';
    document.getElementById('edit-sort_order').value = category.sort_order || 0;
    document.getElementById('edit-description').value = category.description || '';
    document.getElementById('edit-is_active').checked = Boolean(category.is_active);
    editForm.action = `/admin/forum/categories/${category.id}`;
    modal.style.display = 'flex';
  }

  function closeEditModal() {
    modal.style.display = 'none';
  }

  window.addEventListener('click', (event) => {
    if (event.target === modal) {
      closeEditModal();
    }
  });
</script>
