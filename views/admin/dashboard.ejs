<div class="admin-dashboard">
  <!-- Заголовок -->
  <div class="dashboard-header">
    <div class="header-title">
      <h1><i class="fas fa-cog"></i> Админ-панель</h1>
      <p class="date-today">Сегодня: <%= new Date().toLocaleDateString('ru-RU', { weekday: 'long', year: 'numeric', month: 'long', day: 'numeric' }) %></p>
    </div>
    <div class="admin-user-card">
      <img src="/images/avatars/<%= user.avatar %>" alt="<%= user.name %>" class="admin-avatar">
      <div>
        <div class="admin-name"><%= user.name %></div>
        <div class="admin-role-badge"><%= user.role === 'admin' ? 'Главный администратор' : 'Модератор' %></div>
      </div>
    </div>
  </div>
  
  <!-- Статистика (красивые карточки) -->
  <div class="stats-grid">
    <div class="stat-card primary">
      <div class="stat-icon-wrapper">
        <i class="fas fa-users"></i>
      </div>
      <div class="stat-content">
        <span class="stat-value"><%= stats.totalUsers %></span>
        <span class="stat-label">Пользователей</span>
        <div class="stat-trend positive">
          <i class="fas fa-arrow-up"></i> +<%= stats.newUsersToday %> сегодня
        </div>
      </div>
    </div>
    
    <div class="stat-card success">
      <div class="stat-icon-wrapper">
        <i class="fas fa-book"></i>
      </div>
      <div class="stat-content">
        <span class="stat-value"><%= stats.totalBooks %></span>
        <span class="stat-label">Книг</span>
        <div class="stat-trend positive">
          <i class="fas fa-arrow-up"></i> +<%= stats.newBooksToday %> сегодня
        </div>
      </div>
    </div>
    
    <div class="stat-card warning">
      <div class="stat-icon-wrapper">
        <i class="fas fa-star"></i>
      </div>
      <div class="stat-content">
        <span class="stat-value"><%= stats.totalReviews %></span>
        <span class="stat-label">Рецензий</span>
        <div class="stat-trend positive">
          <i class="fas fa-arrow-up"></i> +<%= stats.newReviewsToday %> сегодня
        </div>
      </div>
    </div>
    
    <div class="stat-card purple">
      <div class="stat-icon-wrapper">
        <i class="fas fa-tags"></i>
      </div>
      <div class="stat-content">
        <span class="stat-value"><%= stats.totalGenres %></span>
        <span class="stat-label">Жанров</span>
      </div>
    </div>
  </div>
  
  <!-- Статистика по ролям (вместо графика) -->
<div class="charts-row">
  <div class="chart-card">
    <div class="card-header">
      <h3><i class="fas fa-users-cog"></i> Пользователи по ролям</h3>
    </div>
    <div class="card-body">
      <% if (rolesStats && rolesStats.length > 0) { %>
        <div class="roles-grid">
          <% 
            const roleNames = {
              'admin': 'Администраторы',
              'moderator': 'Модераторы', 
              'user': 'Пользователи'
            };
            const roleColors = {
              'admin': '#ef4444',
              'moderator': '#f59e0b',
              'user': '#3b82f6'
            };
            const roleIcons = {
              'admin': 'fa-crown',
              'moderator': 'fa-shield-alt',
              'user': 'fa-user'
            };
          %>
          <% rolesStats.forEach(stat => { %>
            <div class="role-stat-card" style="border-left-color: <%= roleColors[stat.role] %>;">
              <div class="role-stat-icon" style="background: <%= roleColors[stat.role] %>20; color: <%= roleColors[stat.role] %>;">
                <i class="fas <%= roleIcons[stat.role] %>"></i>
              </div>
              <div class="role-stat-content">
                <span class="role-stat-label"><%= roleNames[stat.role] || stat.role %></span>
                <span class="role-stat-value"><%= stat.count %></span>
              </div>
              <div class="role-stat-percent">
                <%= ((stat.count / (rolesStats.reduce((acc, s) => acc + s.count, 0)) * 100)).toFixed(1) %>%
              </div>
            </div>
          <% }) %>
        </div>
      <% } else { %>
        <div class="empty-state-mini">
          <i class="fas fa-users"></i>
          <p>Нет данных о пользователях</p>
        </div>
      <% } %>
    </div>
  </div>
  
  <div class="chart-card">
    <div class="card-header">
      <h3><i class="fas fa-bolt"></i> Быстрые действия</h3>
    </div>
    <div class="card-body quick-actions">
      <a href="/admin/books/add" class="quick-action-btn">
        <i class="fas fa-plus-circle"></i>
        <span>Добавить книгу</span>
      </a>
      <a href="/admin/genres" class="quick-action-btn">
        <i class="fas fa-tag"></i>
        <span>Управление жанрами</span>
      </a>
      <a href="/admin/reviews?status=pending" class="quick-action-btn">
        <i class="fas fa-clock"></i>
        <span>Модерация</span>
        <% if (recentReviews && recentReviews.filter(r => !r.is_moderated).length > 0) { %>
          <span class="badge-pulse"></span>
        <% } %>
      </a>
      <a href="/admin/statistics" class="quick-action-btn">
        <i class="fas fa-chart-bar"></i>
        <span>Статистика</span>
      </a>
    </div>
  </div>
</div>
  
<!-- Таблицы с последними данными -->
  <div class="recent-tables-grid">
    <!-- Новые пользователи -->
    <div class="recent-card">
  <div class="card-header">
    <h3><i class="fas fa-user-plus" style="color: #3b82f6;"></i> Новые пользователи</h3>
    <a href="/admin/users" class="view-all-link">Все <i class="fas fa-arrow-right"></i></a>
  </div>
  <div class="card-body">
    <% if (recentUsers && recentUsers.length > 0) { %>
      <div class="user-list">
        <% recentUsers.forEach(user => { %>
          <div class="user-list-item">
            <img src="/images/avatars/<%= user.avatar || 'default-avatar.png' %>" alt="<%= user.name %>" class="user-avatar" 
                 onerror="this.src='/images/avatars/default-avatar.png'">
            <div class="user-info">
              <div class="user-name"><%= user.name %></div>
              <div class="user-email"><%= user.email %></div>
            </div>
            <div class="user-meta">
              <span class="badge-mini role-<%= user.role %>">
                <%= user.role === 'admin' ? 'Админ' : user.role === 'moderator' ? 'Мод' : 'Юзер' %>
              </span>
              <span class="user-date"><i class="far fa-clock"></i> <%= new Date(user.createdAt).toLocaleDateString('ru-RU') %></span>
            </div>
          </div>
        <% }) %>
      </div>
    <% } else { %>
      <div class="empty-state-mini">
        <p>Нет новых пользователей</p>
      </div>
    <% } %>
  </div>
</div>
    
    <!-- Новые книги -->
    <div class="recent-card">
      <div class="card-header">
        <h3><i class="fas fa-book" style="color: #10b981;"></i> Новые книги</h3>
        <a href="/admin/books" class="view-all-link">Все <i class="fas fa-arrow-right"></i></a>
      </div>
      <div class="card-body">
        <% if (recentBooks && recentBooks.length > 0) { %>
          <div class="book-list">
            <% recentBooks.forEach(book => { %>
              <div class="book-list-item">
                <img src="/images/covers/<%= book.cover_image %>" alt="<%= book.title %>" class="book-cover-mini">
                <div class="book-info">
                  <div class="book-title"><%= book.title %></div>
                  <div class="book-author"><%= book.author %></div>
                </div>
                <div class="book-meta">
                  <span class="genre-tag"><%= book.genre ? book.genre.name : '—' %></span>
                  <span class="book-date"><i class="far fa-calendar"></i> <%= new Date(book.createdAt).toLocaleDateString('ru-RU') %></span>
                </div>
              </div>
            <% }) %>
          </div>
        <% } else { %>
          <div class="empty-state-mini">
            <p>Нет новых книг</p>
          </div>
        <% } %>
      </div>
    </div>
    
    <!-- Новые рецензии -->
    <div class="recent-card">
  <div class="card-header">
    <h3><i class="fas fa-star" style="color: #f59e0b;"></i> Новые рецензии</h3>
    <a href="/admin/reviews" class="view-all-link">Все <i class="fas fa-arrow-right"></i></a>
  </div>
  <div class="card-body">
    <% if (recentReviews && recentReviews.length > 0) { %>
      <div class="review-list">
        <% recentReviews.forEach(review => { %>
          <div class="review-list-item">
            <div class="review-header">
              <div class="review-user">
                <img src="/images/avatars/<%= review.user ? (review.user.avatar || 'default-avatar.png') : 'default-avatar.png' %>" 
                     alt="<%= review.user ? review.user.name : 'User' %>" 
                     class="reviewer-avatar-mini"
                     onerror="this.src='/images/avatars/default-avatar.png'">
                <span class="reviewer-name"><%= review.user ? review.user.name : 'Пользователь' %></span>
              </div>
              <div class="review-rating-mini">
                <% for(let i = 1; i <= 5; i++) { %>
                  <% if (i <= review.rating) { %>
                    <i class="fas fa-star" style="color: #fbbf24;"></i>
                  <% } else { %>
                    <i class="far fa-star" style="color: #fbbf24; opacity: 0.3;"></i>
                  <% } %>
                <% } %>
              </div>
            </div>
            <div class="review-book">
              <i class="fas fa-book"></i> 
              <span class="review-book-title"><%= review.book ? review.book.title : 'Неизвестная книга' %></span>
            </div>
            <div class="review-preview">
              <%= review.content ? (review.content.length > 100 ? review.content.substring(0, 100) + '...' : review.content) : '' %>
            </div>
            <div class="review-footer">
              <span class="review-date"><i class="far fa-clock"></i> <%= new Date(review.createdAt).toLocaleDateString('ru-RU') %></span>
              <% if (!review.is_moderated) { %>
                <span class="badge-mini warning">На модерации</span>
              <% } %>
            </div>
          </div>
        <% }) %>
      </div>
    <% } else { %>
      <div class="empty-state-mini">
        <p>Нет новых рецензий</p>
      </div>
    <% } %>
  </div>
</div>
    </div>
  </div>
</div>



<style>
  /* ===== ОСНОВНЫЕ СТИЛИ ДЛЯ ДАШБОРДА ===== */
  .admin-dashboard {
    padding: 1.5rem;
    color: white;
  }
  
  /* Заголовок */
  .dashboard-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 2rem;
    background: rgba(255, 255, 255, 0.05);
    backdrop-filter: blur(10px);
    -webkit-backdrop-filter: blur(10px);
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: var(--radius-lg);
    padding: 1.5rem;
  }
  
  .header-title h1 {
    font-size: 1.8rem;
    margin-bottom: 0.25rem;
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }
  
  .date-today {
    opacity: 0.7;
    font-size: 0.9rem;
    text-transform: capitalize;
  }
  
  .admin-user-card {
    display: flex;
    align-items: center;
    gap: 1rem;
    background: rgba(255, 255, 255, 0.1);
    padding: 0.75rem 1.5rem;
    border-radius: var(--radius-lg);
  }
  
  .admin-avatar {
    width: 50px;
    height: 50px;
    border-radius: 50%;
    object-fit: cover;
    border: 2px solid var(--accent);
  }
  
  .admin-name {
    font-weight: 600;
    font-size: 1.1rem;
  }
  
  .admin-role-badge {
    font-size: 0.8rem;
    padding: 0.25rem 0.5rem;
    background: linear-gradient(135deg, var(--accent), var(--secondary));
    border-radius: var(--radius-sm);
    display: inline-block;
  }
  
  /* Карточки статистики */
  .stats-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
    gap: 1.5rem;
    margin-bottom: 2rem;
  }
  
  .stat-card {
    display: flex;
    align-items: center;
    gap: 1.5rem;
    padding: 1.5rem;
    border-radius: var(--radius-lg);
    background: rgba(255, 255, 255, 0.05);
    backdrop-filter: blur(10px);
    -webkit-backdrop-filter: blur(10px);
    border: 1px solid rgba(255, 255, 255, 0.1);
    transition: all 0.3s ease;
  }
  
  .stat-card:hover {
    transform: translateY(-5px);
    box-shadow: var(--shadow-lg);
  }
  
  .stat-card.primary .stat-icon-wrapper { background: linear-gradient(135deg, #3b82f6, #2563eb); }
  .stat-card.success .stat-icon-wrapper { background: linear-gradient(135deg, #10b981, #059669); }
  .stat-card.warning .stat-icon-wrapper { background: linear-gradient(135deg, #f59e0b, #d97706); }
  .stat-card.purple .stat-icon-wrapper { background: linear-gradient(135deg, #8b5cf6, #7c3aed); }
  
  .stat-icon-wrapper {
    width: 60px;
    height: 60px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1.8rem;
    color: white;
    box-shadow: var(--shadow);
  }
  
  .stat-content {
    flex: 1;
  }
  
  .stat-value {
    display: block;
    font-size: 2.2rem;
    font-weight: 700;
    line-height: 1.2;
  }
  
  .stat-label {
    opacity: 0.7;
    font-size: 0.9rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }
  
  .stat-trend {
    font-size: 0.8rem;
    margin-top: 0.25rem;
  }
  
  .stat-trend.positive { color: #10b981; }
  .stat-trend.negative { color: #ef4444; }
  
  /* Графики и быстрые действия */
  .charts-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1.5rem;
    margin-bottom: 2rem;
  }
  
  .chart-card {
    background: rgba(255, 255, 255, 0.05);
    backdrop-filter: blur(10px);
    -webkit-backdrop-filter: blur(10px);
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: var(--radius-lg);
    overflow: hidden;
  }
  
  .card-header {
    padding: 1rem 1.5rem;
    border-bottom: 1px solid rgba(255, 255, 255, 0.1);
    display: flex;
    justify-content: space-between;
    align-items: center;
  }
  
  .card-header h3 {
    font-size: 1.1rem;
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }
  
  .card-body {
    padding: 1.5rem;
  }
  
  .chart-legend {
    display: flex;
    justify-content: center;
    gap: 2rem;
    margin-top: 1rem;
    flex-wrap: wrap;
  }
  
  .legend-item {
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }
  
  .legend-color {
    width: 12px;
    height: 12px;
    border-radius: 4px;
  }
  
  .legend-value {
    font-weight: 600;
    margin-left: 0.25rem;
  }
  
  /* Быстрые действия */
  .quick-actions {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1rem;
  }
  
  .quick-action-btn {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 0.75rem;
    padding: 1.5rem 1rem;
    background: rgba(255, 255, 255, 0.05);
    border-radius: var(--radius);
    color: white;
    text-decoration: none;
    transition: all 0.3s ease;
    border: 1px solid rgba(255, 255, 255, 0.1);
    position: relative;
  }
  
  .quick-action-btn:hover {
    background: linear-gradient(135deg, var(--accent), var(--secondary));
    transform: translateY(-3px);
    box-shadow: var(--shadow);
  }
  
  .quick-action-btn i {
    font-size: 2rem;
  }
  
  .quick-action-btn span {
    font-size: 0.9rem;
    text-align: center;
  }
  
  .badge-pulse {
    position: absolute;
    top: 1rem;
    right: 1rem;
    width: 8px;
    height: 8px;
    background: #ef4444;
    border-radius: 50%;
    animation: pulse 2s infinite;
  }
  
  @keyframes pulse {
    0% { box-shadow: 0 0 0 0 rgba(239, 68, 68, 0.7); }
    70% { box-shadow: 0 0 0 10px rgba(239, 68, 68, 0); }
    100% { box-shadow: 0 0 0 0 rgba(239, 68, 68, 0); }
  }
  
  /* Таблицы с последними данными */
  .recent-tables-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
  }
  
  .recent-card {
    background: rgba(255, 255, 255, 0.05);
    backdrop-filter: blur(10px);
    -webkit-backdrop-filter: blur(10px);
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: var(--radius-lg);
    overflow: hidden;
    transition: all 0.3s ease;
  }
  
  .recent-card:hover {
    transform: translateY(-3px);
    box-shadow: var(--shadow-lg);
  }
  
  .view-all-link {
    color: var(--accent);
    text-decoration: none;
    font-size: 0.9rem;
    display: flex;
    align-items: center;
    gap: 0.25rem;
  }
  
  .view-all-link:hover {
    text-decoration: underline;
  }
  
  /* Список пользователей */
  .user-list {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }
  
  .user-list-item {
    display: flex;
    align-items: center;
    gap: 1rem;
    padding: 0.75rem;
    border-radius: var(--radius);
    background: rgba(255, 255, 255, 0.03);
    transition: all 0.2s ease;
  }
  
  .user-list-item:hover {
    background: rgba(255, 255, 255, 0.1);
    transform: translateX(5px);
  }
  
  .user-avatar {
    width: 40px;
    height: 40px;
    border-radius: 50%;
    object-fit: cover;
  }
  
  .user-info {
    flex: 1;
  }
  
  .user-name {
    font-weight: 600;
    margin-bottom: 0.1rem;
  }
  
  .user-email {
    font-size: 0.8rem;
    opacity: 0.6;
  }
  
  .user-meta {
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    gap: 0.25rem;
  }
  
  .badge-mini {
    font-size: 0.7rem;
    padding: 0.2rem 0.4rem;
    border-radius: var(--radius-sm);
    background: rgba(255, 255, 255, 0.1);
  }
  
  .badge-mini.role-admin { background: #ef4444; }
  .badge-mini.role-moderator { background: #f59e0b; }
  .badge-mini.role-user { background: #3b82f6; }
  .badge-mini.warning { background: #f59e0b; color: white; }
  
  .user-date {
    font-size: 0.7rem;
    opacity: 0.5;
  }
  
  /* Список книг */
  .book-list {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }
  
  .book-list-item {
    display: flex;
    align-items: center;
    gap: 1rem;
    padding: 0.75rem;
    border-radius: var(--radius);
    background: rgba(255, 255, 255, 0.03);
    transition: all 0.2s ease;
  }
  
  .book-list-item:hover {
    background: rgba(255, 255, 255, 0.1);
    transform: translateX(5px);
  }
  
  .book-cover-mini {
    width: 35px;
    height: 50px;
    object-fit: cover;
    border-radius: var(--radius-sm);
  }
  
  .book-info {
    flex: 1;
  }
  
  .book-title {
    font-weight: 600;
    font-size: 0.95rem;
    margin-bottom: 0.1rem;
  }
  
  .book-author {
    font-size: 0.8rem;
    opacity: 0.6;
  }
  
  .book-meta {
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    gap: 0.25rem;
  }
  
  .genre-tag {
    font-size: 0.7rem;
    padding: 0.2rem 0.4rem;
    border-radius: var(--radius-sm);
    background: rgba(255, 255, 255, 0.1);
  }
  
  .book-date {
    font-size: 0.7rem;
    opacity: 0.5;
  }
  
  /* Список рецензий */
  .review-list {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }
  
  .review-list-item {
    padding: 0.75rem;
    border-radius: var(--radius);
    background: rgba(255, 255, 255, 0.03);
    transition: all 0.2s ease;
  }
  
  .review-list-item:hover {
    background: rgba(255, 255, 255, 0.1);
    transform: translateX(5px);
  }
  
  .review-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 0.5rem;
  }
  
  .review-user {
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }
  
  .reviewer-avatar-mini {
    width: 25px;
    height: 25px;
    border-radius: 50%;
    object-fit: cover;
  }
  
  .reviewer-name {
    font-size: 0.85rem;
    font-weight: 500;
  }
  
  .review-rating-mini i {
    font-size: 0.7rem;
    color: #fbbf24;
  }
  
  .review-rating-mini i.far {
    opacity: 0.3;
  }
  
  .review-book {
    font-size: 0.85rem;
    margin-bottom: 0.5rem;
    opacity: 0.8;
  }
  
  .review-book i {
    margin-right: 0.25rem;
  }
  
  .review-preview {
    font-size: 0.8rem;
    opacity: 0.6;
    line-height: 1.4;
    margin-bottom: 0.5rem;
  }
  
  .review-footer {
    display: flex;
    justify-content: space-between;
    align-items: center;
  }
  
  .review-date {
    font-size: 0.7rem;
    opacity: 0.5;
  }
  
