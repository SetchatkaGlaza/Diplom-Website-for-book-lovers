

<div class="forum-appeals-page">
  <!-- Герой-секция -->
  <div class="appeals-hero">
    <div class="appeals-hero-content">
      <div class="hero-icon">
        <i class="fas fa-gavel"></i>
      </div>
      <h1 class="hero-title">Модерация обращений</h1>
      <p class="hero-description">
        Управление апелляциями пользователей на удалённые сообщения
      </p>
    </div>
    
    <!-- Кнопки действий -->
    <div class="hero-actions">
      <a href="/admin/forum" class="btn-action btn-overview">
        <i class="fas fa-chart-line"></i>
        <span>Обзор форума</span>
      </a>
      <a href="/admin/forum/topics" class="btn-action btn-topics">
        <i class="fas fa-list-ul"></i>
        <span>Все топики</span>
      </a>
    </div>
  </div>
  
  <!-- Вкладки статусов -->
  <div class="status-tabs">
    <a href="/admin/forum/appeals?status=appealed" 
       class="tab-item <%= currentStatus === 'appealed' ? 'active' : '' %>">
      <i class="fas fa-envelope-open-text"></i>
      <span>Новые обращения</span>
      <span class="tab-badge"><%= cases.filter(c => c.status === 'appealed').length %></span>
    </a>
    <a href="/admin/forum/appeals?status=deleted" 
       class="tab-item <%= currentStatus === 'deleted' ? 'active' : '' %>">
      <i class="fas fa-trash-alt"></i>
      <span>Без обращения</span>
      <span class="tab-badge"><%= cases.filter(c => c.status === 'deleted').length %></span>
    </a>
    <a href="/admin/forum/appeals?status=restored" 
       class="tab-item <%= currentStatus === 'restored' ? 'active' : '' %>">
      <i class="fas fa-undo-alt"></i>
      <span>Восстановленные</span>
      <span class="tab-badge"><%= cases.filter(c => c.status === 'restored').length %></span>
    </a>
    <a href="/admin/forum/appeals?status=kept" 
       class="tab-item <%= currentStatus === 'kept' ? 'active' : '' %>">
      <i class="fas fa-ban"></i>
      <span>Оставлены удалёнными</span>
      <span class="tab-badge"><%= cases.filter(c => c.status === 'kept').length %></span>
    </a>
  </div>
  
  <!-- Список обращений -->
  <div class="appeals-list">
    <% if (cases && cases.length > 0) { %>
      <% cases.forEach(item => { %>
        <div class="appeal-card" data-appeal-id="<%= item.id %>">
          <!-- Заголовок карточки -->
          <div class="appeal-card-header">
            <div class="topic-info">
              <div class="topic-icon">
                <i class="fas fa-comment-dots"></i>
              </div>
              <div class="topic-details">
                <h3 class="topic-title">
                  <a href="/forum/topic/<%= item.topic_id %>" target="_blank" rel="noopener">
                    <%= item.topic ? item.topic.title : 'Топик удалён' %>
                    <i class="fas fa-external-link-alt"></i>
                  </a>
                </h3>
                <div class="topic-meta">
                  <span class="meta-author">
                    <i class="fas fa-user"></i>
                    Автор: <strong><%= item.user ? item.user.name : '—' %></strong>
                  </span>
                  <span class="meta-moderator">
                    <i class="fas fa-user-shield"></i>
                    Удалил: <strong><%= item.moderator ? item.moderator.name : '—' %></strong>
                  </span>
                  <span class="meta-date">
                    <i class="fas fa-calendar-alt"></i>
                    <%= new Date(item.createdAt).toLocaleString('ru-RU') %>
                  </span>
                </div>
              </div>
            </div>
            <div class="status-badge status-<%= item.status %>">
              <% if (item.status === 'appealed') { %>
                <i class="fas fa-envelope-open-text"></i> Ожидает решения
              <% } else if (item.status === 'deleted') { %>
                <i class="fas fa-trash-alt"></i> Удалено
              <% } else if (item.status === 'restored') { %>
                <i class="fas fa-check-circle"></i> Восстановлено
              <% } else if (item.status === 'kept') { %>
                <i class="fas fa-ban"></i> Оставлено удалённым
              <% } %>
            </div>
          </div>
          
          <!-- Причина удаления -->
          <div class="appeal-section">
            <div class="section-label">
              <i class="fas fa-exclamation-triangle"></i>
              Причина удаления
            </div>
            <div class="section-content reason-content">
              <%= item.delete_reason %>
            </div>
          </div>
          
          <!-- Удалённый текст -->
          <div class="appeal-section">
            <div class="section-label">
              <i class="fas fa-trash-alt"></i>
              Удалённый текст
            </div>
            <div class="section-content deleted-content">
              <%= item.content.replace(/\n/g, '<br>') %>
            </div>
          </div>
          
          <!-- Объяснение автора (если есть) -->
          <% if (item.user_explanation) { %>
            <div class="appeal-section highlight">
              <div class="section-label">
                <i class="fas fa-pen-fancy"></i>
                Объяснение автора
              </div>
              <div class="section-content explanation-content">
                <i class="fas fa-quote-left quote-icon"></i>
                <%= item.user_explanation.replace(/\n/g, '<br>') %>
              </div>
            </div>
          <% } %>
          
          <!-- Решение (если уже принято) -->
          <% if (item.resolution_comment) { %>
            <div class="appeal-section resolution">
              <div class="section-label">
                <i class="fas fa-gavel"></i>
                Решение администратора
              </div>
              <div class="section-content resolution-content">
                <i class="fas fa-comment-dots"></i>
                <%= item.resolution_comment %>
              </div>
            </div>
          <% } %>
          
          <!-- Форма действий для необработанных -->
          <% if (item.status === 'appealed') { %>
            <form action="/admin/forum/appeals/<%= item.id %>/resolve" method="POST" class="action-form">
              <div class="action-input-group">
                <div class="input-wrapper">
                  <i class="fas fa-comment"></i>
                  <input type="text" name="comment" placeholder="Комментарий для пользователя (необязательно)" autocomplete="off">
                </div>
                <div class="action-buttons">
                  <button type="submit" name="action" value="restore" class="btn-restore">
                    <i class="fas fa-undo-alt"></i>
                    <span>Восстановить</span>
                  </button>
                  <button type="submit" name="action" value="keep" class="btn-keep">
                    <i class="fas fa-ban"></i>
                    <span>Оставить удалённым</span>
                  </button>
                </div>
              </div>
            </form>
          <% } %>
        </div>
      <% }) %>
    <% } else { %>
      <div class="empty-state">
        <div class="empty-icon">
          <i class="fas fa-inbox"></i>
        </div>
        <h3 class="empty-title">Нет обращений</h3>
        <p class="empty-description">По выбранному статусу обращений не найдено</p>
      </div>
    <% } %>
  </div>
</div>

<style>
  /* ===== ОСНОВНЫЕ ПЕРЕМЕННЫЕ ===== */
