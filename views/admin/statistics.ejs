<div class="admin-statistics-simple">
  <div class="page-header">
    <div>
      <h1><i class="fas fa-chart-bar"></i> Статистика проекта</h1>
      <p class="text-muted">Обновлено: <%= new Date().toLocaleString('ru-RU') %></p>
    </div>
    <div class="header-actions">
      <a href="/admin" class="btn btn-outline btn-sm"><i class="fas fa-arrow-left"></i> Назад в админку</a>
      <link rel="stylesheet" href="/css/admin.css">
    </div>
  </div>

  <div class="stats-cards">
    <div class="stat-card"><strong><%= stats.totalUsers.toLocaleString() %></strong><span>Пользователей (+<%= stats.newUsersToday %> сегодня)</span></div>
    <div class="stat-card"><strong><%= stats.totalBooks.toLocaleString() %></strong><span>Книг (+<%= stats.newBooksToday %> сегодня)</span></div>
    <div class="stat-card"><strong><%= stats.totalReviews.toLocaleString() %></strong><span>Рецензий (+<%= stats.newReviewsToday %> сегодня)</span></div>
    <div class="stat-card"><strong><%= stats.totalGenres.toLocaleString() %></strong><span>Жанров</span></div>
  </div>

  <div class="tables-grid">
    <section class="table-card">
      <div class="table-title-row">
        <h2>Топ популярных книг</h2>
        <a href="/admin/books" class="btn btn-primary btn-sm">Управление книгами</a>
      </div>
      <div class="table-wrapper">
        <table class="simple-admin-table">
          <thead>
            <tr>
              <th style="width:64px;">#</th>
              <th>Название</th>
              <th>Автор</th>
              <th style="width:140px;">Просмотры</th>
            </tr>
          </thead>
          <tbody>
            <% if (topBooks && topBooks.length > 0) { %>
              <% topBooks.forEach((book, index) => { %>
                <tr>
                  <td data-label="#"><%= index + 1 %></td>
                  <td data-label="Название"><a href="/books/<%= book.id %>" target="_blank" rel="noopener"><%= book.title %></a></td>
                  <td data-label="Автор"><%= book.author %></td>
                  <td data-label="Просмотры" class="text-center"><%= book.views_count.toLocaleString() %></td>
                </tr>
              <% }) %>
            <% } else { %>
              <tr><td colspan="4" class="text-center">Нет данных</td></tr>
            <% } %>
          </tbody>
        </table>
      </div>
    </section>

    <section class="table-card">
      <div class="table-title-row">
        <h2>Топ активных пользователей</h2>
        <a href="/admin/users" class="btn btn-primary btn-sm">Управление пользователями</a>
      </div>
      <div class="table-wrapper">
        <table class="simple-admin-table">
          <thead>
            <tr>
              <th style="width:64px;">#</th>
              <th>Пользователь</th>
              <th style="width:160px;">Рецензий</th>
            </tr>
          </thead>
          <tbody>
            <% if (topUsers && topUsers.length > 0) { %>
              <% topUsers.forEach((item, index) => { %>
                <tr>
                  <td data-label="#"><%= index + 1 %></td>
                  <td data-label="Пользователь"><a href="/profile/<%= item.id %>" target="_blank" rel="noopener"><%= item.name %></a></td>
                  <td data-label="Рецензий" class="text-center"><%= item.reviews_count %></td>
                </tr>
              <% }) %>
            <% } else { %>
              <tr><td colspan="3" class="text-center">Нет данных</td></tr>
            <% } %>
          </tbody>
        </table>
      </div>
    </section>
  </div>
</div>

<style>
  .admin-statistics-simple { color: #fff; }
  .page-header { display:flex; justify-content:space-between; gap:1rem; align-items:flex-start; margin-bottom:1.25rem; flex-wrap:wrap; }
  .page-header h1 { margin:0 0 .25rem; font-size:1.75rem; line-height:1.2; }
  .text-muted { opacity:.75; margin:0; }
  .stats-cards { display:grid; grid-template-columns:repeat(auto-fit,minmax(220px,1fr)); gap:12px; margin-bottom:1rem; }
  .stat-card {
    background: linear-gradient(160deg, rgba(255,255,255,.11), rgba(255,255,255,.04));
    border:1px solid rgba(255,255,255,.16);
    border-radius:14px;
    padding:14px 16px;
    display:flex;
    flex-direction:column;
    gap:7px;
    min-height:92px;
  }
  .stat-card strong { font-size:1.34rem; line-height:1; }
  .stat-card span { opacity:.92; font-size:.92rem; }
  .tables-grid { display:grid; grid-template-columns:repeat(auto-fit,minmax(420px,1fr)); gap:16px; }
  .table-card { background:rgba(255,255,255,.08); border:1px solid rgba(255,255,255,.16); border-radius:14px; padding:14px; }
  .table-title-row { display:flex; justify-content:space-between; align-items:center; gap:10px; margin-bottom:12px; flex-wrap:wrap; }
  .table-title-row h2 { margin:0; font-size:1.08rem; }
  .table-wrapper {
    overflow-x:auto;
    border: 1px solid rgba(255,255,255,.12);
    border-radius: 10px;
    scrollbar-width: thin;
    scrollbar-color: rgba(255,255,255,.38) transparent;
  }
  .table-wrapper::-webkit-scrollbar { height: 7px; }
  .table-wrapper::-webkit-scrollbar-thumb { background: rgba(255,255,255,.35); border-radius: 7px; }
  .simple-admin-table { width:100%; min-width:560px; border-collapse:collapse; table-layout:fixed; }
  .simple-admin-table th, .simple-admin-table td { border-bottom:1px solid rgba(255,255,255,.14); padding:10px 12px; vertical-align:middle; }
  .simple-admin-table th { font-weight:600; background:rgba(0,0,0,.25); text-align:left; font-size:.86rem; letter-spacing:.02em; }
  .simple-admin-table td { background:rgba(255,255,255,.02); word-break:break-word; font-size:.92rem; }
  .simple-admin-table tr:last-child td { border-bottom: none; }
  .simple-admin-table a { color:#fff; text-decoration:underline; text-underline-offset:2px; }
  .text-center { text-align:center; }

  @media (max-width: 900px) {
    .tables-grid { grid-template-columns: 1fr; }
  }

  @media (max-width: 768px) {
    .page-header { flex-direction: column; align-items: stretch; }
    .header-actions .btn { width: 100%; justify-content: center; }
    .table-title-row { align-items: stretch; }
    .table-title-row .btn { width: 100%; justify-content: center; }
    .table-card { padding: 10px; }
    .simple-admin-table { min-width: 520px; }
    .simple-admin-table th, .simple-admin-table td { padding: 9px 10px; font-size: .86rem; }
  }

  @media (max-width: 480px) {
    .page-header h1 { font-size: 1.4rem; }
    .stat-card { padding: 12px; min-height: 84px; }
    .stat-card strong { font-size: 1.15rem; }
    .stat-card span { font-size: .84rem; }
    .simple-admin-table { min-width: 460px; }
  }
</style>
