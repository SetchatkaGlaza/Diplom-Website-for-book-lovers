<div class="admin-statistics-simple">
  <div class="page-header">
    <div>
      <h1><i class="fas fa-chart-bar"></i> Статистика проекта</h1>
      <p class="text-muted">Обновлено: <%= new Date().toLocaleString('ru-RU') %></p>
    </div>
    <div class="header-actions">
      <a href="/admin" class="btn btn-outline btn-sm"><i class="fas fa-arrow-left"></i> Назад в админку</a>
      <link rel="stylesheet" href="/css/admin.css">
    </div>
  </div>

  <div class="stats-cards">
    <div class="stat-card"><strong><%= stats.totalUsers.toLocaleString() %></strong><span>Пользователей (+<%= stats.newUsersToday %> сегодня)</span></div>
    <div class="stat-card"><strong><%= stats.totalBooks.toLocaleString() %></strong><span>Книг (+<%= stats.newBooksToday %> сегодня)</span></div>
    <div class="stat-card"><strong><%= stats.totalReviews.toLocaleString() %></strong><span>Рецензий (+<%= stats.newReviewsToday %> сегодня)</span></div>
    <div class="stat-card"><strong><%= stats.totalGenres.toLocaleString() %></strong><span>Жанров</span></div>
  </div>

  <div class="tables-grid">
    <section class="table-card">
      <div class="table-title-row">
        <h2>Топ популярных книг</h2>
        <a href="/admin/books" class="btn btn-primary btn-sm">Управление книгами</a>
      </div>
      <div class="table-wrapper">
        <table class="simple-admin-table">
          <thead>
            <tr>
              <th style="width:64px;">#</th>
              <th>Название</th>
              <th>Автор</th>
              <th style="width:140px;">Просмотры</th>
            </tr>
          </thead>
          <tbody>
            <% if (topBooks && topBooks.length > 0) { %>
              <% topBooks.forEach((book, index) => { %>
                <tr>
                  <td><%= index + 1 %></td>
                  <td><a href="/books/<%= book.id %>" target="_blank" rel="noopener"><%= book.title %></a></td>
                  <td><%= book.author %></td>
                  <td class="text-center"><%= book.views_count.toLocaleString() %></td>
                </tr>
              <% }) %>
            <% } else { %>
              <tr><td colspan="4" class="text-center">Нет данных</td></tr>
            <% } %>
          </tbody>
        </table>
      </div>
    </section>

    <section class="table-card">
      <div class="table-title-row">
        <h2>Топ активных пользователей</h2>
        <a href="/admin/users" class="btn btn-primary btn-sm">Управление пользователями</a>
      </div>
      <div class="table-wrapper">
        <table class="simple-admin-table">
          <thead>
            <tr>
              <th style="width:64px;">#</th>
              <th>Пользователь</th>
              <th style="width:160px;">Рецензий</th>
            </tr>
          </thead>
          <tbody>
            <% if (topUsers && topUsers.length > 0) { %>
              <% topUsers.forEach((item, index) => { %>
                <tr>
                  <td><%= index + 1 %></td>
                  <td><a href="/profile/<%= item.id %>" target="_blank" rel="noopener"><%= item.name %></a></td>
                  <td class="text-center"><%= item.reviews_count %></td>
                </tr>
              <% }) %>
            <% } else { %>
              <tr><td colspan="3" class="text-center">Нет данных</td></tr>
            <% } %>
          </tbody>
        </table>
      </div>
    </section>
  </div>
</div>

<style>
  .admin-statistics-simple { color: #fff; }
  .page-header { display:flex; justify-content:space-between; gap:1rem; align-items:flex-start; margin-bottom:1.25rem; flex-wrap:wrap; }
  .page-header h1 { margin:0 0 .25rem; font-size:1.75rem; }
  .text-muted { opacity:.75; margin:0; }
  .stats-cards { display:grid; grid-template-columns:repeat(auto-fit,minmax(220px,1fr)); gap:12px; margin-bottom:1rem; }
  .stat-card { background:rgba(255,255,255,.08); border:1px solid rgba(255,255,255,.16); border-radius:12px; padding:12px 14px; display:flex; flex-direction:column; gap:6px; }
  .stat-card strong { font-size:1.25rem; line-height:1; }
  .tables-grid { display:grid; grid-template-columns:repeat(auto-fit,minmax(420px,1fr)); gap:16px; }
  .table-card { background:rgba(255,255,255,.08); border:1px solid rgba(255,255,255,.16); border-radius:12px; padding:12px; }
  .table-title-row { display:flex; justify-content:space-between; align-items:center; gap:10px; margin-bottom:10px; flex-wrap:wrap; }
  .table-title-row h2 { margin:0; font-size:1.1rem; }
  .table-wrapper { overflow-x:auto; }
  .simple-admin-table { width:100%; border-collapse:collapse; table-layout:fixed; }
  .simple-admin-table th, .simple-admin-table td { border:1px solid rgba(255,255,255,.14); padding:10px; vertical-align:middle; }
  .simple-admin-table th { font-weight:600; background:rgba(0,0,0,.2); }
  .simple-admin-table td { background:rgba(255,255,255,.02); word-break:break-word; }
  .simple-admin-table tr { height:48px; }
  .simple-admin-table a { color:#fff; text-decoration:underline; text-underline-offset:2px; }
  .text-center { text-align:center; }

  @media (max-width: 768px) {
    .tables-grid {
      grid-template-columns: 1fr;
    }

    .table-card {
      padding: 10px;
    }

    .table-wrapper {
      margin-inline: -6px;
      padding-inline: 6px;
    }

    .simple-admin-table {
      min-width: 540px;
      table-layout: auto;
    }
  }
</style>
