<div class="admin-statistics">
  <!-- Заголовок -->
  <div class="page-header">
    <h1><i class="fas fa-chart-bar"></i> Статистика проекта</h1>
    <p class="text-muted">Обновлено: <%= new Date().toLocaleString('ru-RU') %></p>
  </div>
  
  <!-- Карточки с основной статистикой -->
  <div class="stats-cards">
    <div class="stat-card primary">
      <div class="stat-icon">
        <i class="fas fa-users"></i>
      </div>
      <div class="stat-content">
        <div class="stat-value"><%= stats.totalUsers.toLocaleString() %></div>
        <div class="stat-label">Пользователей</div>
        <div class="stat-today">+<%= stats.newUsersToday %> сегодня</div>
      </div>
    </div>
    
    <div class="stat-card success">
      <div class="stat-icon">
        <i class="fas fa-book"></i>
      </div>
      <div class="stat-content">
        <div class="stat-value"><%= stats.totalBooks.toLocaleString() %></div>
        <div class="stat-label">Книг</div>
        <div class="stat-today">+<%= stats.newBooksToday %> сегодня</div>
      </div>
    </div>
    
    <div class="stat-card warning">
      <div class="stat-icon">
        <i class="fas fa-star"></i>
      </div>
      <div class="stat-content">
        <div class="stat-value"><%= stats.totalReviews.toLocaleString() %></div>
        <div class="stat-label">Рецензий</div>
        <div class="stat-today">+<%= stats.newReviewsToday %> сегодня</div>
      </div>
    </div>
    
    <div class="stat-card info">
      <div class="stat-icon">
        <i class="fas fa-tags"></i>
      </div>
      <div class="stat-content">
        <div class="stat-value"><%= stats.totalGenres.toLocaleString() %></div>
        <div class="stat-label">Жанров</div>
      </div>
    </div>
  </div>
  
  <!-- Две колонки с таблицами -->
  <div class="tables-row">
    <!-- Левая колонка -->
    <div class="table-container">
      <div class="table-header">
        <h2><i class="fas fa-fire"></i> Топ популярных книг</h2>
        <span class="badge">по просмотрам</span>
      </div>
      
      <table class="admin-table">
        <thead>
          <tr>
            <th>#</th>
            <th>Книга</th>
            <th>Автор</th>
            <th>Просмотры</th>
          </tr>
        </thead>
        <tbody>
          <% if (topBooks && topBooks.length > 0) { %>
            <% topBooks.forEach((book, index) => { %>
              <tr>
                <td><%= index + 1 %></td>
                <td class="book-cell">
                  <img src="/images/covers/<%= book.cover_image %>" alt="<%= book.title %>" class="table-cover">
                  <a href="/books/<%= book.id %>" target="_blank"><%= book.title.length > 30 ? book.title.substring(0, 30) + '...' : book.title %></a>
                </td>
                <td><%= book.author.length > 20 ? book.author.substring(0, 20) + '...' : book.author %></td>
                <td class="text-center"><strong><%= book.views_count.toLocaleString() %></strong></td>
              </tr>
            <% }) %>
          <% } else { %>
            <tr><td colspan="4" class="text-center">Нет данных</td></tr>
          <% } %>
        </tbody>
      </table>
    </div>
    
    <!-- Правая колонка -->
    <div class="table-container">
      <div class="table-header">
        <h2><i class="fas fa-star"></i> Топ книг по рейтингу</h2>
        <span class="badge">минимум 3 оценки</span>
      </div>
      
      <table class="admin-table">
        <thead>
          <tr>
            <th>#</th>
            <th>Книга</th>
            <th>Рейтинг</th>
            <th>Оценок</th>
          </tr>
        </thead>
        <tbody>
          <% if (topRatedBooks && topRatedBooks.length > 0) { %>
            <% topRatedBooks.forEach((book, index) => { %>
              <tr>
                <td><%= index + 1 %></td>
                <td class="book-cell">
                  <img src="/images/covers/<%= book.cover_image %>" alt="<%= book.title %>" class="table-cover">
                  <a href="/books/<%= book.id %>" target="_blank"><%= book.title.length > 30 ? book.title.substring(0, 30) + '...' : book.title %></a>
                </td>
                <td class="text-center">
                  <span class="rating-badge">
                    <%= parseFloat(book.avg_rating).toFixed(1) %> ★
                  </span>
                </td>
                <td class="text-center"><%= book.reviews_count %></td>
              </tr>
            <% }) %>
          <% } else { %>
            <tr><td colspan="4" class="text-center">Нет данных</td></tr>
          <% } %>
        </tbody>
      </table>
    </div>
  </div>
  
  <!-- Вторая строка таблиц -->
  <div class="tables-row">
    <!-- Левая колонка -->
    <div class="table-container">
      <div class="table-header">
        <h2><i class="fas fa-users"></i> Топ активных пользователей</h2>
        <span class="badge">по количеству рецензий</span>
      </div>
      
      <table class="admin-table">
        <thead>
          <tr>
            <th>#</th>
            <th>Пользователь</th>
            <th>Рецензий</th>
          </tr>
        </thead>
        <tbody>
          <% if (topUsers && topUsers.length > 0) { %>
            <% topUsers.forEach((user, index) => { %>
              <tr>
                <td><%= index + 1 %></td>
                <td class="user-cell">
                  <img src="/images/avatars/<%= user.avatar || 'default-avatar.png' %>" alt="<%= user.name %>" class="table-avatar">
                  <a href="/profile/<%= user.id %>" target="_blank"><%= user.name %></a>
                </td>
                <td class="text-center"><strong><%= user.reviews_count %></strong></td>
              </tr>
            <% }) %>
          <% } else { %>
            <tr><td colspan="3" class="text-center">Нет данных</td></tr>
          <% } %>
        </tbody>
      </table>
    </div>
    
    <!-- Правая колонка -->
    <div class="table-container">
      <div class="table-header">
        <h2><i class="fas fa-chart-pie"></i> Популярные жанры</h2>
        <span class="badge">по количеству книг</span>
      </div>
      
      <table class="admin-table">
        <thead>
          <tr>
            <th>#</th>
            <th>Жанр</th>
            <th>Книг</th>
          </tr>
        </thead>
        <tbody>
          <% if (popularGenres && popularGenres.length > 0) { %>
            <% popularGenres.forEach((genre, index) => { %>
              <tr>
                <td><%= index + 1 %></td>
                <td><%= genre.name %></td>
                <td class="text-center"><strong><%= genre.books_count %></strong></td>
              </tr>
            <% }) %>
          <% } else { %>
            <tr><td colspan="3" class="text-center">Нет данных</td></tr>
          <% } %>
        </tbody>
      </table>
    </div>
  </div>
  
  <!-- Кнопка обновления -->
  <div class="actions-footer">
    <a href="/admin/statistics" class="btn btn-primary">
      <i class="fas fa-sync-alt"></i> Обновить данные
    </a>
  </div>
</div>

<style>
  .admin-body {
  background: linear-gradient(135deg, #1a1a2e, #16213e);
  min-height: 100vh;
}

.admin-wrapper {
  display: flex;
  min-height: 100vh;
}

.admin-sidebar {
  width: 260px;
  background: rgba(0, 0, 0, 0.3);
  backdrop-filter: blur(10px);
  -webkit-backdrop-filter: blur(10px);
  border-right: 1px solid rgba(255, 255, 255, 0.1);
  padding: 1.5rem;
  display: flex;
  flex-direction: column;
  position: fixed;
  top: 0;
  left: 0;
  bottom: 0;
  overflow-y: auto;
}

.admin-logo {
  text-align: center;
  margin-bottom: 2rem;
  padding-bottom: 1rem;
  border-bottom: 1px solid rgba(255, 255, 255, 0.1);
}

.admin-logo i {
  font-size: 2.5rem;
  color: var(--accent);
  display: block;
  margin-bottom: 0.5rem;
}

.admin-logo span {
  font-size: 1.2rem;
  font-weight: 600;
  color: white;
  display: block;
}

.admin-logo small {
  color: rgba(255, 255, 255, 0.6);
  font-size: 0.8rem;
}

.admin-nav {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 0.25rem;
}

.admin-nav-item {
  display: flex;
  align-items: center;
  gap: 0.75rem;
  padding: 0.75rem 1rem;
  color: rgba(255, 255, 255, 0.8);
  text-decoration: none;
  border-radius: var(--radius);
  transition: all 0.3s;
}

.admin-nav-item i {
  width: 20px;
  font-size: 1.1rem;
}

.admin-nav-item:hover,
.admin-nav-item.active {
  background: rgba(255, 255, 255, 0.1);
  color: white;
  transform: translateX(5px);
}

.admin-nav-divider {
  height: 1px;
  background: rgba(255, 255, 255, 0.1);
  margin: 1rem 0;
}

.admin-user {
  display: flex;
  align-items: center;
  gap: 0.75rem;
  padding: 1rem;
  background: rgba(255, 255, 255, 0.1);
  border-radius: var(--radius);
  margin-top: 1rem;
}

.admin-user img {
  width: 40px;
  height: 40px;
  border-radius: 50%;
  object-fit: cover;
}

.admin-user div {
  color: white;
}

.admin-user small {
  opacity: 0.7;
}

.admin-main {
  flex: 1;
  margin-left: 260px;
  padding: 2rem;
  min-height: 100vh;
}

.admin-content {
  max-width: 1400px;
  margin: 0 auto;
}

@media (max-width: 768px) {
  .admin-sidebar {
    width: 100%;
    position: relative;
    height: auto;
  }
  
  .admin-main {
    margin-left: 0;
  }
  
  .admin-wrapper {
    flex-direction: column;
  }
}
  
  /* Общие стили для страницы статистики */
  .admin-statistics {
    padding: 1.5rem;
    color: white;
  }
  
  .page-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 2rem;
    padding: 1rem 1.5rem;
    background: rgba(255, 255, 255, 0.1);
    backdrop-filter: blur(10px);
    -webkit-backdrop-filter: blur(10px);
    border: 1px solid rgba(255, 255, 255, 0.2);
    border-radius: var(--radius-lg);
  }
  
  .page-header h1 {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    font-size: 1.8rem;
    margin: 0;
  }
  
  .page-header h1 i {
    color: var(--accent);
  }
  
  .text-muted {
    opacity: 0.7;
    font-size: 0.9rem;
    margin: 0;
  }
  
  /* Карточки статистики */
  .stats-cards {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
    gap: 1.5rem;
    margin-bottom: 2rem;
  }
  
  .stat-card {
    display: flex;
    align-items: center;
    gap: 1rem;
    padding: 1.5rem;
    border-radius: var(--radius-lg);
    background: rgba(255, 255, 255, 0.1);
    backdrop-filter: blur(10px);
    -webkit-backdrop-filter: blur(10px);
    border: 1px solid rgba(255, 255, 255, 0.2);
    transition: transform 0.3s;
  }
  
  .stat-card:hover {
    transform: translateY(-5px);
  }
  
  .stat-card.primary { background: linear-gradient(135deg, #3b82f6, #2563eb); }
  .stat-card.success { background: linear-gradient(135deg, #10b981, #059669); }
  .stat-card.warning { background: linear-gradient(135deg, #f59e0b, #d97706); }
  .stat-card.info { background: linear-gradient(135deg, #8b5cf6, #7c3aed); }
  
  .stat-icon {
    font-size: 2.5rem;
    opacity: 0.9;
  }
  
  .stat-content {
    flex: 1;
  }
  
  .stat-value {
    font-size: 2rem;
    font-weight: 700;
    line-height: 1.2;
  }
  
  .stat-label {
    font-size: 0.9rem;
    opacity: 0.9;
    text-transform: uppercase;
    letter-spacing: 0.5px;
  }
  
  .stat-today {
    font-size: 0.8rem;
    opacity: 0.8;
    margin-top: 0.25rem;
  }
  
  /* Контейнеры для таблиц */
  .tables-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1.5rem;
    margin-bottom: 1.5rem;
  }
  
  .table-container {
    background: rgba(255, 255, 255, 0.1);
    backdrop-filter: blur(10px);
    -webkit-backdrop-filter: blur(10px);
    border: 1px solid rgba(255, 255, 255, 0.2);
    border-radius: var(--radius-lg);
    padding: 1.5rem;
    transition: transform 0.3s;
  }
  
  .table-container:hover {
    transform: translateY(-3px);
  }
  
  .table-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 1.5rem;
  }
  
  .table-header h2 {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    font-size: 1.3rem;
    margin: 0;
  }
  
  .table-header h2 i {
    color: var(--accent);
  }
  
  .badge {
    background: rgba(255, 255, 255, 0.2);
    padding: 0.25rem 0.75rem;
    border-radius: 50px;
    font-size: 0.8rem;
    font-weight: 500;
  }
  
  /* Таблицы */
  .admin-table {
    width: 100%;
    border-collapse: collapse;
  }
  
  .admin-table th {
    text-align: left;
    padding: 0.75rem 0.5rem;
    border-bottom: 2px solid rgba(255, 255, 255, 0.2);
    font-weight: 600;
    opacity: 0.9;
    font-size: 0.9rem;
  }
  
  .admin-table td {
    padding: 0.75rem 0.5rem;
    border-bottom: 1px solid rgba(255, 255, 255, 0.1);
  }
  
  .admin-table tr:last-child td {
    border-bottom: none;
  }
  
  .admin-table tr:hover td {
    background: rgba(255, 255, 255, 0.05);
  }
  
  .text-center {
    text-align: center;
  }
  
  /* Ячейки с книгами и пользователями */
  .book-cell, .user-cell {
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }
  
  .table-cover {
    width: 30px;
    height: 45px;
    object-fit: cover;
    border-radius: 4px;
  }
  
  .table-avatar {
    width: 30px;
    height: 30px;
    border-radius: 50%;
    object-fit: cover;
  }
  
  .admin-table a {
    color: white;
    text-decoration: none;
    transition: color 0.3s;
  }
  
  .admin-table a:hover {
    color: var(--accent);
    text-decoration: underline;
  }
  
  .rating-badge {
    display: inline-block;
    background: rgba(251, 191, 36, 0.2);
    color: #fbbf24;
    padding: 0.25rem 0.75rem;
    border-radius: 50px;
    font-weight: 600;
  }
  
  .actions-footer {
    text-align: center;
    margin-top: 2rem;
    padding: 1rem;
  }
  
  /* Адаптивность */
  @media (max-width: 1024px) {
    .tables-row {
      grid-template-columns: 1fr;
      gap: 1rem;
    }
  }
  
  @media (max-width: 768px) {
    .page-header {
      flex-direction: column;
      align-items: flex-start;
      gap: 0.5rem;
    }
    
    .stats-cards {
      grid-template-columns: 1fr;
    }
    
    .admin-table {
      font-size: 0.9rem;
    }
    
    .book-cell, .user-cell {
      flex-direction: column;
      align-items: flex-start;
    }
  }
</style>