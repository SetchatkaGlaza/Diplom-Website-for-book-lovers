<div class="forum-admin-page">
  <header class="admin-header">
    <h1><i class="fas fa-list-ul"></i> Форум: все топики</h1>
    <div class="header-actions">
      <a href="/admin/forum" class="btn btn-outline"><i class="fas fa-chart-line"></i> Обзор</a>
      <a href="/admin/forum/moderation" class="btn btn-outline"><i class="fas fa-shield-alt"></i> Модерация</a>
      <a href="/admin/forum/appeals" class="btn btn-outline"><i class="fas fa-inbox"></i> Обращения</a>
      <a href="/admin/forum/categories" class="btn btn-outline"><i class="fas fa-folder"></i> Категории</a>
    </div>
  </header>

  <section class="admin-card moderation-toolbar">
    <form method="GET" action="/admin/forum/topics" class="moderation-filter-form">
      <div class="toolbar-row">
        <input type="search" name="q" value="<%= filters.search %>" placeholder="Поиск по топикам...">
        <select name="category_id">
          <option value="">Все категории</option>
          <% categories.forEach(category => { %>
            <option value="<%= category.id %>" <%= String(filters.category_id) === String(category.id) ? 'selected' : '' %>><%= category.name %></option>
          <% }) %>
        </select>
        <select name="locked">
          <option value="">Закрытие: все</option>
          <option value="yes" <%= filters.locked === 'yes' ? 'selected' : '' %>>Только закрытые</option>
          <option value="no" <%= filters.locked === 'no' ? 'selected' : '' %>>Только открытые</option>
        </select>
        <select name="pinned">
          <option value="">Закрепление: все</option>
          <option value="yes" <%= filters.pinned === 'yes' ? 'selected' : '' %>>Только закреплённые</option>
          <option value="no" <%= filters.pinned === 'no' ? 'selected' : '' %>>Только обычные</option>
        </select>
        <button class="btn btn-primary" type="submit"><i class="fas fa-search"></i> Фильтр</button>
      </div>
    </form>
  </section>

  <section class="admin-card">
    <% if (topics.length) { %>
      <div class="table-responsive">
        <table class="modern-table">
          <thead>
            <tr>
              <th>Топик</th>
              <th>Категория</th>
              <th>Автор</th>
              <th>Ответов</th>
              <th>Статусы</th>
              <th>Действия</th>
            </tr>
          </thead>
          <tbody>
            <% topics.forEach(topic => { %>
              <tr>
                <td>
                  <strong><a href="/forum/topic/<%= topic.id %>" target="_blank"><%= topic.title %></a></strong>
                  <div class="muted"><%= new Date(topic.createdAt).toLocaleString('ru-RU') %></div>
                </td>
                <td><%= topic.category ? topic.category.name : '—' %></td>
                <td><%= topic.user ? topic.user.name : '—' %></td>
                <td><%= topic.replies_count %></td>
                <td>
                  <% if (topic.is_pinned) { %><span class="badge badge-warning">Закреплён</span><% } %>
                  <% if (topic.is_locked) { %><span class="badge badge-danger">Закрыт</span><% } %>
                  <% if (!topic.is_locked && !topic.is_pinned) { %><span class="badge">Обычный</span><% } %>
                </td>
                <td>
                  <div class="moderation-actions">
                    <a class="btn btn-outline" href="/admin/forum/topic/<%= topic.id %>/posts"><i class="fas fa-comments"></i> Сообщения</a>
                    <form action="/admin/forum/topic/<%= topic.id %>/pin" method="POST">
                      <button class="btn btn-outline" type="submit"><i class="fas fa-thumbtack"></i> <%= topic.is_pinned ? 'Открепить' : 'Закрепить' %></button>
                    </form>
                    <form action="/admin/forum/topic/<%= topic.id %>/lock" method="POST">
                      <button class="btn btn-outline" type="submit"><i class="fas fa-lock"></i> <%= topic.is_locked ? 'Открыть' : 'Закрыть' %></button>
                    </form>
                  </div>
                </td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
    <% } else { %>
      <p class="muted">Топики по выбранным фильтрам не найдены.</p>
    <% } %>
  </section>

  <% if (totalPages > 1) { %>
    <nav class="pagination">
      <% for (let i = 1; i <= totalPages; i++) { %>
        <% if (i === currentPage) { %>
          <span class="page-link active"><%= i %></span>
        <% } else { %>
          <a class="page-link" href="/admin/forum/topics?page=<%= i %>&q=<%= encodeURIComponent(filters.search || '') %>&locked=<%= filters.locked %>&pinned=<%= filters.pinned %>&category_id=<%= filters.category_id %>"><%= i %></a>
        <% } %>
      <% } %>
    </nav>
  <% } %>
</div>
