<div class="forum-topic">
  <!-- Хлебные крошки -->
  <div class="topic-breadcrumbs">
    <a href="/forum"><i class="fas fa-home"></i> Форум</a>
    <i class="fas fa-chevron-right"></i>
    <a href="/forum/category/<%= topic.category.id %>"><%= topic.category.name %></a>
    <i class="fas fa-chevron-right"></i>
    <span><%= topic.title %></span>
  </div>

  <!-- Заголовок темы -->
  <div class="topic-header">
    <h1 class="topic-title"><%= topic.title %></h1>

    <div class="topic-info">
      <div class="topic-author">
        <img src="/images/avatars/<%= topic.user.avatar %>" alt="<%= topic.user.name %>" class="topic-avatar">
        <div class="topic-author-details">
          <a href="/profile/<%= topic.user.id %>" class="topic-author-name"><%= topic.user.name %></a>
          <span class="topic-author-role">
            <%= topic.user.role === 'admin' ? 'Администратор' : topic.user.role === 'moderator' ? 'Модератор' : 'Участник' %>
          </span>
        </div>
      </div>

      <div class="topic-stats">
        <div class="stat-item" title="Просмотры">
          <i class="fas fa-eye"></i>
          <span><%= topic.views %></span>
        </div>
        <div class="stat-item" title="Ответы">
          <i class="fas fa-reply-all"></i>
          <span><%= totalPosts %></span>
        </div>
        <div class="stat-item" title="Создана">
          <i class="fas fa-calendar-alt"></i>
          <span><%= new Date(topic.createdAt).toLocaleDateString('ru-RU') %></span>
        </div>
      </div>

      <% if (user && !topic.is_locked) { %>
        <button class="subscribe-btn <%= isSubscribed ? 'subscribed' : '' %>" id="subscribeBtn" data-topic-id="<%= topic.id %>">
          <i class="fas <%= isSubscribed ? 'fa-bell' : 'fa-bell-slash' %>"></i>
          <span><%= isSubscribed ? 'Вы подписаны' : 'Подписаться' %></span>
        </button>
      <% } else if (topic.is_locked) { %>
        <span class="post-badge author-badge"><i class="fas fa-lock"></i> Тема закрыта администратором</span>
      <% } %>
    </div>
  </div>

  <!-- СПИСОК СООБЩЕНИЙ -->
  <div class="posts-container">
    <% posts.forEach((post, index) => { %>
      <div class="post-card" id="post-<%= post.id %>" data-post-id="<%= post.id %>">
        <div class="post-sidebar">
          <img src="/images/avatars/<%= post.user.avatar %>" alt="<%= post.user.name %>" class="post-avatar">

          <div class="post-author-info">
            <a href="/profile/<%= post.user.id %>" class="post-author-name"><%= post.user.name %></a>
            <span class="post-author-role">
              <%= post.user.role === 'admin' ? 'Администратор' : post.user.role === 'moderator' ? 'Модератор' : 'Участник' %>
            </span>
          </div>

          <div class="post-date">
            <div><i class="far fa-calendar-alt"></i> <%= new Date(post.createdAt).toLocaleDateString('ru-RU') %></div>
            <div><i class="far fa-clock"></i> <%= new Date(post.createdAt).toLocaleTimeString('ru-RU', { hour: '2-digit', minute: '2-digit' }) %></div>
          </div>

          <% if (post.user_id === topic.user_id && index === 0) { %>
            <div class="post-badge author-badge">
              <i class="fas fa-crown"></i> Автор темы
            </div>
          <% } %>

          <div class="post-stats-mini">
            <span title="Лайки">
              <i class="fas fa-heart"></i>
              <span class="post-likes-count" data-likes-full="<%= post.likes_count %>"><%= post.likes_count %></span>
            </span>
          </div>
        </div>

        <div class="post-main">
          <div class="post-content" data-raw-content="<%= post.content.replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;').replace(/\"/g, '&quot;').replace(/\n/g, '\\n') %>">
            <%- post.content
              .replace(/&/g, '&amp;')
              .replace(/</g, '&lt;')
              .replace(/>/g, '&gt;')
              .replace(/\n/g, '<br>') %>
          </div>

          <div class="post-footer">
            <button class="action-btn like-btn <%= userLikes.includes(post.id) ? 'liked' : '' %>"
                    data-post-id="<%= post.id %>"
                    <%= (!user || topic.is_locked) ? 'disabled' : '' %>>
              <i class="fas fa-heart"></i>
              <span class="likes-count" data-likes-full="<%= post.likes_count %>"><%= post.likes_count %></span>
            </button>

            <% if (user && !topic.is_locked) { %>
              <button class="action-btn quote-btn" data-post-id="<%= post.id %>" data-author="<%= post.user.name %>">
                <i class="fas fa-quote-right"></i>
                <span>Цитировать</span>
              </button>
            <% } %>
          </div>
        </div>
      </div>
    <% }) %>
  </div>

  <!-- Пагинация -->
  <% if (totalPages > 1) { %>
    <div class="pagination">
      <% if (currentPage > 1) { %>
        <a href="?page=<%= currentPage - 1 %>" class="page-link">
          <i class="fas fa-chevron-left"></i>
        </a>
      <% } %>

      <% for(let i = 1; i <= totalPages; i++) { %>
        <% if (i === currentPage) { %>
          <span class="page-link active"><%= i %></span>
        <% } else { %>
          <a href="?page=<%= i %>" class="page-link"><%= i %></a>
        <% } %>
      <% } %>

      <% if (currentPage < totalPages) { %>
        <a href="?page=<%= currentPage + 1 %>" class="page-link">
          <i class="fas fa-chevron-right"></i>
        </a>
      <% } %>
    </div>
  <% } %>

  <!-- Форма ответа -->
  <% if (user && !topic.is_locked) { %>
    <div class="reply-section" id="reply-section">
      <h3 class="reply-title">
        <i class="fas fa-reply"></i>
        Ответить в тему
      </h3>

      <div id="quote-preview" class="quote-preview" style="display: none;">
        <div class="quote-preview-header">
          <i class="fas fa-quote-left"></i>
          <span>Вы цитируете сообщение от <span id="quote-author"></span></span>
          <button type="button" class="remove-quote" onclick="removeQuote()">
            <i class="fas fa-times"></i>
          </button>
        </div>
        <div class="quote-preview-content" id="quote-content"></div>
      </div>

      <form action="/forum/topic/<%= topic.id %>/reply" method="POST" class="reply-form" id="reply-form">
        <textarea
          id="reply-content"
          name="content"
          rows="6"
          placeholder="Напишите ваш ответ..."
          required
        ></textarea>

        <div class="reply-actions">
          <button type="submit" class="submit-btn">
            <i class="fas fa-paper-plane"></i>
            Отправить ответ
          </button>
        </div>
      </form>
    </div>
  <% } else if (topic.is_locked) { %>
    <div class="login-prompt">
      <i class="fas fa-lock"></i>
      <p>Тема закрыта: новые ответы и реакции отключены.</p>
    </div>
  <% } else { %>
    <div class="login-prompt">
      <i class="fas fa-lock"></i>
      <p><a href="/auth/login">Войдите</a>, чтобы отвечать в темах</p>
    </div>
  <% } %>
</div>

<script>
  let currentQuote = null;

  function formatLikesCount(value) {
    const likes = Number(value) || 0;
    if (likes < 1000) return String(likes);
    return new Intl.NumberFormat('ru-RU', {
      notation: 'compact',
      compactDisplay: 'short',
      maximumFractionDigits: 1
    }).format(likes);
  }

  function applyLikesFormatting() {
    document.querySelectorAll('.likes-count, .post-likes-count').forEach((element) => {
      const fullValue = element.getAttribute('data-likes-full') || element.textContent;
      element.textContent = formatLikesCount(fullValue);
      element.title = `${Number(fullValue) || 0} лайков`;
    });
  }

  applyLikesFormatting();

  document.getElementById('subscribeBtn')?.addEventListener('click', async function() {
    const topicId = this.dataset.topicId;
    try {
      const response = await fetch(`/forum/topic/${topicId}/subscribe`, { method: 'POST' });
      if (response.ok) {
        const data = await response.json();
        if (data.action === 'subscribed') {
          this.innerHTML = '<i class="fas fa-bell"></i><span>Вы подписаны</span>';
          this.classList.add('subscribed');
        } else {
          this.innerHTML = '<i class="fas fa-bell-slash"></i><span>Подписаться</span>';
          this.classList.remove('subscribed');
        }
      }
    } catch (error) {
      console.error('Ошибка:', error);
    }
  });

  document.querySelectorAll('.like-btn').forEach((btn) => {
    btn.addEventListener('click', async function(e) {
      e.preventDefault();
      if (this.disabled) return;
      const postId = this.dataset.postId;
      const likesCountSpan = this.querySelector('.likes-count');
      const postLikesSpan = document.querySelector(`.post-card[data-post-id="${postId}"] .post-likes-count`);

      this.disabled = true;
      this.style.opacity = '0.6';

      try {
        const response = await fetch(`/forum/post/${postId}/like`, { method: 'POST', headers: { 'Content-Type': 'application/json' } });
        if (response.ok) {
          const data = await response.json();
          if (data.success) {
            likesCountSpan.dataset.likesFull = data.likesCount;
            likesCountSpan.textContent = formatLikesCount(data.likesCount);
            likesCountSpan.title = `${data.likesCount} лайков`;

            if (postLikesSpan) {
              postLikesSpan.dataset.likesFull = data.likesCount;
              postLikesSpan.textContent = formatLikesCount(data.likesCount);
              postLikesSpan.title = `${data.likesCount} лайков`;
            }

            if (data.action === 'liked') {
              this.classList.add('liked');
              this.style.transform = 'scale(1.08)';
              setTimeout(() => { this.style.transform = ''; }, 200);
            } else {
              this.classList.remove('liked');
            }
          }
        }
      } catch (error) {
        console.error('Ошибка:', error);
      } finally {
        this.disabled = false;
        this.style.opacity = '';
      }
    });
  });

  function removeLegacyQuoteBlocks(text) {
    let source = String(text || '');
    let iterations = 0;

    while (iterations < 10) {
      const markerMatch = source.match(/Цитата от [^:\n]+:\s*\n?\s*«/);
      if (!markerMatch) break;

      const start = markerMatch.index;
      const quoteStart = start + markerMatch[0].length - 1;
      let depth = 0;
      let end = -1;

      for (let i = quoteStart; i < source.length; i += 1) {
        if (source[i] === '«') depth += 1;
        if (source[i] === '»') {
          depth -= 1;
          if (depth === 0) {
            end = i;
            break;
          }
        }
      }

      if (end === -1) break;

      source = `${source.slice(0, start)}${source.slice(end + 1)}`.replace(/^\s+|\s+$/g, '');
      iterations += 1;
    }

    return source;
  }

  function getCleanPostContent(postId) {
    const postCard = document.getElementById(`post-${postId}`);
    if (!postCard) return '';
    const contentDiv = postCard.querySelector('.post-content');
    if (!contentDiv) return '';
    let raw = contentDiv.getAttribute('data-raw-content');
    if (!raw) return '';

    const textarea = document.createElement('textarea');
    textarea.innerHTML = raw;
    let content = textarea.value;
    content = content.replace(/\\n/g, '\n')
      .replace(/<br\s*\/?>/gi, '\n')
      .replace(/<\/?[^>]+(>|$)/g, '')
      .replace(/\[quote="[^"]*"\][\s\S]*?\[\/quote\]/g, '')
      .replace(/<blockquote[^>]*>[\s\S]*?<\/blockquote>/gi, '')
      .replace(/\n{3,}/g, '\n\n');
    content = removeLegacyQuoteBlocks(content);
    return content.trim();
  }

  function buildPlainQuote(authorName, quoteText) {
    const preparedText = quoteText.split('\n').map(line => line.trimEnd()).join('\n').replace(/\n{3,}/g, '\n\n').trim();
    return `Цитата от ${authorName}:\n«${preparedText}»\n\n`;
  }

  function addQuoteToForm(authorName, cleanText) {
    const replyField = document.getElementById('reply-content');
    const quotePreview = document.getElementById('quote-preview');
    const quoteAuthorSpan = document.getElementById('quote-author');
    const quoteContentDiv = document.getElementById('quote-content');
    if (!replyField) return;

    const maxLength = 500;
    let shortContent = cleanText;
    if (cleanText.length > maxLength) shortContent = `${cleanText.substring(0, maxLength)}...`;

    currentQuote = { author: authorName, content: shortContent, fullContent: cleanText };
    quoteAuthorSpan.textContent = authorName;
    quoteContentDiv.textContent = shortContent;
    quotePreview.style.display = 'block';
    replyField.scrollIntoView({ behavior: 'smooth', block: 'center' });
    replyField.focus();
  }

  window.removeQuote = function() {
    const quotePreview = document.getElementById('quote-preview');
    currentQuote = null;
    if (quotePreview) quotePreview.style.display = 'none';
  };

  document.querySelectorAll('.quote-btn').forEach((btn) => {
    btn.addEventListener('click', function() {
      const postId = this.dataset.postId;
      const authorName = this.dataset.author;
      const cleanText = getCleanPostContent(postId);
      if (!cleanText) return;
      addQuoteToForm(authorName, cleanText);

      const postCard = document.getElementById(`post-${postId}`);
      if (postCard) {
        postCard.style.transition = 'all 0.3s';
        postCard.style.backgroundColor = 'rgba(251, 191, 36, 0.15)';
        postCard.style.borderLeft = '4px solid #fbbf24';
        setTimeout(() => {
          postCard.style.backgroundColor = '';
          postCard.style.borderLeft = '';
        }, 2000);
      }
    });
  });

  const replyForm = document.getElementById('reply-form');
  if (replyForm) {
    replyForm.addEventListener('submit', function() {
      const replyField = document.getElementById('reply-content');
      if (replyField && currentQuote) {
        const plainQuote = buildPlainQuote(currentQuote.author, currentQuote.fullContent);
        if (replyField.value.trim() === '') replyField.value = plainQuote;
        else replyField.value = `${plainQuote}${replyField.value}`;
      }
    });
  }
</script>

<style>
