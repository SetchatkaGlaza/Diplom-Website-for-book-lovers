  .post-footer {
    display: flex;
    gap: 0.9rem;
    justify-content: flex-end;
    align-items: center;
    border-top: 1px solid rgba(255, 255, 255, 0.1);
    padding-top: 1rem;
    flex-wrap: wrap;
  }
  .action-btn {
    padding: 0.5rem 1rem;
    border-radius: 30px;
    border: none;
    cursor: pointer;
    font-size: 0.9rem;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.45rem;
    transition: all 0.3s;
    background: rgba(255, 255, 255, 0.05);
    color: #fff;
    line-height: 1;
  }
  .like-btn {
    background: rgba(239, 68, 68, 0.1);
    color: #ef4444;
    border: 1px solid rgba(239, 68, 68, 0.3);
    min-width: 5.9rem;
  }
  .like-btn i {
