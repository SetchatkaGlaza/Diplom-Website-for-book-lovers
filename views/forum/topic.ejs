<div class="forum-topic">
  <!-- Хлебные крошки -->
  <div class="topic-breadcrumbs">
    <a href="/forum">Форум</a>
    <i class="fas fa-chevron-right"></i>
    <a href="/forum/category/<%= topic.category.id %>"><%= topic.category.name %></a>
    <i class="fas fa-chevron-right"></i>
    <span><%= topic.title.length > 50 ? topic.title.substring(0, 50) + '...' : topic.title %></span>
  </div>
  
  <!-- Заголовок темы -->
  <div class="topic-header">
    <h1 class="topic-title"><%= topic.title %></h1>
    
    <div class="topic-info">
      <div class="topic-author">
        <img src="/images/avatars/<%= topic.user.avatar %>" alt="<%= topic.user.name %>" class="topic-author-avatar">
        <div class="topic-author-details">
          <a href="/profile/<%= topic.user.id %>" class="topic-author-name"><%= topic.user.name %></a>
          <span class="topic-author-role">
            <%= topic.user.role === 'admin' ? 'Администратор' : 
                topic.user.role === 'moderator' ? 'Модератор' : 'Участник' %>
          </span>
        </div>
      </div>
      
      <div class="topic-stats">
        <div class="stat-item" title="Просмотры">
          <i class="fas fa-eye"></i>
          <span><%= topic.views %></span>
        </div>
        <div class="stat-item" title="Ответы">
          <i class="fas fa-reply"></i>
          <span><%= totalPosts %></span>
        </div>
        <div class="stat-item" title="Создана">
          <i class="fas fa-clock"></i>
          <span><%= new Date(topic.createdAt).toLocaleDateString('ru-RU') %></span>
        </div>
      </div>
      
      <% if (user) { %>
        <button class="subscribe-btn <%= isSubscribed ? 'subscribed' : '' %>" id="subscribeBtn" data-topic-id="<%= topic.id %>">
          <i class="fas <%= isSubscribed ? 'fa-bell' : 'fa-bell-slash' %>"></i>
          <span><%= isSubscribed ? 'Вы подписаны' : 'Подписаться' %></span>
        </button>
      <% } %>
    </div>
  </div>
  
  <!-- СПИСОК СООБЩЕНИЙ -->
  <div class="posts-list">
    <% posts.forEach((post, index) => { %>
      <div class="post-card" id="post-<%= post.id %>" data-post-id="<%= post.id %>">
        <!-- Левая колонка с информацией о пользователе -->
        <div class="post-sidebar">
          <img src="/images/avatars/<%= post.user.avatar %>" alt="<%= post.user.name %>" class="post-avatar">
          
          <div class="post-author-info">
            <a href="/profile/<%= post.user.id %>" class="post-author-name"><%= post.user.name %></a>
            <span class="post-author-role">
              <%= post.user.role === 'admin' ? 'Администратор' : 
                  post.user.role === 'moderator' ? 'Модератор' : 'Участник' %>
            </span>
          </div>
          
          <div class="post-date">
            <div><i class="far fa-calendar-alt"></i> <%= new Date(post.createdAt).toLocaleDateString('ru-RU') %></div>
            <div><i class="far fa-clock"></i> <%= new Date(post.createdAt).toLocaleTimeString('ru-RU', { hour: '2-digit', minute: '2-digit' }) %></div>
          </div>
          
          <% if (post.user_id === topic.user_id && index === 0) { %>
            <div class="post-badge author-badge">Автор темы</div>
          <% } %>
        </div>
        
        <!-- Правая колонка с содержимым -->
        <div class="post-main">
          <div class="post-content">
            <%= post.content.replace(/\n/g, '<br>') %>
          </div>
          
          <div class="post-footer">
            <button class="action-btn like-btn <%= userLikes.includes(post.id) ? 'liked' : '' %>" 
                    data-post-id="<%= post.id %>"
                    <%= !user ? 'disabled' : '' %>>
              <i class="fas fa-heart"></i>
              <span class="likes-count"><%= post.likes_count %></span>
            </button>
            
            <% if (user) { %>
              <button class="action-btn quote-btn" onclick="quotePost(<%= post.id %>, '<%= post.user.name %>')">
                <i class="fas fa-quote-right"></i>
              </button>
            <% } %>
          </div>
        </div>
      </div>
    <% }) %>
  </div>
  
  <!-- Пагинация -->
  <% if (totalPages > 1) { %>
    <div class="pagination">
      <% if (currentPage > 1) { %>
        <a href="?page=<%= currentPage - 1 %>" class="page-link">
          <i class="fas fa-chevron-left"></i>
        </a>
      <% } %>
      
      <% for(let i = 1; i <= totalPages; i++) { %>
        <% if (i === currentPage) { %>
          <span class="page-link active"><%= i %></span>
        <% } else { %>
          <a href="?page=<%= i %>" class="page-link"><%= i %></a>
        <% } %>
      <% } %>
      
      <% if (currentPage < totalPages) { %>
        <a href="?page=<%= currentPage + 1 %>" class="page-link">
          <i class="fas fa-chevron-right"></i>
        </a>
      <% } %>
    </div>
  <% } %>
  
  <!-- Форма ответа -->
  <% if (user) { %>
    <div class="reply-section">
      <h3 class="reply-title">
        <i class="fas fa-reply"></i>
        Ответить в тему
      </h3>
      
      <form action="/forum/topic/<%= topic.id %>/reply" method="POST" class="reply-form">
        <textarea 
          id="reply-content" 
          name="content" 
          rows="6" 
          placeholder="Напишите ваш ответ..."
          required
        ></textarea>
        
        <div class="reply-actions">
          <button type="submit" class="submit-btn">
            <i class="fas fa-paper-plane"></i>
            Отправить ответ
          </button>
        </div>
      </form>
    </div>
  <% } else { %>
    <div class="login-prompt">
      <i class="fas fa-lock"></i>
      <p><a href="/auth/login">Войдите</a>, чтобы отвечать в темах</p>
    </div>
  <% } %>
</div>

<script>
  // Подписка на тему
  document.getElementById('subscribeBtn')?.addEventListener('click', async function() {
    const topicId = this.dataset.topicId;
    
    try {
      const response = await fetch(`/forum/topic/${topicId}/subscribe`, {
        method: 'POST'
      });
      
      if (response.ok) {
        const data = await response.json();
        const icon = this.querySelector('i');
        const text = this.querySelector('span');
        
        if (data.action === 'subscribed') {
          icon.className = 'fas fa-bell';
          text.textContent = 'Вы подписаны';
          this.classList.add('subscribed');
        } else {
          icon.className = 'fas fa-bell-slash';
          text.textContent = 'Подписаться';
          this.classList.remove('subscribed');
        }
      }
    } catch (error) {
      console.error('Ошибка:', error);
    }
  });
  
  // ЛАЙКИ - ИСПРАВЛЕННАЯ ВЕРСИЯ
  document.querySelectorAll('.like-btn').forEach(btn => {
    btn.addEventListener('click', async function(e) {
      e.preventDefault();
      
      if (this.disabled) return;
      
      const postId = this.dataset.postId;
      const likesCountSpan = this.querySelector('.likes-count');
      const currentCount = parseInt(likesCountSpan.textContent);
      
      // Блокируем кнопку на время запроса
      this.disabled = true;
      
      try {
        const response = await fetch(`/forum/post/${postId}/like`, {
          method: 'POST',
          headers: {
            'Content-Type': 'application/json'
          }
        });
        
        if (response.ok) {
          const data = await response.json();
          
          if (data.success) {
            // Обновляем количество лайков
            likesCountSpan.textContent = data.likesCount;
            
            // Обновляем класс кнопки
            if (data.action === 'liked') {
              this.classList.add('liked');
            } else {
              this.classList.remove('liked');
            }
          }
        }
      } catch (error) {
        console.error('Ошибка:', error);
      } finally {
        // Разблокируем кнопку
        this.disabled = false;
      }
    });
  });
  
  // ЦИТИРОВАНИЕ ЛЮБОГО СООБЩЕНИЯ
  function quotePost(postId, authorName) {
    const postElement = document.getElementById(`post-${postId}`);
    if (!postElement) return;
    
    // Находим текст сообщения
    const postBody = postElement.querySelector('.post-content');
    if (!postBody) return;
    
    const postContent = postBody.innerText.trim();
    
    // Находим поле для ответа
    const replyField = document.getElementById('reply-content');
    if (!replyField) return;
    
    // Добавляем цитату в поле ответа
    const quoteText = `[quote="${authorName}"]\n${postContent}\n[/quote]\n\n`;
    
    // Вставляем в начало или добавляем к существующему тексту
    if (replyField.value.trim() === '') {
      replyField.value = quoteText;
    } else {
      replyField.value = replyField.value + '\n' + quoteText;
    }
    
    // Прокручиваем к полю ответа и фокусируемся
    replyField.scrollIntoView({ behavior: 'smooth' });
    replyField.focus();
    
    // Подсвечиваем цитируемое сообщение
    postElement.style.transition = 'all 0.3s';
    postElement.style.backgroundColor = 'rgba(251, 191, 36, 0.2)';
    postElement.style.borderLeft = '4px solid #fbbf24';
    
    setTimeout(() => {
      postElement.style.backgroundColor = '';
      postElement.style.borderLeft = '';
    }, 2000);
  }
</script>

