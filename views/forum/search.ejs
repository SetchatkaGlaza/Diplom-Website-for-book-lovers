<div class="forum-search">
  <div class="page-header">
    <h1><i class="fas fa-search"></i> Поиск по форуму</h1>
    <a href="/forum" class="btn btn-outline">
      <i class="fas fa-arrow-left"></i> Вернуться к форуму
    </a>
  </div>
  

  <% if (locals.errors && errors.length > 0) { %>
    <div class="alert alert-danger">
      <i class="fas fa-exclamation-circle"></i>
      <ul>
        <% errors.forEach(error => { %>
          <li><%= error.msg %></li>
        <% }) %>
      </ul>
    </div>
  <% } %>

  <form action="/forum/search" method="GET" class="search-form">
    <div class="search-input-group">
      <input 
        type="text" 
        name="q" 
        placeholder="Введите поисковый запрос..." 
        value="<%= query || '' %>"
        required
        minlength="3"
      >
      <button type="submit" class="btn btn-primary">
        <i class="fas fa-search"></i> Найти
      </button>
    </div>
    <small>Минимум 3 символа</small>
    <span class="search-help">Поиск проверяет названия и тексты тем, а также сообщения форума. Используйте короткие ключевые слова.</span>
  </form>
  
  <% if (query) { %>
    <div class="search-results">
      <h2>Результаты поиска по запросу "<%= query %>"</h2>
      <p class="search-summary">Найдено тем: <strong><%= topics ? topics.length : 0 %></strong>, сообщений: <strong><%= posts ? posts.length : 0 %></strong>.</p>
      
      <% if (topics && topics.length > 0) { %>
        <div class="results-section">
          <h3><i class="fas fa-comments"></i> Найдено тем: <%= topics.length %></h3>
          <div class="results-list">
            <% topics.forEach(topic => { %>
              <div class="result-item">
                <div class="result-icon">
                  <i class="fas fa-comment"></i>
                </div>
                <div class="result-content">
                  <h4><a href="/forum/topic/<%= topic.id %>"><%= topic.title %></a></h4>
                  <p class="result-meta">
                    Категория: <a href="/forum/category/<%= topic.category.id %>"><%= topic.category.name %></a> • 
                    Автор: <a href="/profile/<%= topic.user.id %>"><%= topic.user.name %></a> • 
                    <%= topic.replies_count %> ответов • 
                    <%= topic.views %> просмотров
                  </p>
                  <% const topicPreview = truncateText(topic.content, 240); %>
                  <p class="result-excerpt"><%= topicPreview.text %></p>
                </div>
              </div>
            <% }) %>
          </div>
        </div>
      <% } %>
      
      <% if (posts && posts.length > 0) { %>
        <div class="results-section">
          <h3><i class="fas fa-reply"></i> Найдено сообщений: <%= posts.length %></h3>
          <div class="results-list">
            <% posts.forEach(post => { %>
              <div class="result-item">
                <div class="result-icon">
                  <i class="fas fa-reply"></i>
                </div>
                <div class="result-content">
                  <h4>
                    <a href="/forum/topic/<%= post.topic.id %>#post-<%= post.id %>">
                      Сообщение в теме "<%= post.topic.title %>"
                    </a>
                  </h4>
                  <p class="result-meta">
                    Категория: <a href="/forum/category/<%= post.topic.category.id %>"><%= post.topic.category.name %></a> • 
                    Автор: <a href="/profile/<%= post.user.id %>"><%= post.user.name %></a> • 
                    <%= new Date(post.createdAt).toLocaleString('ru-RU') %>
                  </p>
                  <% const postPreview = truncateText(post.content, 240); %>
                  <p class="result-excerpt"><%= postPreview.text %></p>
                </div>
              </div>
            <% }) %>
          </div>
        </div>
      <% } %>
      
      <% if ((!topics || topics.length === 0) && (!posts || posts.length === 0)) { %>
        <div class="no-results">
          <i class="fas fa-search fa-4x"></i>
          <h3>Ничего не найдено</h3>
          <p>Попробуйте изменить поисковый запрос</p>
        </div>
      <% } %>
    </div>
  <% } %>
</div>

<style>
  .forum-search {
    background: linear-gradient(160deg, rgba(255, 255, 255, 0.16), rgba(255, 255, 255, 0.08));
    backdrop-filter: blur(10px);
    -webkit-backdrop-filter: blur(10px);
    border: 1px solid rgba(255, 255, 255, 0.22);
    border-radius: var(--radius-lg);
    padding: clamp(1rem, 2.5vw, 2rem);
    margin: 2rem 0;
    color: white;
    box-shadow: var(--shadow-lg);
  }

  .page-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 1.5rem;
    flex-wrap: wrap;
    gap: 1rem;
  }

  .page-header h1 {
    margin: 0;
    overflow-wrap: anywhere;
  }

  .search-form {
    max-width: 820px;
    margin: 0 auto 2rem;
    padding: 1rem;
    border-radius: var(--radius-lg);
    background: rgba(15, 23, 42, 0.42);
    border: 1px solid rgba(255, 255, 255, 0.14);
  }

  .search-input-group {
    display: flex;
    gap: 0.75rem;
    margin-bottom: 0.65rem;
  }

  .search-input-group input {
    flex: 1;
    min-width: 0;
    padding: 0.85rem 1rem;
    border: 2px solid rgba(255, 255, 255, 0.22);
    border-radius: var(--radius);
    background: rgba(255, 255, 255, 0.96);
    color: var(--dark);
    font-size: 1rem;
    box-shadow: inset 0 1px 2px rgba(0, 0, 0, 0.08);
  }

  .search-input-group input::placeholder {
    color: #64748b;
  }

  .search-input-group input:focus {
    outline: none;
    border-color: var(--accent);
    box-shadow: 0 0 0 4px rgba(236, 72, 153, 0.2);
  }

  .search-form small,
  .search-help {
    display: block;
    text-align: center;
    color: rgba(255, 255, 255, 0.78);
  }

  .search-help {
    margin-top: 0.4rem;
    font-size: 0.9rem;
  }

  .search-summary {
    margin: 0 0 1.5rem;
    padding: 1rem;
    border-radius: var(--radius);
    background: rgba(236, 72, 153, 0.14);
    border: 1px solid rgba(236, 72, 153, 0.28);
    overflow-wrap: anywhere;
  }

  .search-results {
    margin-top: 2rem;
  }

  .search-results h2 {
    margin-bottom: 1rem;
    padding-bottom: 1rem;
    border-bottom: 1px solid rgba(255, 255, 255, 0.12);
    overflow-wrap: anywhere;
  }

  .results-section {
    margin-bottom: 2rem;
  }

  .results-section h3 {
    margin-bottom: 1rem;
    display: flex;
    align-items: center;
    gap: 0.5rem;
    color: #f9a8d4;
  }

  .result-item {
    display: grid;
    grid-template-columns: 44px minmax(0, 1fr);
    gap: 1rem;
    padding: 1rem;
    background: rgba(15, 23, 42, 0.5);
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: var(--radius);
    margin-bottom: 0.75rem;
    transition: var(--transition);
  }

  .result-item:hover {
    background: rgba(15, 23, 42, 0.68);
    transform: translateY(-2px);
  }

  .result-icon {
    width: 44px;
    height: 44px;
    border-radius: 50%;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    background: rgba(236, 72, 153, 0.16);
    color: #f9a8d4;
    font-size: 1.15rem;
  }

  .result-content {
    min-width: 0;
  }

  .result-content h4 {
    margin: 0 0 0.5rem;
    line-height: 1.35;
  }

  .result-content h4 a {
    color: white;
    text-decoration: none;
    overflow-wrap: anywhere;
  }

  .result-content h4 a:hover {
    color: #f9a8d4;
  }

  .result-meta {
    display: flex;
    flex-wrap: wrap;
    gap: 0.35rem 0.5rem;
    font-size: 0.9rem;
    color: rgba(255, 255, 255, 0.78);
    margin-bottom: 0.5rem;
  }

  .result-meta a {
    color: #f9a8d4;
    text-decoration: none;
  }

  .result-meta a:hover {
    text-decoration: underline;
  }

  .result-excerpt {
    color: rgba(255, 255, 255, 0.82);
    font-size: 0.95rem;
    line-height: 1.6;
    overflow-wrap: anywhere;
  }

  .no-results {
    text-align: center;
    padding: clamp(2rem, 5vw, 3rem);
    background: rgba(15, 23, 42, 0.38);
    border-radius: var(--radius-lg);
    border: 1px dashed rgba(255, 255, 255, 0.2);
  }

  .no-results i {
    opacity: 0.35;
    margin-bottom: 1rem;
  }

  .no-results h3 {
    margin-bottom: 0.5rem;
  }

  @media (max-width: 768px) {
    .forum-search {
      margin: 1rem 0;
    }

    .page-header,
    .search-input-group {
      flex-direction: column;
      align-items: stretch;
    }

    .page-header .btn,
    .search-input-group .btn {
      width: 100%;
      justify-content: center;
    }

    .result-item {
      grid-template-columns: 1fr;
    }

    .result-icon {
      width: 38px;
      height: 38px;
    }
  }
</style>