<div class="appeal-page">
  <div class="appeal-container">
    <!-- Декоративные элементы -->
    <div class="appeal-bg-decoration">
      <div class="decoration-circle circle-1"></div>
      <div class="decoration-circle circle-2"></div>
      <div class="decoration-circle circle-3"></div>
    </div>
    
    <div class="appeal-card">
      <!-- Иконка и заголовок -->
      <div class="appeal-header">
        <div class="appeal-icon-wrapper">
          <div class="appeal-icon">
            <i class="fas fa-gavel"></i>
          </div>
        </div>
        <h1 class="appeal-title">
          Обжалование решения модератора
        </h1>
        <p class="appeal-subtitle">
          Вы можете оспорить удаление сообщения, предоставив объяснение администратору
        </p>
      </div>
      
      <!-- Информация о топике -->
      <div class="info-section">
        <div class="info-row">
          <div class="info-label">
            <i class="fas fa-comment"></i>
            Тема обсуждения
          </div>
          <div class="info-value">
            <a href="/forum/topic/<%= moderationCase.topic_id %>" class="topic-link">
              <%= moderationCase.topic ? moderationCase.topic.title : 'Перейти к топику' %>
              <i class="fas fa-external-link-alt"></i>
            </a>
          </div>
        </div>
        
        <div class="info-row">
          <div class="info-label">
            <i class="fas fa-user-shield"></i>
            Решение модератора
          </div>
          <div class="info-value rejection-reason">
            <i class="fas fa-ban"></i>
            <%= moderationCase.delete_reason %>
          </div>
        </div>
      </div>
      
      <!-- Удалённый текст -->
      <div class="deleted-content-section">
        <div class="section-header">
          <i class="fas fa-trash-alt"></i>
          <h3>Удалённое сообщение</h3>
        </div>
        <div class="deleted-content">
          <%- moderationCase.content
            .replace(/&/g, '&amp;')
            .replace(/</g, '&lt;')
            .replace(/>/g, '&gt;')
            .replace(/\n/g, '<br>') %>
        </div>
      </div>
      
      <!-- Форма обращения -->
      <form action="/forum/post-moderation/<%= moderationCase.id %>/appeal" method="POST" class="appeal-form">
        <div class="form-section">
          <div class="section-header">
            <i class="fas fa-pen-fancy"></i>
            <h3>Ваше объяснение</h3>
          </div>
          
          <div class="form-group">
            <label for="explanation">
              Объясните контекст и причину, почему сообщение стоит восстановить
              <span class="required">*</span>
            </label>
            <textarea 
              id="explanation" 
              name="explanation" 
              rows="8" 
              required 
              placeholder="Напишите, пожалуйста, подробно...&#10;&#10;Например:&#10;• Какой контекст был у сообщения&#10;• Почему вы считаете, что удаление было ошибочным&#10;• Какие правила не были нарушены"
            ><%= moderationCase.user_explanation || '' %></textarea>
            <div class="textarea-hint">
              <i class="fas fa-info-circle"></i>
              Минимум 20 символов. Чем подробнее вы объясните ситуацию, тем быстрее администратор сможет рассмотреть обращение.
            </div>
          </div>
        </div>
        
        <div class="form-actions">
          <button type="submit" class="btn-submit">
            <i class="fas fa-paper-plane"></i>
            <span>Отправить обращение</span>
          </button>
          <a href="/forum/topic/<%= moderationCase.topic_id %>" class="btn-cancel">
            <i class="fas fa-times"></i>
            <span>Отмена</span>
          </a>
        </div>
      </form>
      
      <!-- Информационная панель -->
      <div class="info-panel">
        <div class="info-item">
          <i class="fas fa-clock"></i>
          <div>
            <strong>Что произойдёт дальше?</strong>
            <p>Администратор рассмотрит ваше обращение в течение 24-48 часов и свяжется с вами через уведомления.</p>
          </div>
        </div>
        <div class="info-item">
          <i class="fas fa-shield-alt"></i>
          <div>
            <strong>Правила обжалования</strong>
            <p>Пожалуйста, будьте вежливы и аргументированы. Оскорбления в адрес модераторов недопустимы.</p>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

<style>
  /* ===== ОСНОВНЫЕ СТИЛИ ===== */
  .appeal-page {
    min-height: calc(100vh - 200px);
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 2rem;
    position: relative;
  }
  
  .appeal-container {
    max-width: 900px;
    width: 100%;
    margin: 0 auto;
    position: relative;
  }
  
  /* ===== ДЕКОРАТИВНЫЕ ЭЛЕМЕНТЫ ===== */
  .appeal-bg-decoration {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    overflow: hidden;
    z-index: 0;
    pointer-events: none;
  }
  
  .decoration-circle {
    position: absolute;
    border-radius: 50%;
    background: linear-gradient(135deg, rgba(251, 191, 36, 0.15), rgba(245, 158, 11, 0.05));
    animation: float 20s ease-in-out infinite;
  }
  
  .circle-1 {
    width: 300px;
    height: 300px;
    top: -100px;
    right: -100px;
    animation-delay: 0s;
  }
  
  .circle-2 {
    width: 200px;
    height: 200px;
    bottom: -50px;
    left: -80px;
    animation-delay: 5s;
  }
  
  .circle-3 {
    width: 150px;
    height: 150px;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    animation-delay: 10s;
  }
  
  @keyframes float {
    0%, 100% { transform: translateY(0) scale(1); }
    50% { transform: translateY(-20px) scale(1.05); }
  }
  
  /* ===== КАРТОЧКА ===== */
  .appeal-card {
    position: relative;
    z-index: 1;
    background: linear-gradient(145deg, rgba(25, 25, 35, 0.95), rgba(15, 15, 25, 0.98));
    backdrop-filter: blur(10px);
    -webkit-backdrop-filter: blur(10px);
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: 32px;
    padding: 2.5rem;
    box-shadow: 0 30px 60px rgba(0, 0, 0, 0.5), 0 0 0 1px rgba(251, 191, 36, 0.1);
    transition: all 0.3s ease;
  }
  
  .appeal-card:hover {
    box-shadow: 0 35px 70px rgba(0, 0, 0, 0.6), 0 0 0 2px rgba(251, 191, 36, 0.2);
    transform: translateY(-5px);
  }
  
  /* ===== ЗАГОЛОВОК ===== */
  .appeal-header {
    text-align: center;
    margin-bottom: 2.5rem;
  }
  
  .appeal-icon-wrapper {
    display: flex;
    justify-content: center;
    margin-bottom: 1.5rem;
  }
  
  .appeal-icon {
    width: 80px;
    height: 80px;
    background: linear-gradient(135deg, #fbbf24, #f59e0b);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 2.5rem;
    color: #000;
    box-shadow: 0 10px 30px rgba(251, 191, 36, 0.4);
    animation: pulse 2s ease-in-out infinite;
  }
  
  @keyframes pulse {
    0%, 100% { transform: scale(1); box-shadow: 0 10px 30px rgba(251, 191, 36, 0.4); }
    50% { transform: scale(1.05); box-shadow: 0 15px 40px rgba(251, 191, 36, 0.6); }
  }
  
  .appeal-title {
    font-size: 2rem;
    font-weight: 700;
    margin: 0 0 0.5rem;
    background: linear-gradient(135deg, #fff, #fbbf24);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
  }
  
  .appeal-subtitle {
    font-size: 1rem;
    color: rgba(255, 255, 255, 0.7);
    margin: 0;
  }
  
  /* ===== ИНФОРМАЦИОННАЯ СЕКЦИЯ ===== */
  .info-section {
    background: rgba(0, 0, 0, 0.3);
    border-radius: 20px;
    padding: 1.5rem;
    margin-bottom: 2rem;
    border: 1px solid rgba(255, 255, 255, 0.05);
  }
  
  .info-row {
    display: flex;
    align-items: center;
    padding: 0.75rem 0;
    border-bottom: 1px solid rgba(255, 255, 255, 0.05);
  }
  
  .info-row:last-child {
    border-bottom: none;
  }
  
  .info-label {
    width: 160px;
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-weight: 600;
    color: rgba(255, 255, 255, 0.8);
  }
  
  .info-label i {
    color: #fbbf24;
    width: 20px;
  }
  
  .info-value {
    flex: 1;
    color: white;
  }
  
  .topic-link {
    color: #fbbf24;
    text-decoration: none;
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    transition: all 0.3s;
  }
  
  .topic-link:hover {
    gap: 0.75rem;
    text-decoration: underline;
  }
  
  .rejection-reason {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    background: rgba(239, 68, 68, 0.15);
    padding: 0.5rem 1rem;
    border-radius: 12px;
    color: #f87171;
    font-weight: 500;
  }
  
  .rejection-reason i {
    color: #ef4444;
  }
  
  /* ===== УДАЛЁННОЕ СООБЩЕНИЕ ===== */
  .deleted-content-section {
    margin-bottom: 2rem;
  }
  
  .section-header {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin-bottom: 1rem;
    padding-bottom: 0.5rem;
    border-bottom: 2px solid rgba(251, 191, 36, 0.3);
  }
  
  .section-header i {
    font-size: 1.2rem;
    color: #fbbf24;
  }
  
  .section-header h3 {
    margin: 0;
    font-size: 1.2rem;
    font-weight: 600;
    color: white;
  }
  
  .deleted-content {
    background: rgba(0, 0, 0, 0.4);
    border: 1px solid rgba(239, 68, 68, 0.3);
    border-radius: 16px;
    padding: 1.5rem;
    line-height: 1.8;
    color: rgba(255, 255, 255, 0.9);
    white-space: pre-wrap;
    word-wrap: break-word;
    font-size: 0.95rem;
    max-height: 300px;
    overflow-y: auto;
  }
  
  .deleted-content::before {
    content: '⚠️ Удалённый текст:';
    display: block;
    color: #ef4444;
    font-size: 0.8rem;
    margin-bottom: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 1px;
  }
  
  /* ===== ФОРМА ===== */
  .appeal-form {
    margin-bottom: 2rem;
  }
  
  .form-section {
    margin-bottom: 2rem;
  }
  
  .form-group {
    margin-top: 1rem;
  }
  
  .form-group label {
    display: block;
    margin-bottom: 0.75rem;
    font-weight: 500;
    color: rgba(255, 255, 255, 0.9);
  }
  
  .required {
    color: #ef4444;
    margin-left: 0.25rem;
  }
  
  .form-group textarea {
    width: 100%;
    padding: 1rem;
    border: 2px solid rgba(255, 255, 255, 0.1);
    border-radius: 16px;
    background: rgba(0, 0, 0, 0.3);
    color: white;
    font-size: 1rem;
    line-height: 1.7;
    resize: vertical;
    transition: all 0.3s;
    font-family: inherit;
  }
  
  .form-group textarea:focus {
    outline: none;
    border-color: #fbbf24;
    background: rgba(0, 0, 0, 0.5);
    box-shadow: 0 0 0 3px rgba(251, 191, 36, 0.2);
  }
  
  .form-group textarea::placeholder {
    color: rgba(255, 255, 255, 0.4);
    font-style: italic;
  }
  
  .textarea-hint {
    margin-top: 0.5rem;
    font-size: 0.85rem;
    color: rgba(255, 255, 255, 0.6);
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }
  
  .textarea-hint i {
    color: #fbbf24;
  }
  
  /* ===== КНОПКИ ===== */
  .form-actions {
    display: flex;
    gap: 1rem;
    justify-content: center;
    margin-top: 2rem;
  }
  
  .btn-submit {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.75rem;
    padding: 1rem 2rem;
    background: linear-gradient(135deg, #fbbf24, #f59e0b);
    border: none;
    border-radius: 50px;
    color: #000;
    font-size: 1rem;
    font-weight: 600;
    cursor: pointer;
    transition: all 0.3s;
    box-shadow: 0 5px 15px rgba(251, 191, 36, 0.3);
  }
  
  .btn-submit:hover {
    transform: translateY(-3px);
    box-shadow: 0 8px 25px rgba(251, 191, 36, 0.5);
  }
  
  .btn-submit i {
    font-size: 1.1rem;
  }
  
  .btn-cancel {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.75rem;
    padding: 1rem 2rem;
    background: rgba(255, 255, 255, 0.05);
    border: 1px solid rgba(255, 255, 255, 0.2);
    border-radius: 50px;
    color: white;
    font-size: 1rem;
    font-weight: 500;
    text-decoration: none;
    transition: all 0.3s;
  }
  
  .btn-cancel:hover {
    background: rgba(239, 68, 68, 0.2);
    border-color: #ef4444;
    transform: translateY(-3px);
  }
  
  /* ===== ИНФОРМАЦИОННАЯ ПАНЕЛЬ ===== */
  .info-panel {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1rem;
    margin-top: 2rem;
    padding-top: 1.5rem;
    border-top: 1px solid rgba(255, 255, 255, 0.1);
  }
  
  .info-item {
    display: flex;
    gap: 1rem;
    padding: 1rem;
    background: rgba(0, 0, 0, 0.2);
    border-radius: 16px;
    transition: all 0.3s;
  }
  
  .info-item:hover {
    background: rgba(0, 0, 0, 0.3);
    transform: translateY(-3px);
  }
  
  .info-item i {
    font-size: 1.5rem;
    color: #fbbf24;
  }
  
  .info-item strong {
    display: block;
    margin-bottom: 0.25rem;
    font-size: 0.9rem;
  }
  
  .info-item p {
    margin: 0;
    font-size: 0.85rem;
    color: rgba(255, 255, 255, 0.7);
    line-height: 1.5;
  }
  
  /* ===== АДАПТИВНОСТЬ ===== */
  @media (max-width: 768px) {
    .appeal-page {
      padding: 1rem;
    }
    
    .appeal-card {
      padding: 1.5rem;
    }
    
    .appeal-title {
      font-size: 1.5rem;
    }
    
    .info-row {
      flex-direction: column;
      align-items: flex-start;
      gap: 0.5rem;
    }
    
    .info-label {
      width: 100%;
    }
    
    .form-actions {
      flex-direction: column;
    }
    
    .btn-submit,
    .btn-cancel {
      width: 100%;
    }
    
    .info-panel {
      grid-template-columns: 1fr;
    }
  }
  
  @media (max-width: 480px) {
    .appeal-icon {
      width: 60px;
      height: 60px;
      font-size: 1.8rem;
    }
    
    .appeal-title {
      font-size: 1.2rem;
    }
    
    .appeal-subtitle {
      font-size: 0.85rem;
    }
  }
</style>
