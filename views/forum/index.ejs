

<div class="forum-main">
  <!-- Заголовок форума -->
  <div class="forum-hero">
    <div class="forum-hero-content">
      <h1 class="forum-title">
        <i class="fas fa-comments"></i>
        Форум читателей
      </h1>
      <p class="forum-description">
        Обсуждайте книги, делитесь впечатлениями, находите единомышленников и открывайте новые миры вместе с нами!
      </p>
      
      <div class="forum-stats-badges">
        <div class="stat-badge">
          <i class="fas fa-folder"></i>
          <span><%= categories ? categories.length : 0 %> категорий</span>
        </div>
        <div class="stat-badge">
          <i class="fas fa-comment"></i>
          <span><%= activeTopics ? activeTopics.length : 0 %> активных тем</span>
        </div>
      </div>
      
      <div class="forum-actions">
        <a href="/forum/search" class="btn btn-outline">
          <i class="fas fa-search"></i>
          Поиск по форуму
        </a>
        <% if (user) { %>
          <a href="/forum/new" class="btn btn-primary">
            <i class="fas fa-plus"></i>
            Создать тему
          </a>
        <% } %>
      </div>
    </div>
  </div>
  
  <!-- Категории форума -->
  <div class="categories-section">
    <h2 class="section-title">
      <i class="fas fa-folder"></i>
      Категории форума
    </h2>
    
    <div class="categories-grid">
      <% if (categories && categories.length > 0) { %>
        <% categories.forEach(category => { %>
          <div class="category-card">
            <div class="category-card-header">
              <div class="category-icon">
                <i class="fas <%= category.icon || 'fa-folder' %>"></i>
              </div>
              <h3 class="category-name">
                <a href="/forum/category/<%= category.id %>"><%= category.name %></a>
              </h3>
            </div>
            
            <% if (category.description) { %>
              <p class="category-description"><%= category.description %></p>
            <% } %>
            
            <div class="category-stats">
              <div class="category-stat">
                <i class="fas fa-comment"></i>
                <span><%= category.topicsCount || 0 %> тем</span>
              </div>
              <div class="category-stat">
                <i class="fas fa-reply"></i>
                <span><%= category.postsCount || 0 %> сообщений</span>
              </div>
            </div>
            
            <% if (category.topics && category.topics.length > 0) { %>
              <div class="recent-topics">
                <h4>Последние темы:</h4>
                <ul class="recent-topics-list">
                  <% category.topics.slice(0, 3).forEach(topic => { %>
                    <li>
                      <a href="/forum/topic/<%= topic.id %>" class="recent-topic-link">
                        <%= topic.title && topic.title.length > 40 ? topic.title.substring(0, 40) + '...' : (topic.title || 'Без названия') %>
                      </a>
                      <span class="recent-topic-meta">
                        от <a href="/profile/<%= topic.user ? topic.user.id : '#' %>">
                          <%= topic.user ? topic.user.name : 'Пользователь' %>
                        </a>
                      </span>
                    </li>
                  <% }) %>
                </ul>
              </div>
            <% } %>
            
            <a href="/forum/category/<%= category.id %>" class="category-link">
              Перейти в категорию <i class="fas fa-arrow-right"></i>
            </a>
          </div>
        <% }) %>
      <% } else { %>
        <div class="empty-categories">
          <p>Категории форума пока не созданы</p>
        </div>
      <% } %>
    </div>
  </div>
  
  <!-- Активные темы -->
  <% if (activeTopics && activeTopics.length > 0) { %>
    <div class="active-topics-section">
      <h2 class="section-title">
        <i class="fas fa-fire"></i>
        Активные обсуждения
      </h2>
      
      <div class="active-topics-list">
        <% activeTopics.forEach(topic => { %>
          <div class="active-topic-card">
            <div class="active-topic-icon">
              <i class="fas fa-comment-dots"></i>
            </div>
            
            <div class="active-topic-content">
              <h3 class="active-topic-title">
                <a href="/forum/topic/<%= topic.id %>"><%= topic.title || 'Без названия' %></a>
              </h3>
              
              <div class="active-topic-meta">
                <% if (topic.category) { %>
                  <span class="topic-category">
                    <i class="fas fa-folder"></i>
                    <a href="/forum/category/<%= topic.category.id %>"><%= topic.category.name %></a>
                  </span>
                <% } %>
                
                <span class="topic-author">
                  <i class="fas fa-user"></i>
                  <a href="/profile/<%= topic.user ? topic.user.id : '#' %>">
                    <%= topic.user ? topic.user.name : 'Пользователь' %>
                  </a>
                </span>
                
                <span class="topic-stats">
                  <i class="fas fa-eye"></i> <%= topic.views || 0 %>
                  <i class="fas fa-reply"></i> <%= topic.replies_count || 0 %>
                </span>
                
                <span class="topic-last-reply">
                  <i class="fas fa-clock"></i>
                  <%= topic.last_reply_at ? new Date(topic.last_reply_at).toLocaleString('ru-RU', { 
                    day: 'numeric', 
                    month: 'short', 
                    hour: '2-digit', 
                    minute: '2-digit' 
                  }) : 'Нет ответов' %>
                </span>
              </div>
            </div>
          </div>
        <% }) %>
      </div>
    </div>
  <% } %>
  
  <!-- Информация о форуме -->
  <div class="forum-info-section">
    <div class="info-cards">
      <div class="info-card">
        <i class="fas fa-users"></i>
        <div>
          <h3>Активное сообщество</h3>
          <p>Тысячи читателей обсуждают любимые книги</p>
        </div>
      </div>
      
      <div class="info-card">
        <i class="fas fa-star"></i>
        <div>
          <h3>Рецензии и отзывы</h3>
          <p>Делитесь мнениями и находите новые книги</p>
        </div>
      </div>
      
      <div class="info-card">
        <i class="fas fa-shield-alt"></i>
        <div>
          <h3>Модерация</h3>
          <p>Темы проходят проверку перед публикацией</p>
        </div>
      </div>
    </div>
  </div>
</div>

<style>
  /* ===== ОСНОВНЫЕ СТИЛИ ===== */
  .forum-main {
    background: linear-gradient(145deg, rgba(30, 30, 40, 0.9), rgba(20, 20, 30, 0.95));
    backdrop-filter: blur(10px);
    -webkit-backdrop-filter: blur(10px);
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: 32px;
    padding: 2.5rem;
    margin: 2rem 0;
    color: #fff;
    box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.5);
  }
  
  /* ===== ГЕРОЙ ФОРУМА ===== */
  .forum-hero {
    background: linear-gradient(135deg, rgba(251, 191, 36, 0.2), rgba(245, 158, 11, 0.1));
    border-radius: 24px;
    padding: 3rem 2rem;
    margin-bottom: 3rem;
    text-align: center;
    border: 1px solid rgba(251, 191, 36, 0.3);
    position: relative;
    overflow: hidden;
  }
  
  .forum-hero::before {
    content: '';
    position: absolute;
    top: -50%;
    right: -50%;
    width: 200%;
    height: 200%;
    background: radial-gradient(circle, rgba(251, 191, 36, 0.1) 0%, transparent 50%);
    animation: rotate 20s linear infinite;
  }
  
  @keyframes rotate {
    from { transform: rotate(0deg); }
    to { transform: rotate(360deg); }
  }
  
  .forum-hero-content {
    position: relative;
    z-index: 1;
  }
  
  .forum-title {
    font-size: 3rem;
    margin: 0 0 1rem;
    background: linear-gradient(135deg, #fff, #fbbf24);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 1rem;
  }
  
  .forum-title i {
    background: linear-gradient(135deg, #fbbf24, #f59e0b);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    font-size: 3rem;
  }
  
  .forum-description {
    font-size: 1.2rem;
    color: rgba(255, 255, 255, 0.9);
    max-width: 700px;
    margin: 0 auto 2rem;
    line-height: 1.8;
  }
  
  .forum-stats-badges {
    display: flex;
    justify-content: center;
    gap: 1rem;
    margin-bottom: 2rem;
    flex-wrap: wrap;
  }
  
  .stat-badge {
    background: rgba(0, 0, 0, 0.3);
    border: 1px solid rgba(251, 191, 36, 0.3);
    border-radius: 50px;
    padding: 0.75rem 1.5rem;
    display: flex;
    align-items: center;
    gap: 0.75rem;
    font-size: 1rem;
    backdrop-filter: blur(5px);
  }
  
  .stat-badge i {
    color: #fbbf24;
    font-size: 1.2rem;
  }
  
  .forum-actions {
    display: flex;
    justify-content: center;
    gap: 1rem;
    flex-wrap: wrap;
  }
  
  .btn {
    padding: 0.9rem 2rem;
    border-radius: 50px;
    font-size: 1rem;
    font-weight: 600;
    text-decoration: none;
    transition: all 0.3s;
    display: inline-flex;
    align-items: center;
    gap: 0.75rem;
    border: none;
    cursor: pointer;
  }
  
  .btn-primary {
    background: linear-gradient(135deg, #fbbf24, #f59e0b);
    color: #000;
    box-shadow: 0 5px 15px rgba(251, 191, 36, 0.3);
  }
  
  .btn-primary:hover {
    transform: translateY(-3px);
    box-shadow: 0 8px 25px rgba(251, 191, 36, 0.5);
  }
  
  .btn-outline {
    background: rgba(255, 255, 255, 0.05);
    color: #fff;
    border: 1px solid rgba(255, 255, 255, 0.2);
  }
  
  .btn-outline:hover {
    background: rgba(251, 191, 36, 0.1);
    border-color: #fbbf24;
    transform: translateY(-3px);
  }
  
  /* ===== ЗАГОЛОВКИ СЕКЦИЙ ===== */
  .section-title {
    font-size: 2rem;
    margin: 0 0 2rem;
    display: flex;
    align-items: center;
    gap: 1rem;
    color: #fbbf24;
    padding-bottom: 0.75rem;
    border-bottom: 3px solid rgba(251, 191, 36, 0.3);
  }
  
  .section-title i {
    font-size: 1.8rem;
  }
  
  /* ===== СЕТКА КАТЕГОРИЙ ===== */
  .categories-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(350px, 1fr));
    gap: 1.5rem;
    margin-bottom: 3rem;
  }
  
  .category-card {
    background: rgba(0, 0, 0, 0.25);
    border-radius: 20px;
    padding: 1.5rem;
    transition: all 0.3s;
    border: 1px solid rgba(255, 255, 255, 0.05);
    display: flex;
    flex-direction: column;
    height: 100%;
  }
  
  .category-card:hover {
    transform: translateY(-5px);
    background: rgba(0, 0, 0, 0.35);
    border-color: rgba(251, 191, 36, 0.3);
    box-shadow: 0 10px 30px rgba(0, 0, 0, 0.3);
  }
  
  .category-card-header {
    display: flex;
    align-items: center;
    gap: 1rem;
    margin-bottom: 1rem;
  }
  
  .category-icon {
    width: 50px;
    height: 50px;
    border-radius: 16px;
    background: linear-gradient(135deg, #fbbf24, #f59e0b);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1.5rem;
    color: #000;
    flex-shrink: 0;
  }
  
  .category-name {
    margin: 0;
    font-size: 1.3rem;
    word-wrap: break-word;
    overflow-wrap: break-word;
  }
  
  .category-name a {
    color: #fff;
    text-decoration: none;
    transition: color 0.3s;
  }
  
  .category-name a:hover {
    color: #fbbf24;
  }
  
  .category-description {
    color: rgba(255, 255, 255, 0.7);
    line-height: 1.6;
    margin: 0 0 1rem;
    font-size: 0.95rem;
  }
  
  .category-stats {
    display: flex;
    gap: 1rem;
    margin-bottom: 1rem;
    flex-wrap: wrap;
  }
  
  .category-stat {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.9rem;
    color: rgba(255, 255, 255, 0.8);
    background: rgba(0, 0, 0, 0.2);
    padding: 0.4rem 1rem;
    border-radius: 30px;
  }
  
  .category-stat i {
    color: #fbbf24;
  }
  
  .recent-topics {
    margin: 1rem 0;
    padding: 1rem 0;
    border-top: 1px solid rgba(255, 255, 255, 0.1);
    border-bottom: 1px solid rgba(255, 255, 255, 0.1);
  }
  
  .recent-topics h4 {
    font-size: 0.9rem;
    color: rgba(255, 255, 255, 0.6);
    margin: 0 0 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.5px;
  }
  
  .recent-topics-list {
    list-style: none;
    padding: 0;
    margin: 0;
  }
  
  .recent-topics-list li {
    margin-bottom: 0.5rem;
    line-height: 1.4;
  }
  
  .recent-topic-link {
    color: #fff;
    text-decoration: none;
    font-size: 0.95rem;
    transition: color 0.3s;
    display: block;
    word-wrap: break-word;
    overflow-wrap: break-word;
  }
  
  .recent-topic-link:hover {
    color: #fbbf24;
  }
  
  .recent-topic-meta {
    font-size: 0.8rem;
    color: rgba(255, 255, 255, 0.5);
    display: block;
    margin-top: 0.2rem;
  }
  
  .recent-topic-meta a {
    color: rgba(255, 255, 255, 0.7);
    text-decoration: none;
  }
  
  .recent-topic-meta a:hover {
    color: #fbbf24;
  }
  
  .category-link {
    margin-top: auto;
    color: #fbbf24;
    text-decoration: none;
    font-size: 0.95rem;
    display: flex;
    align-items: center;
    gap: 0.5rem;
    transition: all 0.3s;
    padding: 0.5rem 0;
  }
  
  .category-link:hover {
    gap: 0.8rem;
  }
  
  .empty-categories {
    grid-column: 1 / -1;
    text-align: center;
    padding: 3rem;
    background: rgba(0, 0, 0, 0.2);
    border-radius: 16px;
    color: rgba(255, 255, 255, 0.7);
  }
  
  /* ===== АКТИВНЫЕ ТЕМЫ ===== */
  .active-topics-section {
    margin-bottom: 3rem;
  }
  
  .active-topics-list {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }
  
  .active-topic-card {
    display: flex;
    align-items: center;
    gap: 1.5rem;
    padding: 1.25rem 1.5rem;
    background: rgba(0, 0, 0, 0.25);
    border-radius: 16px;
    transition: all 0.3s;
    border: 1px solid rgba(255, 255, 255, 0.05);
    word-wrap: break-word;
    overflow-wrap: break-word;
  }
  
  .active-topic-card:hover {
    background: rgba(0, 0, 0, 0.35);
    transform: translateX(5px);
    border-color: rgba(251, 191, 36, 0.3);
  }
  
  .active-topic-icon {
    width: 40px;
    height: 40px;
    border-radius: 12px;
    background: rgba(251, 191, 36, 0.15);
    display: flex;
    align-items: center;
    justify-content: center;
    color: #fbbf24;
    font-size: 1.2rem;
    flex-shrink: 0;
  }
  
  .active-topic-content {
    flex: 1;
    min-width: 0;
  }
  
  .active-topic-title {
    margin: 0 0 0.5rem;
    font-size: 1.1rem;
    word-wrap: break-word;
    overflow-wrap: break-word;
  }
  
  .active-topic-title a {
    color: #fff;
    text-decoration: none;
    transition: color 0.3s;
  }
  
  .active-topic-title a:hover {
    color: #fbbf24;
  }
  
  .active-topic-meta {
    display: flex;
    align-items: center;
    gap: 1.5rem;
    font-size: 0.9rem;
    color: rgba(255, 255, 255, 0.6);
    flex-wrap: wrap;
  }
  
  .active-topic-meta span {
    display: flex;
    align-items: center;
    gap: 0.3rem;
  }
  
  .active-topic-meta i {
    color: #fbbf24;
    font-size: 0.8rem;
  }
  
  .active-topic-meta a {
    color: rgba(255, 255, 255, 0.8);
    text-decoration: none;
    transition: color 0.3s;
  }
  
  .active-topic-meta a:hover {
    color: #fbbf24;
  }
  
  /* ===== ИНФОРМАЦИЯ О ФОРУМЕ ===== */
  .forum-info-section {
    margin-top: 3rem;
  }
  
  .info-cards {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
    gap: 1.5rem;
  }
  
  .info-card {
    display: flex;
    align-items: center;
    gap: 1.5rem;
    padding: 1.5rem;
    background: rgba(0, 0, 0, 0.2);
    border-radius: 16px;
    border: 1px solid rgba(255, 255, 255, 0.05);
    transition: all 0.3s;
  }
  
  .info-card:hover {
    background: rgba(0, 0, 0, 0.3);
    border-color: rgba(251, 191, 36, 0.2);
    transform: translateY(-5px);
  }
  
  .info-card i {
    font-size: 2.5rem;
    color: #fbbf24;
  }
  
  .info-card h3 {
    margin: 0 0 0.25rem;
    font-size: 1.2rem;
    color: #fff;
  }
  
  .info-card p {
    margin: 0;
    color: rgba(255, 255, 255, 0.7);
    font-size: 0.95rem;
    line-height: 1.5;
  }
  
  /* ===== АДАПТИВНОСТЬ ===== */
  @media (max-width: 992px) {
    .forum-main {
      padding: 1.5rem;
    }
    
    .forum-title {
      font-size: 2.5rem;
    }
    
    .categories-grid {
      grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
    }
  }
  
  @media (max-width: 768px) {
    .forum-hero {
      padding: 2rem 1rem;
    }
    
    .forum-title {
      font-size: 2rem;
      flex-direction: column;
    }
    
    .forum-description {
      font-size: 1rem;
    }
    
    .forum-actions {
      flex-direction: column;
    }
    
    .btn {
      width: 100%;
      justify-content: center;
    }
    
    .active-topic-card {
      flex-direction: column;
      align-items: flex-start;
    }
    
    .active-topic-meta {
      flex-direction: column;
      align-items: flex-start;
      gap: 0.75rem;
    }
    
    .info-card {
      flex-direction: column;
      text-align: center;
    }
    
    .section-title {
      font-size: 1.5rem;
    }
  }
  
  @media (max-width: 480px) {
    .forum-main {
      padding: 1rem;
    }
    
    .categories-grid {
      grid-template-columns: 1fr;
    }
    
    .category-card-header {
      flex-direction: column;
      text-align: center;
    }
    
    .category-stats {
      justify-content: center;
    }
    
    .info-cards {
      grid-template-columns: 1fr;
    }
  }
</style>