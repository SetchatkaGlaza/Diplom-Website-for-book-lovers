<%
  const readBooks = (userBooks || []).filter(item => item.status === 'read');
  const readingBooks = (userBooks || []).filter(item => item.status === 'reading');
  const plannedBooks = (userBooks || []).filter(item => item.status === 'want_to_read');
%>

<div class="public-profile-page">
  <div class="profile-header">
    <div class="profile-cover">
      <div class="profile-avatar-large">
        <img src="/images/avatars/<%= profileUser.avatar || 'default-avatar.png' %>" alt="<%= profileUser.name %>">
      </div>
    </div>

    <div class="profile-info">
      <h1><%= profileUser.name %></h1>
      <p class="profile-meta">
        <span><i class="fas fa-calendar-alt"></i> На сайте с <%= new Date(profileUser.createdAt).toLocaleDateString('ru-RU') %></span>
        <span>
          <i class="fas fa-user-tag"></i>
          <%= profileUser.role === 'admin' ? 'Администратор' : profileUser.role === 'moderator' ? 'Модератор' : 'Читатель' %>
        </span>
      </p>

      <% if (profileUser.bio) { %>
        <div class="profile-bio"><%= profileUser.bio %></div>
      <% } %>
    </div>
  </div>

  <div class="profile-stats-grid">
    <div class="stat-card">
      <div class="stat-icon"><i class="fas fa-book-reader"></i></div>
      <div class="stat-content">
        <span class="stat-value"><%= stats.booksRead %></span>
        <span class="stat-label">Прочитано</span>
      </div>
    </div>

    <div class="stat-card">
      <div class="stat-icon"><i class="fas fa-book-open"></i></div>
      <div class="stat-content">
        <span class="stat-value"><%= stats.booksReading %></span>
        <span class="stat-label">Читает сейчас</span>
      </div>
    </div>

    <div class="stat-card">
      <div class="stat-icon"><i class="fas fa-bookmark"></i></div>
      <div class="stat-content">
        <span class="stat-value"><%= stats.booksWantToRead %></span>
        <span class="stat-label">В планах</span>
      </div>
    </div>

    <div class="stat-card">
      <div class="stat-icon"><i class="fas fa-star"></i></div>
      <div class="stat-content">
        <span class="stat-value"><%= stats.reviewsCount %></span>
        <span class="stat-label">Рецензий</span>
      </div>
    </div>
  </div>

  <div class="profile-section">
    <div class="section-header">
      <h2><i class="fas fa-book"></i> Книжные полки</h2>
      <span class="section-badge"><%= (userBooks || []).length %> книг</span>
    </div>

    <div class="shelf-columns">
      <div class="shelf-column">
        <h3><i class="fas fa-check-circle"></i> Прочитано (<%= readBooks.length %>)</h3>
        <% if (readBooks.length > 0) { %>
          <div class="book-list">
            <% readBooks.forEach(item => { %>
              <a href="/books/<%= item.book.id %>" class="book-row">
                <img src="/images/covers/<%= item.book.cover_image %>" alt="<%= item.book.title %>">
                <div>
                  <strong><%= item.book.title %></strong>
                  <span><%= item.book.author %></span>
                </div>
              </a>
            <% }) %>
          </div>
        <% } else { %>
          <p class="empty-state">Нет книг в этой полке</p>
        <% } %>
      </div>

      <div class="shelf-column">
        <h3><i class="fas fa-book-open"></i> Читает сейчас (<%= readingBooks.length %>)</h3>
        <% if (readingBooks.length > 0) { %>
          <div class="book-list">
            <% readingBooks.forEach(item => { %>
              <a href="/books/<%= item.book.id %>" class="book-row">
                <img src="/images/covers/<%= item.book.cover_image %>" alt="<%= item.book.title %>">
                <div>
                  <strong><%= item.book.title %></strong>
                  <span><%= item.book.author %></span>
                </div>
              </a>
            <% }) %>
          </div>
        <% } else { %>
          <p class="empty-state">Нет книг в этой полке</p>
        <% } %>
      </div>

      <div class="shelf-column">
        <h3><i class="fas fa-bookmark"></i> В планах (<%= plannedBooks.length %>)</h3>
        <% if (plannedBooks.length > 0) { %>
          <div class="book-list">
            <% plannedBooks.forEach(item => { %>
              <a href="/books/<%= item.book.id %>" class="book-row">
                <img src="/images/covers/<%= item.book.cover_image %>" alt="<%= item.book.title %>">
                <div>
                  <strong><%= item.book.title %></strong>
                  <span><%= item.book.author %></span>
                </div>
              </a>
            <% }) %>
          </div>
        <% } else { %>
          <p class="empty-state">Нет книг в этой полке</p>
        <% } %>
      </div>
    </div>
  </div>

  <div class="profile-section">
    <div class="section-header">
      <h2><i class="fas fa-star"></i> Рецензии пользователя</h2>
      <span class="section-badge"><%= recentReviews.length %></span>
    </div>

    <% if (recentReviews.length > 0) { %>
      <div class="reviews-list">
        <% recentReviews.forEach(review => { %>
          <article class="review-card">
            <div class="review-head">
              <a href="/books/<%= review.book.id %>" class="review-book-link">
                <img src="/images/covers/<%= review.book.cover_image %>" alt="<%= review.book.title %>">
                <div>
                  <h4><%= review.book.title %></h4>
                  <p><%= review.book.author %></p>
                </div>
              </a>
              <div class="review-meta">
                <span class="review-rating"><%= review.rating %>/5</span>
                <span class="review-date"><%= new Date(review.createdAt).toLocaleDateString('ru-RU') %></span>
              </div>
            </div>
            <p class="review-text"><%= review.content %></p>
          </article>
        <% }) %>
      </div>
    <% } else { %>
      <p class="empty-state">Пока нет опубликованных рецензий</p>
    <% } %>
  </div>
</div>

<style>
  .public-profile-page { color: white; margin: 2rem 0; }

  .profile-header {
    background: rgba(255,255,255,0.08);
    border: 1px solid rgba(255,255,255,0.18);
    border-radius: var(--radius-lg);
    overflow: hidden;
    margin-bottom: 1.5rem;
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
  }

  .profile-cover {
    height: 180px;
    background: linear-gradient(135deg, var(--primary), var(--secondary));
    position: relative;
  }

  .profile-avatar-large {
    position: absolute;
    left: 2rem;
    bottom: -45px;
    width: 110px;
    height: 110px;
    border-radius: 50%;
    overflow: hidden;
    border: 4px solid #fff;
    box-shadow: var(--shadow-lg);
    background: #fff;
  }

  .profile-avatar-large img { width: 100%; height: 100%; object-fit: cover; }

  .profile-info { padding: 4rem 2rem 2rem; }
  .profile-info h1 { margin-bottom: 0.5rem; }

  .profile-meta {
    display: flex;
    gap: 1.25rem;
    flex-wrap: wrap;
    opacity: 0.85;
    margin-bottom: 1rem;
  }

  .profile-bio {
    background: rgba(255,255,255,0.1);
    border: 1px solid rgba(255,255,255,0.18);
    border-radius: var(--radius);
    padding: 1rem;
    max-width: 900px;
  }

  .profile-stats-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(190px, 1fr));
    gap: 1rem;
    margin-bottom: 1.5rem;
  }

  .stat-card {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding: 1rem;
    background: rgba(255,255,255,0.08);
    border: 1px solid rgba(255,255,255,0.18);
    border-radius: var(--radius-lg);
  }

  .stat-icon {
    width: 44px;
    height: 44px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    background: rgba(251,191,36,0.2);
    color: #fbbf24;
  }

  .stat-content { display: flex; flex-direction: column; }
  .stat-value { font-size: 1.5rem; font-weight: 700; }
  .stat-label { opacity: 0.85; font-size: 0.9rem; }

  .profile-section {
    background: rgba(255,255,255,0.08);
    border: 1px solid rgba(255,255,255,0.18);
    border-radius: var(--radius-lg);
    padding: 1.25rem;
    margin-bottom: 1.5rem;
  }

  .section-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 1rem;
    gap: 0.75rem;
  }

  .section-header h2 {
    margin: 0;
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 1.2rem;
  }

  .section-badge {
    padding: 0.3rem 0.75rem;
    border-radius: 999px;
    background: rgba(255,255,255,0.12);
    border: 1px solid rgba(255,255,255,0.2);
    font-size: 0.85rem;
  }

  .shelf-columns {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 1rem;
  }

  .shelf-column {
    background: rgba(0,0,0,0.2);
    border-radius: var(--radius);
    border: 1px solid rgba(255,255,255,0.12);
    padding: 0.9rem;
    min-height: 180px;
  }

  .shelf-column h3 {
    font-size: 0.95rem;
    margin-bottom: 0.75rem;
    display: flex;
    align-items: center;
    gap: 0.4rem;
  }

  .book-list {
    display: flex;
    flex-direction: column;
    gap: 0.55rem;
    max-height: 360px;
    overflow: auto;
    padding-right: 0.25rem;
  }

  .book-row {
    display: grid;
    grid-template-columns: 36px 1fr;
    gap: 0.6rem;
    align-items: center;
    text-decoration: none;
    color: white;
    padding: 0.45rem;
    border-radius: 8px;
    background: rgba(255,255,255,0.03);
  }

  .book-row:hover { background: rgba(255,255,255,0.09); }
  .book-row img { width: 36px; height: 54px; object-fit: cover; border-radius: 6px; }
  .book-row strong { display: block; font-size: 0.9rem; line-height: 1.2; }
  .book-row span { opacity: 0.75; font-size: 0.82rem; }

  .reviews-list { display: flex; flex-direction: column; gap: 0.8rem; }

  .review-card {
    background: rgba(0,0,0,0.2);
    border: 1px solid rgba(255,255,255,0.12);
    border-radius: var(--radius);
    padding: 0.9rem;
  }

  .review-head {
    display: flex;
    justify-content: space-between;
    gap: 1rem;
    margin-bottom: 0.65rem;
    flex-wrap: wrap;
  }

  .review-book-link {
    color: white;
    text-decoration: none;
    display: grid;
    grid-template-columns: 42px 1fr;
    gap: 0.7rem;
    align-items: center;
  }

  .review-book-link img { width: 42px; height: 62px; border-radius: 6px; object-fit: cover; }
  .review-book-link h4 { margin: 0; font-size: 1rem; }
  .review-book-link p { margin: 0; opacity: 0.75; font-size: 0.88rem; }

  .review-meta { text-align: right; font-size: 0.88rem; display: flex; flex-direction: column; gap: 0.25rem; }
  .review-rating { color: #fbbf24; font-weight: 700; }
  .review-date { opacity: 0.7; }
  .review-text { margin: 0; line-height: 1.55; opacity: 0.95; }

  .empty-state {
    margin: 0;
    opacity: 0.75;
    padding: 0.6rem;
    background: rgba(255,255,255,0.04);
    border-radius: 8px;
  }

  @media (max-width: 1024px) {
    .shelf-columns { grid-template-columns: 1fr; }
  }

  @media (max-width: 768px) {
    .profile-avatar-large { left: 1rem; }
    .profile-info { padding: 4rem 1rem 1rem; }
    .review-meta { text-align: left; }
  }
</style>
