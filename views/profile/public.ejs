<div class="public-profile-page">
  <div class="profile-header">
    <div class="profile-cover">
      <div class="profile-avatar-wrapper">
        <img src="/images/avatars/<%= profileUser.avatar %>" alt="<%= profileUser.name %>" class="profile-avatar">
      </div>
    </div>

    <div class="profile-info">
      <h1 class="profile-name"><%= profileUser.name %></h1>
      <p class="profile-meta">
        <i class="fas fa-calendar-alt"></i> На сайте с <%= new Date(profileUser.createdAt).toLocaleDateString('ru-RU') %>
        <i class="fas fa-user-tag"></i>
        <%= profileUser.role === 'admin' ? 'Администратор' : profileUser.role === 'moderator' ? 'Модератор' : 'Читатель' %>
      </p>
      <% if (profileUser.bio) { %>
        <div class="profile-bio"><p><%= profileUser.bio %></p></div>
      <% } %>
    </div>
  </div>

  <div class="profile-stats-grid">
    <div class="stat-card"><div class="stat-icon"><i class="fas fa-book-reader"></i></div><div class="stat-content"><span class="stat-value"><%= stats.booksRead %></span><span class="stat-label">Прочитано</span></div></div>
    <div class="stat-card"><div class="stat-icon"><i class="fas fa-book-open"></i></div><div class="stat-content"><span class="stat-value"><%= stats.booksReading %></span><span class="stat-label">Читает сейчас</span></div></div>
    <div class="stat-card"><div class="stat-icon"><i class="fas fa-bookmark"></i></div><div class="stat-content"><span class="stat-value"><%= stats.booksWantToRead %></span><span class="stat-label">В планах</span></div></div>
    <div class="stat-card"><div class="stat-icon"><i class="fas fa-star"></i></div><div class="stat-content"><span class="stat-value"><%= stats.reviewsCount %></span><span class="stat-label">Рецензий</span></div></div>
  </div>

  <div class="profile-sections">
    <section class="profile-section">
      <div class="section-header"><h2><i class="fas fa-book"></i> Книги на полках</h2></div>
      <% if (recentBooks && recentBooks.length > 0) { %>
        <div class="books-grid">
          <% recentBooks.forEach(item => { %>
            <a href="/books/<%= item.book.id %>" class="book-card">
              <img src="/images/covers/<%= item.book.cover_image %>" alt="<%= item.book.title %>">
              <div class="book-card-info">
                <h3><%= item.book.title %></h3>
                <p><%= item.book.author %></p>
                <span class="status-tag status-<%= item.status %>">
                  <%= item.status === 'read' ? 'Прочитано' : item.status === 'reading' ? 'Читает' : 'В планах' %>
                </span>
              </div>
            </a>
          <% }) %>
        </div>
      <% } else { %>
        <p class="empty-state">У пользователя пока нет книг на полках.</p>
      <% } %>
    </section>

    <section class="profile-section">
      <div class="section-header"><h2><i class="fas fa-star"></i> Рецензии пользователя</h2></div>
      <% if (recentReviews && recentReviews.length > 0) { %>
        <div class="reviews-list">
          <% recentReviews.forEach(review => { %>
            <article class="review-card">
              <div class="review-head">
                <a href="/books/<%= review.book.id %>" class="review-book"><%= review.book.title %></a>
                <span class="review-date"><%= new Date(review.createdAt).toLocaleDateString('ru-RU') %></span>
              </div>
              <div class="review-rating">
                <% for(let i = 1; i <= 5; i++) { %>
                  <i class="<%= i <= review.rating ? 'fas' : 'far' %> fa-star"></i>
                <% } %>
              </div>
              <p class="review-content"><%= review.content.length > 220 ? review.content.substring(0, 220) + '...' : review.content %></p>
            </article>
          <% }) %>
        </div>
      <% } else { %>
        <p class="empty-state">Пока нет опубликованных рецензий.</p>
      <% } %>
    </section>
  </div>
</div>

<style>
  .public-profile-page { color: #fff; }
  .profile-header { background: rgba(255,255,255,.1); border: 1px solid rgba(255,255,255,.2); border-radius: 16px; overflow: hidden; margin: 2rem 0 1rem; }
  .profile-cover { height: 180px; background: linear-gradient(135deg, var(--primary), var(--secondary)); position: relative; }
  .profile-avatar-wrapper { position: absolute; bottom: -46px; left: 1.5rem; width: 110px; height: 110px; border-radius: 50%; overflow: hidden; border: 4px solid #fff; background: #fff; }
  .profile-avatar { width: 100%; height: 100%; object-fit: cover; }
  .profile-info { padding: 3.5rem 1.5rem 1.5rem; }
  .profile-name { margin: 0 0 .5rem; font-size: 2rem; }
  .profile-meta { display: flex; flex-wrap: wrap; gap: 1rem; opacity: .85; margin: 0 0 .75rem; }
  .profile-bio { background: rgba(255,255,255,.08); border-radius: 10px; padding: .75rem 1rem; }
  .profile-bio p { margin: 0; }
  .profile-stats-grid { display: grid; grid-template-columns: repeat(auto-fit,minmax(190px,1fr)); gap: 12px; margin-bottom: 1rem; }
  .stat-card { background: rgba(255,255,255,.08); border: 1px solid rgba(255,255,255,.2); border-radius: 12px; padding: 12px; display: flex; align-items: center; gap: 10px; }
  .stat-value { font-size: 1.25rem; font-weight: 700; }
  .stat-label { display: block; opacity: .8; font-size: .9rem; }
  .profile-sections { display: grid; gap: 1rem; }
  .profile-section { background: rgba(255,255,255,.08); border: 1px solid rgba(255,255,255,.2); border-radius: 12px; padding: 14px; }
  .section-header h2 { margin: 0; font-size: 1.15rem; }
  .books-grid { display: grid; grid-template-columns: repeat(auto-fill,minmax(220px,1fr)); gap: 10px; margin-top: 10px; }
  .book-card { display: grid; grid-template-columns: 64px 1fr; gap: 10px; background: rgba(0,0,0,.2); border-radius: 10px; padding: 8px; color: #fff; text-decoration: none; }
  .book-card img { width: 64px; height: 92px; object-fit: cover; border-radius: 6px; }
  .book-card-info h3 { margin: 0 0 4px; font-size: .95rem; }
  .book-card-info p { margin: 0 0 8px; opacity: .8; font-size: .9rem; }
  .status-tag { display: inline-block; font-size: .75rem; padding: 2px 8px; border-radius: 999px; background: rgba(255,255,255,.16); }
  .reviews-list { display: grid; gap: 10px; margin-top: 10px; }
  .review-card { background: rgba(0,0,0,.2); border-radius: 10px; padding: 10px; }
  .review-head { display: flex; justify-content: space-between; gap: 10px; align-items: center; }
  .review-book { color: #fff; font-weight: 600; }
  .review-date { opacity: .75; font-size: .85rem; }
  .review-rating { margin: 6px 0; color: #fbbf24; }
  .review-content { margin: 0; opacity: .95; }
  .empty-state { opacity: .8; margin-top: 10px; }
</style>
