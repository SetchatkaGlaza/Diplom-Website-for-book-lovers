<div class="profile-header">
  <div class="profile-cover">
    <div class="profile-avatar-large">
      <img src="/images/avatars/<%= user.avatar %>" alt="<%= user.name %>">
    </div>
  </div>
  
  <div class="profile-info">
    <h1><%= user.name %></h1>
    <p class="profile-meta">
      <i class="fas fa-calendar-alt"></i> На сайте с <%= new Date(user.createdAt).toLocaleDateString('ru-RU') %>
      <i class="fas fa-user-tag"></i> <%= user.role === 'admin' ? 'Администратор' : user.role === 'moderator' ? 'Модератор' : 'Читатель' %>
    </p>
    
    <% if (user.bio) { %>
      <div class="profile-bio">
        <p><%= user.bio %></p>
      </div>
    <% } %>
    
    <a href="/profile/edit" class="btn btn-primary">
      <i class="fas fa-edit"></i> Редактировать профиль
    </a>
  </div>
</div>

<div class="profile-stats-grid">
  <div class="stat-card">
    <div class="stat-icon"><i class="fas fa-book-reader"></i></div>
    <div class="stat-content">
      <span class="stat-value"><%= stats.booksRead %></span>
      <span class="stat-label">Прочитано</span>
    </div>
  </div>
  
  <div class="stat-card">
    <div class="stat-icon"><i class="fas fa-bookmark"></i></div>
    <div class="stat-content">
      <span class="stat-value"><%= stats.booksWantToRead %></span>
      <span class="stat-label">Хочу прочитать</span>
    </div>
  </div>
  
  <div class="stat-card">
    <div class="stat-icon"><i class="fas fa-book-open"></i></div>
    <div class="stat-content">
      <span class="stat-value"><%= stats.booksReading %></span>
      <span class="stat-label">Читаю сейчас</span>
    </div>
  </div>
  
  <div class="stat-card">
    <div class="stat-icon"><i class="fas fa-star"></i></div>
    <div class="stat-content">
      <span class="stat-value"><%= stats.reviewsCount %></span>
      <span class="stat-label">Рецензий</span>
    </div>
  </div>
</div>

<div class="profile-sections">
  <div class="profile-section">
    <div class="section-header">
      <h2><i class="fas fa-clock"></i> Недавние рецензии</h2>
      <a href="/profile/reviews" class="btn-link">Все рецензии <i class="fas fa-arrow-right"></i></a>
    </div>
    
    <% if (recentReviews.length > 0) { %>
      <div class="recent-reviews">
        <% recentReviews.forEach(review => { %>
          <div class="recent-review-card">
            <div class="review-book-cover">
              <img src="/images/covers/<%= review.book.cover_image %>" alt="<%= review.book.title %>">
            </div>
            <div class="review-content">
              <h3><a href="/books/<%= review.book.id %>"><%= review.book.title %></a></h3>
              <p class="review-meta">
                <span class="review-rating">
                  <% for(let i = 1; i <= 5; i++) { %>
                    <% if (i <= review.rating) { %>
                      <i class="fas fa-star"></i>
                    <% } else { %>
                      <i class="far fa-star"></i>
                    <% } %>
                  <% } %>
                </span>
                <span class="review-date"><%= new Date(review.createdAt).toLocaleDateString('ru-RU') %></span>
              </p>
              <p class="review-excerpt"><%= review.content.substring(0, 150) %>...</p>
            </div>
          </div>
        <% }) %>
      </div>
    <% } else { %>
      <p class="empty-state">Вы ещё не написали ни одной рецензии</p>
    <% } %>
  </div>
  
  <div class="profile-section">
    <div class="section-header">
      <h2><i class="fas fa-book"></i> Недавние книги</h2>
      <a href="/profile/books" class="btn-link">Все книги <i class="fas fa-arrow-right"></i></a>
    </div>
    
    <% if (recentBooks.length > 0) { %>
      <div class="recent-books-grid">
        <% recentBooks.forEach(ub => { %>
          <div class="recent-book-card">
            <a href="/books/<%= ub.book.id %>" class="book-link">
              <div class="book-cover">
                <img src="/images/covers/<%= ub.book.cover_image %>" alt="<%= ub.book.title %>">
                <span class="book-status status-<%= ub.status %>">
                  <% if (ub.status === 'read') { %>
                    <i class="fas fa-check"></i> Прочитано
                  <% } else if (ub.status === 'reading') { %>
                    <i class="fas fa-book-open"></i> Читаю
                  <% } else { %>
                    <i class="fas fa-bookmark"></i> В планах
                  <% } %>
                </span>
              </div>
              <div class="book-info">
                <h4><%= ub.book.title %></h4>
                <p><%= ub.book.author %></p>
              </div>
            </a>
          </div>
        <% }) %>
      </div>
    <% } else { %>
      <p class="empty-state">У вас пока нет книг на полках</p>
    <% } %>
  </div>
</div>

