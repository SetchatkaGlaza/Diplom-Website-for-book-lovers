<div class="email-change-page">
  <div class="email-change-card">
    <div class="email-change-header">
      <h1><i class="fas fa-envelope-open-text"></i> Запрос на смену email</h1>
      <p>Отправьте обращение администратору. После проверки вы получите решение по запросу.</p>
    </div>

    <% if (errors && errors.length > 0) { %>
      <div class="alert alert-danger"><ul><% errors.forEach(error => { %><li><%= error.msg %></li><% }) %></ul></div>
    <% } %>

    <% if (pendingRequest) { %>
      <div class="request-lock-banner">
        <div class="lock-icon"><i class="fas fa-clock"></i></div>
        <div class="lock-content">
          <h3>Запрос уже на рассмотрении</h3>
          <p>Мы уже передали ваше обращение администратору.</p>
          <p class="lock-time">Отправлен: <strong><%= new Date(pendingRequest.createdAt).toLocaleString('ru-RU') %></strong></p>
          <p class="lock-hint">Новый запрос можно отправить после принятия решения по текущему.</p>
        </div>
      </div>
    <% } %>

    <form action="/profile/email-change" method="POST" class="email-change-form">
      <div class="form-group">
        <label>Текущий email</label>
        <input type="email" value="<%= user.email %>" disabled>
      </div>

      <div class="form-group">
        <label for="new_email">Новый email</label>
        <input type="email" id="new_email" name="new_email" maxlength="254" required value="<%= (typeof formData !== 'undefined' && formData && formData.new_email) ? formData.new_email : '' %>">
      </div>

      <div class="form-group">
        <label for="reason">Причина обращения</label>
        <textarea id="reason" name="reason" rows="6" minlength="20" maxlength="1000" required placeholder="Кратко опишите, почему нужен перенос email"><%= (typeof formData !== 'undefined' && formData && formData.reason) ? formData.reason : '' %></textarea>
        <small>От 20 до 1000 символов. Поддерживается перенос длинных слов и ссылок.</small>
      </div>

      <div class="email-change-actions">
        <button type="submit" class="btn btn-primary" <%= pendingRequest ? 'disabled' : '' %>>Отправить запрос</button>
        <a href="/profile/edit" class="btn btn-outline">Назад</a>
      </div>
    </form>
  </div>
</div>

<style>
  .email-change-page {
    margin: 2rem 0;
    position: relative;
  }

  .email-change-page::before {
    content: '';
    position: absolute;
    inset: 0;
    background: radial-gradient(circle at 20% 10%, rgba(99,102,241,.2), transparent 40%), radial-gradient(circle at 80% 80%, rgba(14,165,233,.18), transparent 38%);
    filter: blur(6px);
    pointer-events: none;
  }

  .email-change-card {
    color: #c7d2fe;
    position: relative;
    z-index: 1;
    max-width: 820px;
    margin: 0 auto;
    padding: 2rem;
    background: linear-gradient(160deg, rgba(255, 255, 255, 0.16), rgba(255, 255, 255, 0.07));
    border: 1px solid rgba(255, 255, 255, 0.24);
    border-radius: var(--radius-lg);
    backdrop-filter: blur(14px);
    -webkit-backdrop-filter: blur(14px);
    box-shadow: 0 20px 40px rgba(15, 23, 42, 0.35);
  }

  .email-change-header h1 {
    display:flex;
    gap:.75rem;
    align-items:center;
    margin-bottom:.5rem;
    font-size: 2rem;
  }

  .email-change-header p {
    color: #bfdbfe;
    opacity:.92;
    margin-bottom:1.25rem;
    line-height: 1.6;
  }

  .request-lock-banner {
    display: grid;
    grid-template-columns: auto 1fr;
    gap: .9rem;
    align-items: start;
    margin-bottom: 1.1rem;
    padding: 1rem;
    border-radius: var(--radius);
    border: 1px solid rgba(251,191,36,.4);
    background: linear-gradient(145deg, rgba(251,191,36,.2), rgba(251,191,36,.08));
  }

  .lock-icon {
    width: 42px;
    height: 42px;
    border-radius: 12px;
    display: grid;
    place-items: center;
    background: rgba(0,0,0,.2);
    color: #fde68a;
    font-size: 1.05rem;
  }

  .lock-content h3 { margin: 0 0 .3rem; font-size: 1.05rem; }
  .lock-content p { margin: .2rem 0; }
  .lock-time { color: #fde68a; }
  .lock-hint { opacity: .9; color: #fde68a; }

  .email-change-form .form-group { margin-bottom: 1rem; }
  .email-change-form label { font-weight: 600; display: block; margin-bottom: .45rem; }
  .email-change-form small { display: block; margin-top: .4rem; opacity: .8; }

  .email-change-form input,
  .email-change-form textarea {
    width: 100%;
    box-sizing: border-box;
    max-width: 100%;
    border-radius: var(--radius);
    border: 1px solid rgba(255,255,255,.26);
    background: rgba(10, 14, 25, .35);
    color: #cbd5e1;
    padding: .95rem 1rem;
    overflow-wrap: anywhere;
    word-break: break-word;
    transition: .2s ease;
  }

  .email-change-form input[disabled] {
    opacity: .85;
    cursor: not-allowed;
    background: rgba(255,255,255,.06);
  }

  .email-change-form textarea {
    resize: vertical;
    min-height: 160px;
    max-height: 440px;
  }

  .email-change-form input:focus,
  .email-change-form textarea:focus {
    outline: none;
    border-color: rgba(99,102,241,.9);
    box-shadow: 0 0 0 3px rgba(99,102,241,.28);
    background: rgba(10, 14, 25, .5);
  }

  .email-change-actions { display:flex; gap:.75rem; flex-wrap:wrap; margin-top:1rem; }

  @media (max-width: 768px) {
    .email-change-card {
      color: #c7d2fe;
      padding: 1.2rem;
    }
    .email-change-header h1 { font-size: 1.55rem; }
    .request-lock-banner { grid-template-columns: 1fr; }
  }
</style>
