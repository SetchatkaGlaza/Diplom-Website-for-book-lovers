<div class="my-reviews">
  <h1><i class="fas fa-star"></i> Мои рецензии</h1>
  
  <% if (reviews.length > 0) { %>
    <div class="reviews-list-detailed">
      <% reviews.forEach(review => { %>
        <div class="review-detailed-card">
          <div class="review-detailed-header">
            <div class="review-book-info">
              <img src="/images/covers/<%= review.book.cover_image %>" alt="<%= review.book.title %>" class="review-book-cover">
              <div>
                <h3><a href="/books/<%= review.book.id %>"><%= review.book.title %></a></h3>
                <p class="review-book-author"><%= review.book.author %></p>
              </div>
            </div>
            
            <div class="review-stats">
              <div class="review-rating-large">
                <% for(let i = 1; i <= 5; i++) { %>
                  <% if (i <= review.rating) { %>
                    <i class="fas fa-star"></i>
                  <% } else { %>
                    <i class="far fa-star"></i>
                  <% } %>
                <% } %>
              </div>
              
              <div class="review-helpfulness">
                <span class="helpful-percent"><%= review.helpful_percent %>%</span>
                <span class="helpful-counts">
                  👍 <%= review.likes_count %> 👎 <%= review.dislikes_count %>
                </span>
              </div>
              
              <div class="review-date">
                <i class="far fa-calendar-alt"></i>
                <%= new Date(review.createdAt).toLocaleDateString('ru-RU') %>
              </div>
            </div>
          </div>
          
          <div class="review-detailed-content">
            <p><%= review.content %></p>
          </div>
          
          <!-- ЕДИНЫЙ РАЗМЕР КНОПОК - ВСЕ ОДИНАКОВЫЕ! -->
          <div class="review-detailed-footer">
            <a href="/reviews/<%= review.id %>/edit" class="btn-edit">
              <i class="fas fa-edit"></i>
              <span>Редактировать</span>
            </a>
            
            <form action="/reviews/<%= review.id %>?_method=DELETE" method="POST" class="delete-form">
              <button type="submit" class="btn-delete" onclick="return confirm('Удалить рецензию?')">
                <i class="fas fa-trash"></i>
                <span>Удалить</span>
              </button>
            </form>
            
            <a href="/books/<%= review.book.id %>" class="btn-view">
              <i class="fas fa-book"></i>
              <span>К книге</span>
            </a>
          </div>
        </div>
      <% }) %>
    </div>
    
    <!-- Пагинация -->
    <% if (totalPages > 1) { %>
      <div class="pagination">
        <% if (currentPage > 1) { %>
          <a href="?page=<%= currentPage - 1 %>" class="page-link">
            <i class="fas fa-chevron-left"></i>
          </a>
        <% } %>
        
        <% for(let i = 1; i <= totalPages; i++) { %>
          <% if (i === currentPage) { %>
            <span class="page-link active"><%= i %></span>
          <% } else { %>
            <a href="?page=<%= i %>" class="page-link"><%= i %></a>
          <% } %>
        <% } %>
        
        <% if (currentPage < totalPages) { %>
          <a href="?page=<%= currentPage + 1 %>" class="page-link">
            <i class="fas fa-chevron-right"></i>
          </a>
        <% } %>
      </div>
    <% } %>
    
  <% } else { %>
    <div class="empty-state">
      <i class="fas fa-star fa-4x"></i>
      <h3>У вас пока нет рецензий</h3>
      <p>Напишите первую рецензию на <a href="/books">понравившуюся книгу</a></p>
    </div>
  <% } %>
</div>

<style>
  .my-reviews {
    background: rgba(255, 255, 255, 0.1);
    backdrop-filter: blur(10px);
    -webkit-backdrop-filter: blur(10px);
    border: 1px solid rgba(255, 255, 255, 0.2);
    border-radius: var(--radius-lg);
    padding: 2rem;
    margin: 2rem 0;
    color: white;
  }
  
  .my-reviews h1 {
    margin-bottom: 2rem;
    display: flex;
    align-items: center;
    gap: 1rem;
  }
  
  .reviews-list-detailed {
    display: flex;
    flex-direction: column;
    gap: 2rem;
  }
  
  .review-detailed-card {
    background: rgba(0, 0, 0, 0.3);
    border-radius: var(--radius-lg);
    padding: 1.5rem;
    transition: var(--transition);
  }
  
  .review-detailed-card:hover {
    transform: translateX(10px);
    background: rgba(0, 0, 0, 0.4);
  }
  
  .review-detailed-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    margin-bottom: 1.5rem;
    padding-bottom: 1rem;
    border-bottom: 1px solid rgba(255, 255, 255, 0.1);
    flex-wrap: wrap;
    gap: 1rem;
  }
  
  .review-book-info {
    display: flex;
    gap: 1rem;
  }
  
  .review-book-cover {
    width: 60px;
    height: 90px;
    object-fit: cover;
    border-radius: var(--radius-sm);
  }
  
  .review-book-info h3 {
    margin-bottom: 0.25rem;
  }
  
  .review-book-info h3 a {
    color: white;
    text-decoration: none;
  }
  
  .review-book-info h3 a:hover {
    text-decoration: underline;
  }
  
  .review-book-author {
    opacity: 0.7;
  }
  
  .review-stats {
    text-align: right;
  }
  
  .review-rating-large {
    color: #fbbf24;
    font-size: 1.2rem;
    margin-bottom: 0.5rem;
  }
  
  .review-helpfulness {
    margin-bottom: 0.25rem;
  }
  
  .helpful-percent {
    font-weight: 700;
    color: var(--success);
  }
  
  .helpful-counts {
    font-size: 0.9rem;
    opacity: 0.7;
  }
  
  .review-date {
    font-size: 0.9rem;
    opacity: 0.6;
  }
  
  .review-detailed-content {
    margin-bottom: 1.5rem;
    line-height: 1.8;
  }
  
  /* ===== ЕДИНЫЙ СТИЛЬ ДЛЯ ВСЕХ КНОПОК ===== */
  .review-detailed-footer {
    display: flex;
    gap: 1rem;
    justify-content: flex-end;
    margin-top: 1rem;
    flex-wrap: wrap;
  }
  
  /* Базовый стиль для всех кнопок - ОДИНАКОВЫЙ РАЗМЕР! */
  .btn-edit,
  .btn-delete,
  .btn-view {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    padding: 0.6rem 1.2rem;
    min-width: 130px;
    height: 38px;
    border-radius: 8px;
    font-size: 0.9rem;
    font-weight: 500;
    text-decoration: none;
    cursor: pointer;
    transition: all 0.3s ease;
    border: none;
    font-family: inherit;
    box-sizing: border-box;
  }
  
  /* Кнопка Редактировать */
  .btn-edit {
    background: rgba(59, 130, 246, 0.15);
    color: #3b82f6;
    border: 1px solid rgba(59, 130, 246, 0.3);
  }
  
  .btn-edit:hover {
    background: #3b82f6;
    color: white;
    transform: translateY(-2px);
    box-shadow: 0 4px 12px rgba(59, 130, 246, 0.3);
  }
  
  /* Кнопка Удалить */
  .btn-delete {
    background: rgba(239, 68, 68, 0.15);
    color: #ef4444;
    border: 1px solid rgba(239, 68, 68, 0.3);
  }
  
  .btn-delete:hover {
    background: #ef4444;
    color: white;
    transform: translateY(-2px);
    box-shadow: 0 4px 12px rgba(239, 68, 68, 0.3);
  }
  
  /* Кнопка К книге */
  .btn-view {
    background: rgba(251, 191, 36, 0.15);
    color: #fbbf24;
    border: 1px solid rgba(251, 191, 36, 0.3);
  }
  
  .btn-view:hover {
    background: #fbbf24;
    color: #000;
    transform: translateY(-2px);
    box-shadow: 0 4px 12px rgba(251, 191, 36, 0.3);
  }
  
  /* Иконки внутри кнопок */
  .btn-edit i,
  .btn-delete i,
  .btn-view i {
    font-size: 0.9rem;
  }
  
  /* Текст внутри кнопок */
  .btn-edit span,
  .btn-delete span,
  .btn-view span {
    font-size: 0.9rem;
  }
  
  /* Форма удаления - inline */
  .delete-form {
    display: inline-block;
  }
  
  /* Пагинация */
  .pagination {
    display: flex;
    justify-content: center;
    align-items: center;
    gap: 0.5rem;
    margin-top: 2rem;
    flex-wrap: wrap;
  }
  
  .page-link {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-width: 40px;
    height: 40px;
    padding: 0 0.5rem;
    border-radius: 10px;
    background: rgba(255, 255, 255, 0.1);
    color: white;
    text-decoration: none;
    transition: all 0.3s;
    border: 1px solid rgba(255, 255, 255, 0.1);
  }
  
  .page-link:hover {
    background: var(--accent);
    transform: translateY(-2px);
  }
  
  .page-link.active {
    background: var(--accent);
    cursor: default;
    transform: none;
  }
  
  /* Пустое состояние */
  .empty-state {
    text-align: center;
    padding: 3rem;
  }
  
  .empty-state i {
    opacity: 0.5;
    margin-bottom: 1rem;
    color: #fbbf24;
  }
  
  .empty-state h3 {
    margin-bottom: 0.5rem;
  }
  
  .empty-state a {
    color: #fbbf24;
    text-decoration: none;
  }
  
  .empty-state a:hover {
    text-decoration: underline;
  }
  
  /* Адаптивность */
  @media (max-width: 768px) {
    .review-detailed-header {
      flex-direction: column;
      align-items: flex-start;
    }
    
    .review-stats {
      text-align: left;
      width: 100%;
    }
    
    .review-detailed-footer {
      flex-direction: column;
      align-items: stretch;
    }
    
    .btn-edit,
    .btn-delete,
    .btn-view {
      width: 100%;
      justify-content: center;
    }
  }
  
  @media (max-width: 480px) {
    .my-reviews {
      padding: 1rem;
    }
    
    .btn-edit,
    .btn-delete,
    .btn-view {
      min-width: 100%;
    }
  }
</style>