<div class="my-reviews">
  <h1><i class="fas fa-star"></i> Мои рецензии</h1>
  
  <% if (reviews.length > 0) { %>
    <div class="reviews-list-detailed">
      <% reviews.forEach(review => { %>
        <div class="review-detailed-card">
          <div class="review-detailed-header">
            <div class="review-book-info">
              <img src="/images/covers/<%= review.book.cover_image %>" alt="<%= review.book.title %>" class="review-book-cover">
              <div>
                <h3><a href="/books/<%= review.book.id %>"><%= review.book.title %></a></h3>
                <p class="review-book-author"><%= review.book.author %></p>
              </div>
            </div>
            
            <div class="review-stats">
              <div class="review-rating-large">
                <% for(let i = 1; i <= 5; i++) { %>
                  <% if (i <= review.rating) { %>
                    <i class="fas fa-star"></i>
                  <% } else { %>
                    <i class="far fa-star"></i>
                  <% } %>
                <% } %>
              </div>
              
              <div class="review-helpfulness">
                <span class="helpful-percent"><%= review.helpful_percent %>%</span>
                <span class="helpful-counts">
                  👍 <%= review.likes_count %> 👎 <%= review.dislikes_count %>
                </span>
              </div>
              
              <div class="review-date">
                <i class="far fa-calendar-alt"></i>
                <%= new Date(review.createdAt).toLocaleDateString('ru-RU') %>
              </div>
            </div>
          </div>
          
          <div class="review-detailed-content">
            <p><%= review.content %></p>
          </div>
          
          <div class="review-detailed-footer">
            <a href="/profile/reviews/<%= review.id %>/edit" class="btn btn-outline">
              <i class="fas fa-edit"></i> Редактировать
            </a>
            
            <form action="/profile/reviews/<%= review.id %>?_method=DELETE" method="POST" class="delete-form">
              <button type="submit" class="btn btn-danger" onclick="return confirm('Удалить рецензию?')">
                <i class="fas fa-trash"></i> Удалить
              </button>
            </form>
            
            <a href="/books/<%= review.book.id %>" class="btn btn-primary">
              <i class="fas fa-book"></i> К книге
            </a>
          </div>
        </div>
      <% }) %>
    </div>
    
    <!-- Пагинация -->
    <% if (totalPages > 1) { %>
      <div class="pagination">
        <% if (currentPage > 1) { %>
          <a href="?page=<%= currentPage - 1 %>" class="page-link">
            <i class="fas fa-chevron-left"></i>
          </a>
        <% } %>
        
        <% for(let i = 1; i <= totalPages; i++) { %>
          <% if (i === currentPage) { %>
            <span class="page-link active"><%= i %></span>
          <% } else { %>
            <a href="?page=<%= i %>" class="page-link"><%= i %></a>
          <% } %>
        <% } %>
        
        <% if (currentPage < totalPages) { %>
          <a href="?page=<%= currentPage + 1 %>" class="page-link">
            <i class="fas fa-chevron-right"></i>
          </a>
        <% } %>
      </div>
    <% } %>
    
  <% } else { %>
    <div class="empty-state">
      <i class="fas fa-star fa-4x"></i>
      <h3>У вас пока нет рецензий</h3>
      <p>Напишите первую рецензию на <a href="/books">понравившуюся книгу</a></p>
    </div>
  <% } %>
</div>

<style>
  .my-reviews {
    background: rgba(255, 255, 255, 0.1);
    backdrop-filter: blur(10px);
    -webkit-backdrop-filter: blur(10px);
    border: 1px solid rgba(255, 255, 255, 0.2);
    border-radius: var(--radius-lg);
    padding: 2rem;
    margin: 2rem 0;
    color: white;
  }
  
  .my-reviews h1 {
    margin-bottom: 2rem;
    display: flex;
    align-items: center;
    gap: 1rem;
  }
  
  .reviews-list-detailed {
    display: flex;
    flex-direction: column;
    gap: 2rem;
  }
  
  .review-detailed-card {
    background: rgba(0, 0, 0, 0.2);
    border-radius: var(--radius-lg);
    padding: 1.5rem;
    transition: var(--transition);
  }
  
  .review-detailed-card:hover {
    transform: translateX(10px);
    background: rgba(0, 0, 0, 0.3);
  }
  
  .review-detailed-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    margin-bottom: 1.5rem;
    padding-bottom: 1rem;
    border-bottom: 1px solid rgba(255, 255, 255, 0.1);
  }
  
  .review-book-info {
    display: flex;
    gap: 1rem;
  }
  
  .review-book-cover {
    width: 60px;
    height: 90px;
    object-fit: cover;
    border-radius: var(--radius-sm);
  }
  
  .review-book-info h3 {
    margin-bottom: 0.25rem;
  }
  
  .review-book-info h3 a {
    color: white;
    text-decoration: none;
  }
  
  .review-book-info h3 a:hover {
    text-decoration: underline;
  }
  
  .review-book-author {
    opacity: 0.7;
  }
  
  .review-stats {
    text-align: right;
  }
  
  .review-rating-large {
    color: #fbbf24;
    font-size: 1.2rem;
    margin-bottom: 0.5rem;
  }
  
  .review-helpfulness {
    margin-bottom: 0.25rem;
  }
  
  .helpful-percent {
    font-weight: 700;
    color: var(--success);
  }
  
  .helpful-counts {
    font-size: 0.9rem;
    opacity: 0.7;
  }
  
  .review-date {
    font-size: 0.9rem;
    opacity: 0.6;
  }
  
  .review-detailed-content {
    margin-bottom: 1.5rem;
    line-height: 1.8;
  }
  
  .review-detailed-footer {
    display: flex;
    gap: 1rem;
    justify-content: flex-end;
  }
  
  .delete-form {
    display: inline;
  }
  
  @media (max-width: 768px) {
    .review-detailed-header {
      flex-direction: column;
      gap: 1rem;
    }
    
    .review-stats {
      text-align: left;
    }
    
    .review-detailed-footer {
      flex-wrap: wrap;
    }
  }
</style>