<div class="hero">
  <h1>Добро пожаловать в Книгоманы!</h1>
  <p>Крупнейшее сообщество книголюбов. Найди свою следующую книгу вместе с тысячами читателей.</p>
  
  <div class="hero-search">
  <form action="/books" method="GET" class="search-form">
    <div class="search-input-wrapper">
      <i class="fas fa-search search-icon"></i>
      <input 
        type="text" 
        name="search" 
        placeholder="Поиск книг по названию или автору..." 
        autocomplete="off"
      >
    </div>
    <button type="submit" class="btn btn-primary btn-search">
      <i class="fas fa-search"></i> Найти
    </button>
  </form>
  <p class="search-hint">Например: "Война и мир" или "Толстой"</p>
</div>

<div class="stats">
  <div class="stat-item">
    <i class="fas fa-book"></i>
    <span class="stat-number">1234</span>
    <span class="stat-label">книг в базе</span>
  </div>
  <div class="stat-item">
    <i class="fas fa-users"></i>
    <span class="stat-number">567</span>
    <span class="stat-label">пользователей</span>
  </div>
  <div class="stat-item">
    <i class="fas fa-star"></i>
    <span class="stat-number">890</span>
    <span class="stat-label">рецензий</span>
  </div>
</div>

<h2 class="section-title">Популярные книги</h2>
<div class="books-grid" id="popular-books">
  <!-- Сюда подгрузятся книги через JavaScript -->
</div>

<div class="cta-section">
  <h2>Готовы поделиться впечатлениями?</h2>
  <p>Присоединяйтесь к сообществу и начните писать рецензии уже сегодня!</p>
  <% if (!user) { %>
    <a href="/auth/register" class="btn btn-large btn-primary">
      <i class="fas fa-user-plus"></i> Присоединиться
    </a>
  <% } %>
</div>

<script>
  // Загружаем популярные книги
  fetch('/books/popular?limit=6')
    .then(response => response.json())
    .then(books => {
      const container = document.getElementById('popular-books');
      container.innerHTML = '';
      
      books.forEach(book => {
        const stars = '★'.repeat(Math.floor(book.averageRating)) + '☆'.repeat(5 - Math.floor(book.averageRating));
        
        container.innerHTML += `
          <div class="book-card">
            <a href="/books/${book.id}" class="book-link">
              <div class="book-cover">
                <img src="/images/covers/${book.cover_image}" alt="${book.title}">
              </div>
              <div class="book-info">
                <h3 class="book-title">${book.title}</h3>
                <p class="book-author">${book.author}</p>
                <div class="book-meta">
                  <span class="book-genre">${book.genre ? book.genre.name : 'Без жанра'}</span>
                </div>
                <div class="book-rating">
                  <span class="rating-stars">${stars}</span>
                  <span class="rating-value">${book.averageRating}</span>
                </div>
              </div>
            </a>
          </div>
        `;
      });
    })
    .catch(error => console.error('Error loading popular books:', error));
</script>

<style>
  .hero-search {
    max-width: 700px;
    margin: 2rem auto 0;
  }
  
  .search-form {
    display: flex;
    gap: 0.5rem;
    background: rgba(255, 255, 255, 0.2);
    border-radius: var(--radius-lg);
    padding: 0.5rem;
    backdrop-filter: blur(10px);
    -webkit-backdrop-filter: blur(10px);
  }
  
  .search-input-wrapper {
    flex: 1;
    position: relative;
  }
  
  .search-icon {
    position: absolute;
    left: 1rem;
    top: 50%;
    transform: translateY(-50%);
    color: rgba(255, 255, 255, 0.5);
    font-size: 1rem;
  }
  
  .search-input-wrapper input {
    width: 100%;
    padding: 1rem 1rem 1rem 2.8rem;
    border: none;
    border-radius: var(--radius);
    background: rgba(255, 255, 255, 0.9);
    font-size: 1rem;
    transition: all 0.3s ease;
  }
  
  .search-input-wrapper input:focus {
    outline: none;
    box-shadow: 0 0 0 3px rgba(99, 102, 241, 0.5);
    background: white;
  }
  
  .search-input-wrapper input::placeholder {
    color: #666;
    font-style: italic;
  }
  
  .btn-search {
    padding: 1rem 2rem;
    font-weight: 600;
    letter-spacing: 0.5px;
  }
  
  .search-hint {
    text-align: left;
    margin-top: 0.5rem;
    font-size: 0.8rem;
    opacity: 0.7;
    padding-left: 1rem;
  }
  
  @media (max-width: 768px) {
    .search-form {
      flex-direction: column;
    }
    
    .btn-search {
      width: 100%;
    }
  }
</style>