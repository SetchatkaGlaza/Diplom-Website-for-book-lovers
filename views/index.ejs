    line-height: 1.6;
  }
  
  .read-more {
    display: inline-block;
    margin-top: 1rem;
    color: var(--accent);
    font-weight: 500;
  }
  
  .loading {
    text-align: center;
    padding: 3rem;
    opacity: 0.7;
  }
  
  @media (max-width: 768px) {
    .random-book-link {
      grid-template-columns: 1fr;
