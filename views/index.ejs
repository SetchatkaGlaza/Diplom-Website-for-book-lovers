<div class="hero">
  <h1>Добро пожаловать в Книгоманы!</h1>
  <p>Крупнейшее сообщество книголюбов. Найди свою следующую книгу вместе с тысячами читателей.</p>
  
  <div class="hero-search">
    <form action="/books" method="GET" class="search-form">
      <input type="text" name="search" placeholder="Поиск книг по названию или автору..." autocomplete="off">
      <button type="submit" class="btn btn-primary">
        <i class="fas fa-search"></i> <span class="search-btn-text">Найти</span>
      </button>
    </form>
  </div>
</div>

<div class="stats">
  <div class="stat-item">
    <i class="fas fa-book"></i>
    <span class="stat-number" id="totalBooks"><%= stats.totalBooks || 0 %></span>
    <span class="stat-label">книг в базе</span>
  </div>
  <div class="stat-item">
    <i class="fas fa-users"></i>
    <span class="stat-number" id="totalUsers"><%= stats.totalUsers || 0 %></span>
    <span class="stat-label">пользователей</span>
  </div>
  <div class="stat-item">
    <i class="fas fa-star"></i>
    <span class="stat-number" id="totalReviews"><%= stats.totalReviews || 0 %></span>
    <span class="stat-label">рецензий</span>
  </div>
</div>

<% const bookOfDay = homeData.bookOfDay || { title: 'Мастер и Маргарита', author: 'Михаил Булгаков', coverUrl: '/images/covers/default-book-cover.jpg', reason: 'Культовый роман для разговоров о добре, свободе и цене выбора.', id: null }; %>
<section class="home-live-grid">
  <article class="home-panel book-of-day" data-book-id="<%= bookOfDay.id || '' %>">
    <div class="panel-kicker"><i class="fas fa-sun"></i> Книга дня</div>
    <div class="book-of-day-layout">
      <a href="<%= bookOfDay.id ? `/books/${bookOfDay.id}` : '/books' %>" class="book-of-day-cover">
        <img src="<%= bookOfDay.coverUrl %>" alt="<%= bookOfDay.title %>">
      </a>
      <div>
        <h2><%= bookOfDay.title %></h2>
        <p class="book-author"><%= bookOfDay.author %></p>
        <p class="choice-reason"><strong>Почему сегодня:</strong> <%= bookOfDay.reason %></p>
        <div class="book-of-day-actions">
          <% if (user && bookOfDay.id) { %>
            <button class="btn btn-primary shelf-action" data-status="want_to_read"><i class="fas fa-bookmark"></i> Хочу прочитать</button>
            <button class="btn btn-outline shelf-action" data-status="read"><i class="fas fa-check"></i> Уже читал</button>
            <button class="btn btn-outline dismiss-book"><i class="fas fa-times"></i> Не интересно</button>
          <% } else { %>
            <a href="/auth/login" class="btn btn-primary"><i class="fas fa-bookmark"></i> Хочу прочитать</a>
            <a href="/books" class="btn btn-outline"><i class="fas fa-compass"></i> В каталог</a>
          <% } %>
        </div>
        <p class="shelf-feedback" aria-live="polite"></p>
      </div>
    </div>
  </article>

  <% const personal = homeData.personal; %>
  <% if (user && personal) { %>
    <aside class="home-panel personal-panel">
      <div class="panel-kicker"><i class="fas fa-user-check"></i> Ваш читательский пульт</div>
      <h2>Продолжайте без паузы</h2>
      <ul class="personal-list">
        <li><i class="fas fa-book-open"></i> <% if (personal.continueReading) { %><a href="<%= personal.continueReading.url %>"><%= personal.continueReading.title %></a><span><%= personal.continueReading.author %></span><% } else { %><a href="/profile/books?status=reading">Выберите книгу для текущего чтения</a><span>Мы закрепим её здесь.</span><% } %></li>
        <li><i class="fas fa-bullseye"></i> <strong><%= personal.weeklyGoal %></strong><span>Цель недели</span></li>
        <li><i class="fas fa-lightbulb"></i> <strong><%= personal.shelfRecommendation %></strong><span>Рекомендация по полке</span></li>
      </ul>
    </aside>
  <% } %>
</section>

<section class="home-columns">
  <div class="home-panel">
    <div class="panel-kicker"><i class="fas fa-comments"></i> Сегодня обсуждают</div>
    <div class="compact-feed">
      <% const fallbackTopics = [{ title: 'Какая книга вернула вам любовь к чтению?', url: '/forum', meta: 'новая тема дня' }, { title: 'Экранизация или оригинал: что выбираете?', url: '/forum', meta: 'горячая дискуссия' }, { title: 'Советуем короткие книги на выходные', url: '/forum', meta: 'подборка сообщества' }]; %>
      <% (homeData.discussedTopics.length ? homeData.discussedTopics : fallbackTopics).forEach((topic) => { %>
        <a href="<%= topic.url %>" class="feed-item"><strong><%= topic.title %></strong><span><%= topic.meta %></span></a>
      <% }) %>
    </div>
  </div>

  <div class="home-panel">
    <div class="panel-kicker"><i class="fas fa-trophy"></i> Топ рецензий недели</div>
    <div class="review-list">
      <% const fallbackReviews = [{ rating: 5, author: 'Редакция', bookTitle: 'Лучшие открытия недели', bookUrl: '/books?sort=rating', excerpt: 'Собрали рецензии, которые вдохновляют спорить, перечитывать и пополнять полку.', likes: 0 }]; %>
      <% (homeData.weeklyTopReviews.length ? homeData.weeklyTopReviews : fallbackReviews).forEach((review) => { %>
        <a href="<%= review.bookUrl %>" class="review-mini"><span class="rating-stars"><%= '★'.repeat(review.rating) %></span><strong><%= review.bookTitle %></strong><p><%= review.excerpt %></p><small><%= review.author %> · <%= review.likes %> лайков</small></a>
      <% }) %>
    </div>
  </div>
</section>

<% const reviewOfWeek = homeData.weeklyTopReviews[0]; %>
<section class="home-panel challenge-editorial">
  <div>
    <div class="panel-kicker"><i class="fas fa-flag-checkered"></i> Читательские челленджи</div>
    <div class="challenge-grid">
      <a href="/profile/books" class="challenge-card"><strong>7 дней чтения подряд</strong><span>Отмечайте прогресс каждый день и не теряйте темп.</span></a>
      <a href="/books?genre_name=классика&sort=rating" class="challenge-card"><strong>Классика месяца</strong><span>Выберите произведение, которое давно откладывали.</span></a>
      <a href="/books?sort=rating#popular-books" class="challenge-card"><strong>Рецензия недели</strong><span>Расскажите, кому точно стоит открыть вашу последнюю книгу.</span></a>
    </div>
  </div>
  <div>
    <div class="panel-kicker"><i class="fas fa-wand-magic-sparkles"></i> Подборки редакции</div>
    <div class="collection-tags">
      <a href="/books?pages_to=300&sort=rating">Для дождливого вечера</a>
      <a href="/books?pages_to=200">Книги на 200 страниц</a>
      <a href="/books?genre_name=классика&author=Достоевский&sort=rating">Если понравился Достоевский</a>
      <a href="/books?genre_name=современная&pages_to=350&sort=rating">Уютное чтение</a>
    </div>
  </div>
</section>

<section class="home-panel activity-panel">
  <div class="panel-kicker"><i class="fas fa-signal"></i> Активность сообщества в реальном времени</div>
  <div class="activity-ticker" id="community-activity-ticker">
    <% const fallbackActivity = [{ userName: 'Анна', action: 'добавила в планы', bookTitle: 'новый роман', bookUrl: '/books' }, { userName: 'Игорь', action: 'оценил', bookTitle: 'классику', bookUrl: '/books' }, { userName: 'Мария', action: 'прочитала', bookTitle: 'детектив недели', bookUrl: '/books' }]; %>
    <% (homeData.communityActivity.length ? homeData.communityActivity : fallbackActivity).forEach((activity) => { %>
      <a href="<%= activity.bookUrl %>" class="activity-pill"><span class="pulse-dot"></span><strong><%= activity.userName %></strong> <%= activity.action %> «<%= activity.bookTitle %>»</a>
    <% }) %>
  </div>
</section>

<h2 class="section-title">Популярные книги</h2>
<div class="books-grid" id="popular-books">
  <!-- Сюда подгрузятся книги через JavaScript -->
</div>

<!-- Блок для неавторизованных пользователей -->
<% if (!user) { %>
  <div class="cta-section">
    <h2>Готовы поделиться впечатлениями?</h2>
    <p>Присоединяйтесь к сообществу и начните писать рецензии уже сегодня!</p>
    <a href="/auth/register" class="btn btn-large btn-primary">
      <i class="fas fa-user-plus"></i> Присоединиться
    </a>
  </div>
<% } else { %>
  <!-- Блок для авторизованных пользователей -->
 <div class="welcome-back-section">
  <h2>С возвращением, <%= user.name %>!</h2>
  <div class="quick-actions">
    <a href="/profile/books" class="quick-action-card">
      <i class="fas fa-bookmark"></i>
      <span>Мои книги</span>
    </a>
    <a href="/profile/reviews" class="quick-action-card">
      <i class="fas fa-star"></i>
      <span>Мои рецензии</span>
    </a>
    <a href="/profile" class="quick-action-card">
      <i class="fas fa-user"></i>
      <span>Профиль</span>
    </a>
  </div>
</div>
<% } %>

<!-- Блок случайной книги -->
<div class="random-book-section">
  <h2 class="section-title">Случайная книга</h2>
  <div id="random-book" class="random-book-card">
    <!-- Заглушка, загрузится через JS -->
    <div class="loading">Загрузка...</div>
  </div>
  <button id="refresh-random" class="btn btn-outline">
    <i class="fas fa-sync-alt"></i> Другую книгу
  </button>
</div>

<script>
  document.querySelectorAll('.shelf-action').forEach((button) => {
    button.addEventListener('click', async () => {
      const card = button.closest('.book-of-day');
      const bookId = card?.dataset.bookId;
      const feedback = card?.querySelector('.shelf-feedback');
      if (!bookId) return;

      try {
        const response = await fetch('/profile/books/status', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ book_id: bookId, status: button.dataset.status })
        });
        if (!response.ok) throw new Error('Не удалось обновить полку');
        if (feedback) feedback.textContent = button.dataset.status === 'read' ? 'Отметили как прочитанную.' : 'Добавили в «Хочу прочитать».';
      } catch (error) {
        if (feedback) feedback.textContent = 'Не получилось обновить полку. Попробуйте позже.';
      }
    });
  });

  document.querySelector('.dismiss-book')?.addEventListener('click', (event) => {
    const card = event.currentTarget.closest('.book-of-day');
    const feedback = card?.querySelector('.shelf-feedback');
    if (feedback) feedback.textContent = 'Поняли — сегодня предложим другую книгу в каталоге.';
  });

  const renderCommunityActivity = (activities) => {
    const ticker = document.getElementById('community-activity-ticker');
    if (!ticker || !Array.isArray(activities) || activities.length === 0) return;

    ticker.innerHTML = '';
    activities.forEach((activity) => {
      const link = document.createElement('a');
      link.className = 'activity-pill';
      link.href = activity.bookUrl || '/books';

      const dot = document.createElement('span');
      dot.className = 'pulse-dot';
      link.appendChild(dot);

      const name = document.createElement('strong');
      name.textContent = activity.userName || 'Читатель';
      link.appendChild(name);

      link.append(` ${activity.action || 'обновил(а) полку'} «${activity.bookTitle || 'книгу'}»`);
      ticker.appendChild(link);
    });
  };

  const refreshCommunityActivity = () => {
    fetch('/api/home/community-activity')
      .then((response) => response.ok ? response.json() : Promise.reject(new Error('Activity request failed')))
      .then((data) => renderCommunityActivity(data.activity))
      .catch((error) => console.error('Error refreshing community activity:', error));
  };

  setInterval(refreshCommunityActivity, 45000);

  // Загружаем популярные книги
  fetch('/books/popular?limit=6')
    .then(response => response.json())
    .then(books => {
      const container = document.getElementById('popular-books');
      container.innerHTML = '';
      
      const renderStars = (rating) => Array.from({ length: 5 }, (_, index) => {
        const star = index + 1;
        if (star <= Math.floor(rating)) return '<i class="fas fa-star"></i>';
        if (star - 0.5 <= rating) return '<i class="fas fa-star-half-alt"></i>';
        return '<i class="far fa-star"></i>';
      }).join('');
      
      books.forEach(book => {
        const stars = renderStars(book.averageRating);
  
  container.innerHTML += `
    <div class="book-card">
      <a href="/books/${book.id}" class="book-link">
        <div class="book-cover">
          <img src="${book.coverUrl || '/images/covers/default-book-cover.jpg'}" alt="${book.title}">
        </div>
        <div class="book-info">
          <h3 class="book-title">${book.title}</h3>
          <p class="book-author">${book.author}</p>
          <div class="book-meta">
            <span class="book-genre">${book.genre ? book.genre.name : 'Без жанра'}</span>
          </div>
          <div class="book-rating">
            ${book.averageRating > 0 ? `
              <span class="rating-stars">${stars}</span>
              <span class="rating-value">${book.averageRating}</span>
              <span class="rating-count">(${book.ratingsCount})</span>
            ` : '<span class="rating-value no-rating">Нет оценок</span>'}
          </div>
        </div>
      </a>
    </div>
  `;
});
    })
    .catch(error => console.error('Error loading popular books:', error));
  
  // Функция загрузки случайной книги
  function loadRandomBook() {
    const container = document.getElementById('random-book');
    container.innerHTML = '<div class="loading">Загрузка...</div>';
    
    fetch('/books/random')
      .then(response => response.json())
      .then(book => {
        if (book) {
          const stars = Array.from({ length: 5 }, (_, index) => {
            const star = index + 1;
            return star <= Math.floor(book.rating) ? '<i class="fas fa-star"></i>' : '<i class="far fa-star"></i>';
          }).join('');
          
          container.innerHTML = `
            <a href="/books/${book.id}" class="random-book-link">
              <div class="random-book-cover">
                <img src="${book.coverUrl || '/images/covers/default-book-cover.jpg'}" alt="${book.title}">
              </div>
              <div class="random-book-info">
                <h3>${book.title}</h3>
                <p class="book-author">${book.author}</p>
                <p class="book-genre">${book.genre}</p>
                <div class="book-rating">
                  <span class="rating-stars">${stars}</span>
                  <span class="rating-value">${book.rating}</span>
                </div>
                <p class="book-description">${book.description || ''}</p>
                <span class="read-more">Читать далее →</span>
              </div>
            </a>
          `;
        } else {
          container.innerHTML = '<p class="no-books">Книги пока не добавлены</p>';
        }
      })
      .catch(error => {
        console.error('Error loading random book:', error);
        container.innerHTML = '<p class="error">Ошибка загрузки</p>';
      });
  }
  
  // Загружаем случайную книгу при загрузке страницы
  loadRandomBook();
  
  // Обработчик кнопки "Другую книгу"
  document.getElementById('refresh-random')?.addEventListener('click', loadRandomBook);
</script>

