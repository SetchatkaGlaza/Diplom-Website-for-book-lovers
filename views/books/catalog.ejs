<div class="catalog-header">
  <h1>Каталог книг</h1>
  <p class="books-count">Найдено книг: <%= totalBooks %></p>
</div>

<div class="catalog-layout">
  <!-- Боковая панель с фильтрами -->
  <aside class="filters-sidebar">
    <h3>Фильтры</h3>
    
    <form action="/books" method="GET" id="filter-form">
      <div class="filter-group">
        <label for="search">Поиск по названию</label>
        <input 
          type="text" 
          id="search" 
          name="search" 
          value="<%= filters.search || '' %>"
          placeholder="Введите название..."
        >
      </div>
      
      <div class="filter-group">
        <label for="genre">Жанр</label>
        <select id="genre" name="genre">
          <option value="">Все жанры</option>
          <% genres.forEach(genre => { %>
            <option 
              value="<%= genre.id %>"
              <%= filters.genre == genre.id ? 'selected' : '' %>
            >
              <%= genre.name %>
            </option>
          <% }) %>
        </select>
      </div>
      
      <div class="filter-group">
        <label for="author">Автор</label>
        <input 
          type="text" 
          id="author" 
          name="author" 
          value="<%= filters.author || '' %>"
          placeholder="Фамилия автора..."
        >
      </div>
      
      <div class="filter-group">
        <label>Год издания</label>
        <div class="range-inputs">
          <input 
            type="number" 
            name="year_from" 
            placeholder="От"
            value="<%= filters.year_from || '' %>"
            min="<%= minCatalogYear %>"
            max="<%= maxCatalogYear %>"
            data-min-year="<%= minCatalogYear %>"
          >
          <input 
            type="number" 
            name="year_to" 
            placeholder="До"
            value="<%= filters.year_to || '' %>"
            min="<%= minCatalogYear %>"
            max="<%= maxCatalogYear %>"
            data-min-year="<%= minCatalogYear %>"
          >
        </div>
        <small class="filter-hint">Минимальный год в каталоге: <strong><%= minCatalogYear %></strong></small>
      </div>

      <% if (filterWarnings && filterWarnings.length > 0) { %>
        <div class="filter-warnings">
          <% filterWarnings.forEach(warning => { %>
            <div class="filter-warning"><i class="fas fa-exclamation-triangle"></i><span><%= warning %></span></div>
          <% }) %>
        </div>
      <% } %>
      
      <button type="submit" class="btn btn-primary btn-block">Применить фильтры</button>
      
      <% if (hasActiveFilters) { %>
        <a href="/books" class="btn btn-outline btn-block">Сбросить фильтры</a>
      <% } %>
    </form>
  </aside>
  
  <!-- Основной контент - список книг -->
  <main class="catalog-content">
    <!-- Сортировка -->
    <div class="sort-bar">
      <label for="sort">Сортировать:</label>
      <select id="sort" name="sort" form="filter-form">
        <option value="newest" <%= sort === 'newest' ? 'selected' : '' %>>Сначала новые</option>
        <option value="popular" <%= sort === 'popular' ? 'selected' : '' %>>По популярности</option>
        <option value="rating" <%= sort === 'rating' ? 'selected' : '' %>>По рейтингу</option>
        <option value="title_asc" <%= sort === 'title_asc' ? 'selected' : '' %>>По названию (А-Я)</option>
        <option value="title_desc" <%= sort === 'title_desc' ? 'selected' : '' %>>По названию (Я-А)</option>
        <option value="year_desc" <%= sort === 'year_desc' ? 'selected' : '' %>>По году (сначала новые)</option>
        <option value="year_asc" <%= sort === 'year_asc' ? 'selected' : '' %>>По году (сначала старые)</option>
      </select>
    </div>
    
    <!-- Сетка книг - 4 колонки -->
    <% if (books.length > 0) { %>
      <div class="books-grid">
        <% books.forEach(book => { %>
          <div class="book-card">
            <a href="/books/<%= book.id %>" class="book-link">
              <div class="book-cover">
                <img src="<%= book.coverUrl || '/images/covers/default-book-cover.jpg' %>" alt="<%= book.title %>">
              </div>
              <div class="book-info">
                <h3 class="book-title"><%= book.title %></h3>
                <p class="book-author"><%= book.author %></p>
                <div class="book-meta">
                  <span class="book-genre"><%= book.genre ? book.genre.name : 'Без жанра' %></span>
                  <span class="book-year"><%= book.year || 'Год не указан' %></span>
                </div>
                <div class="book-rating">
                  <% if (book.averageRating > 0) { %>
                    <span class="rating-stars">
                      <% for(let i = 1; i <= 5; i++) { %>
                        <% if (i <= Math.floor(book.averageRating)) { %>
                          <i class="fas fa-star"></i>
                        <% } else if (i - 0.5 <= book.averageRating) { %>
                          <i class="fas fa-star-half-alt"></i>
                        <% } else { %>
                          <i class="far fa-star"></i>
                        <% } %>
                      <% } %>
                    </span>
                    <span class="rating-value"><%= book.averageRating %></span>
                  <% } else { %>
                    <span class="rating-value no-rating">Нет оценок</span>
                  <% } %>
                </div>
              </div>
            </a>
          </div>
        <% }) %>
      </div>
      
      <!-- Пагинация -->
      <% if (totalPages > 1) { %>
        <div class="pagination">
          <% if (currentPage > 1) { %>
            <a href="?<%= new URLSearchParams({...filters, page: currentPage - 1, sort}).toString() %>" class="page-link" data-page-nav="prev">←</a>
          <% } %>
          
          <% for(let i = 1; i <= totalPages; i++) { %>
            <% if (i === currentPage) { %>
              <span class="page-link active" data-page-number="<%= i %>"><%= i %></span>
            <% } else { %>
              <a href="?<%= new URLSearchParams({...filters, page: i, sort}).toString() %>" class="page-link" data-page-number="<%= i %>"><%= i %></a>
            <% } %>
          <% } %>
          
          <% if (currentPage < totalPages) { %>
            <a href="?<%= new URLSearchParams({...filters, page: currentPage + 1, sort}).toString() %>" class="page-link" data-page-nav="next">→</a>
          <% } %>
        </div>
      <% } %>
      
    <% } else { %>
      <div class="no-books">
        <div class="no-books-icon"><i class="fas fa-book-open"></i></div>
        <h2><%= hasActiveFilters ? 'По этим фильтрам книг не найдено' : 'В каталоге пока нет книг' %></h2>
        <p><%= hasActiveFilters ? 'Попробуйте изменить жанр, автора, годы издания или поисковый запрос.' : 'Когда книги будут добавлены, они появятся на этой странице.' %></p>
        <% if (hasActiveFilters) { %>
          <a href="/books" class="btn btn-primary">Показать весь каталог</a>
        <% } %>
      </div>
    <% } %>
  </main>
</div>

<script>
  const filterForm = document.getElementById('filter-form');
  const yearFromInput = filterForm?.querySelector('input[name="year_from"]');

  function validateYearFrom() {
    if (!yearFromInput || !yearFromInput.value) return true;

    const minYear = Number(yearFromInput.dataset.minYear);
    const selectedYear = Number(yearFromInput.value);

    if (Number.isFinite(minYear) && Number.isFinite(selectedYear) && selectedYear < minYear) {
      yearFromInput.setCustomValidity(`Минимальный год в каталоге – ${minYear}`);
      yearFromInput.reportValidity();
      return false;
    }

    yearFromInput.setCustomValidity('');
    return true;
  }

  yearFromInput?.addEventListener('input', validateYearFrom);

  filterForm?.addEventListener('submit', function(event) {
    if (!validateYearFrom()) {
      event.preventDefault();
    }
  });

  document.getElementById('sort')?.addEventListener('change', function() {
    if (validateYearFrom()) {
      filterForm?.submit();
    }
  });

  (function limitVisiblePagination() {
    const pagination = document.querySelector('.pagination');
    if (!pagination) return;

    const pageLinks = Array.from(pagination.querySelectorAll('[data-page-number]'));
    const activeElement = pagination.querySelector('.page-link.active[data-page-number]');
    const currentPage = activeElement ? Number(activeElement.dataset.pageNumber) : 1;

    const getMaxVisiblePages = () => {
      if (window.innerWidth <= 480) return 5;
      if (window.innerWidth <= 768) return 7;
      if (window.innerWidth <= 1024) return 10;
      return 20;
    };

    const updateVisiblePages = () => {
      const maxVisiblePages = getMaxVisiblePages();
      const half = Math.floor(maxVisiblePages / 2);
      let start = Math.max(1, currentPage - half);
      let end = start + maxVisiblePages - 1;
      const total = pageLinks.length;

      if (end > total) {
        end = total;
        start = Math.max(1, end - maxVisiblePages + 1);
      }

      pageLinks.forEach((link) => {
        const pageNumber = Number(link.dataset.pageNumber);
        link.style.display = (pageNumber >= start && pageNumber <= end) ? '' : 'none';
      });
    };

    updateVisiblePages();
    window.addEventListener('resize', updateVisiblePages);
  })();
</script>

