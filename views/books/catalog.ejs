<div class="catalog-header">
  <h1>Каталог книг</h1>
  <p class="books-count">Найдено книг: <%= totalBooks %></p>
</div>

<div class="catalog-layout">
  <!-- Боковая панель с фильтрами -->
  <aside class="filters-sidebar">
    <h3>Фильтры</h3>
    
    <form action="/books" method="GET" id="filter-form">
      <% if (sort) { %>
        <input type="hidden" name="sort" value="<%= sort %>">
      <% } %>
      
      <div class="filter-group">
        <label for="search">Поиск по названию</label>
        <input 
          type="text" 
          id="search" 
          name="search" 
          value="<%= filters.search || '' %>"
          placeholder="Введите название..."
        >
      </div>
      
      <div class="filter-group">
        <label for="genre">Жанр</label>
        <select id="genre" name="genre">
          <option value="">Все жанры</option>
          <% genres.forEach(genre => { %>
            <option 
              value="<%= genre.id %>"
              <%= filters.genre == genre.id ? 'selected' : '' %>
            >
              <%= genre.name %>
            </option>
          <% }) %>
        </select>
      </div>
      
      <div class="filter-group">
        <label for="author">Автор</label>
        <input 
          type="text" 
          id="author" 
          name="author" 
          value="<%= filters.author || '' %>"
          placeholder="Фамилия автора..."
        >
      </div>
      
      <div class="filter-group">
        <label>Год издания</label>
        <div class="range-inputs">
          <input 
            type="number" 
            name="year_from" 
            placeholder="От"
            value="<%= filters.year_from || '' %>"
            min="1000"
            max="2026"
          >
          <input 
            type="number" 
            name="year_to" 
            placeholder="До"
            value="<%= filters.year_to || '' %>"
            min="1000"
            max="2026"
          >
        </div>
      </div>
      
      <button type="submit" class="btn btn-primary btn-block">Применить фильтры</button>
      
      <% if (Object.keys(filters).length > 0) { %>
        <a href="/books" class="btn btn-outline btn-block">Сбросить фильтры</a>
      <% } %>
    </form>
  </aside>
  
  <!-- Основной контент - список книг -->
  <main class="catalog-content">
    <!-- Сортировка -->
    <div class="sort-bar">
      <label for="sort">Сортировать:</label>
      <select id="sort" name="sort" form="filter-form">
        <option value="newest" <%= sort === 'newest' ? 'selected' : '' %>>Сначала новые</option>
        <option value="popular" <%= sort === 'popular' ? 'selected' : '' %>>По популярности</option>
        <option value="title_asc" <%= sort === 'title_asc' ? 'selected' : '' %>>По названию (А-Я)</option>
        <option value="title_desc" <%= sort === 'title_desc' ? 'selected' : '' %>>По названию (Я-А)</option>
        <option value="year_desc" <%= sort === 'year_desc' ? 'selected' : '' %>>По году (сначала новые)</option>
        <option value="year_asc" <%= sort === 'year_asc' ? 'selected' : '' %>>По году (сначала старые)</option>
      </select>
    </div>
    
    <!-- Сетка книг - 4 колонки -->
    <% if (books.length > 0) { %>
      <div class="books-grid">
        <% books.forEach(book => { %>
          <div class="book-card">
            <a href="/books/<%= book.id %>" class="book-link">
              <div class="book-cover">
                <img src="/images/covers/<%= book.cover_image %>" alt="<%= book.title %>">
              </div>
              <div class="book-info">
                <h3 class="book-title"><%= book.title %></h3>
                <p class="book-author"><%= book.author %></p>
                <div class="book-meta">
                  <span class="book-genre"><%= book.genre ? book.genre.name : 'Без жанра' %></span>
                  <span class="book-year"><%= book.year || 'Год не указан' %></span>
                </div>
                <div class="book-rating">
                  <% if (book.averageRating > 0) { %>
                    <span class="rating-stars">
                      <% for(let i = 1; i <= 5; i++) { %>
                        <% if (i <= Math.floor(book.averageRating)) { %>
                          ★
                        <% } else if (i - 0.5 <= book.averageRating) { %>
                          ½
                        <% } else { %>
                          ☆
                        <% } %>
                      <% } %>
                    </span>
                    <span class="rating-value"><%= book.averageRating %></span>
                  <% } else { %>
                    <span class="rating-value no-rating">Нет оценок</span>
                  <% } %>
                </div>
              </div>
            </a>
          </div>
        <% }) %>
      </div>
      
      <!-- Пагинация -->
      <% if (totalPages > 1) { %>
        <div class="pagination">
          <% if (currentPage > 1) { %>
            <a href="?<%= new URLSearchParams({...filters, page: currentPage - 1, sort}).toString() %>" class="page-link">←</a>
          <% } %>
          
          <% for(let i = 1; i <= totalPages; i++) { %>
            <% if (i === currentPage) { %>
              <span class="page-link active"><%= i %></span>
            <% } else { %>
              <a href="?<%= new URLSearchParams({...filters, page: i, sort}).toString() %>" class="page-link"><%= i %></a>
            <% } %>
          <% } %>
          
          <% if (currentPage < totalPages) { %>
            <a href="?<%= new URLSearchParams({...filters, page: currentPage + 1, sort}).toString() %>" class="page-link">→</a>
          <% } %>
        </div>
      <% } %>
      
    <% } else { %>
      <div class="no-books">
        <p>Книги не найдены. Попробуйте изменить параметры поиска.</p>
      </div>
    <% } %>
  </main>
</div>

<script>
  document.getElementById('sort')?.addEventListener('change', function() {
    document.getElementById('filter-form').submit();
  });
</script>

<style>
  /* ===== ОСНОВНЫЕ СТИЛИ ===== */
  .catalog-header {
    background: rgba(255, 255, 255, 0.1);
    backdrop-filter: blur(10px);
    border: 1px solid rgba(255, 255, 255, 0.2);
    border-radius: var(--radius-lg);
    padding: 2rem;
    margin: 2rem 0;
    color: white;
    display: flex;
    justify-content: space-between;
    align-items: center;
  }
  
  .books-count {
    font-size: 1.1rem;
    opacity: 0.9;
  }
  
  .catalog-layout {
    display: grid;
    grid-template-columns: 280px 1fr;
    gap: 2rem;
    margin: 2rem 0;
  }
  
  /* Фильтры */
  .filters-sidebar {
    background: rgba(255, 255, 255, 0.1);
    backdrop-filter: blur(10px);
    border: 1px solid rgba(255, 255, 255, 0.2);
    border-radius: var(--radius-lg);
    padding: 1.5rem;
    color: white;
    height: fit-content;
    position: sticky;
    top: 90px;
  }
  
  .filters-sidebar h3 {
    margin-bottom: 1.5rem;
    font-size: 1.25rem;
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }
  
  .filter-group {
    margin-bottom: 1.5rem;
  }
  
  .filter-group label {
    display: block;
    margin-bottom: 0.5rem;
    font-weight: 500;
  }
  
  .filter-group input,
  .filter-group select {
    width: 100%;
    padding: 0.75rem;
    border: 1px solid rgba(255, 255, 255, 0.2);
    border-radius: var(--radius);
    background: rgba(255, 255, 255, 0.1);
    color: white;
    font-size: 0.95rem;
    transition: var(--transition);
  }
  
  .filter-group input:focus,
  .filter-group select:focus {
    outline: none;
    border-color: white;
    background: rgba(255, 255, 255, 0.2);
  }
  
  .range-inputs {
    display: flex;
    gap: 0.5rem;
  }
  
  .range-inputs input {
    width: 50%;
  }
  
  .btn-block {
    width: 100%;
    margin-bottom: 0.5rem;
  }
  
  /* Сортировка */
  .sort-bar {
    display: flex;
    align-items: center;
    gap: 1rem;
    justify-content: flex-end;
    margin-bottom: 2rem;
    color: white;
  }
  
  .sort-bar select {
    padding: 0.5rem 1rem;
    border: 1px solid rgba(255, 255, 255, 0.2);
    border-radius: var(--radius);
    background: rgba(255, 255, 255, 0.1);
    color: white;
    cursor: pointer;
  }
  
  /* ===== СЕТКА КНИГ - 4 КОЛОНКИ ===== */
  .books-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 2rem;
    margin: 2rem 0;
  }
  
  /* Карточка книги */
  .book-card {
    background: rgba(255, 255, 255, 0.1);
    backdrop-filter: blur(10px);
    border: 1px solid rgba(255, 255, 255, 0.2);
    border-radius: var(--radius-lg);
    overflow: hidden;
    transition: var(--transition);
    height: 100%;
  }
  
  .book-card:hover {
    transform: translateY(-10px);
    box-shadow: var(--shadow-xl);
    background: rgba(255, 255, 255, 0.15);
  }
  
  .book-link {
    text-decoration: none;
    color: white;
    display: block;
    height: 100%;
  }
  
  .book-cover {
    position: relative;
    padding-top: 150%;
    overflow: hidden;
  }
  
  .book-cover img {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: var(--transition);
  }
  
  .book-card:hover .book-cover img {
    transform: scale(1.1);
  }
  
  .book-info {
    padding: 1.5rem;
  }
  
  .book-title {
    font-size: 1.1rem;
    font-weight: 600;
    margin-bottom: 0.25rem;
    line-height: 1.4;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  
  .book-author {
    font-size: 0.9rem;
    opacity: 0.8;
    margin-bottom: 0.5rem;
  }
  
  .book-meta {
    display: flex;
    gap: 0.5rem;
    font-size: 0.8rem;
    opacity: 0.7;
    margin-bottom: 0.5rem;
    flex-wrap: wrap;
  }
  
  .book-rating {
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }
  
  .rating-stars {
    color: #fbbf24;
    font-size: 0.9rem;
  }
  
  .rating-value {
    font-weight: 600;
  }
  
  .no-rating {
    opacity: 0.6;
    font-size: 0.9rem;
  }
  
  /* Пагинация */
  .pagination {
    display: flex;
    justify-content: center;
    align-items: center;
    gap: 0.5rem;
    margin: 3rem 0;
  }
  
  .page-link {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 0.5rem 1rem;
    border-radius: var(--radius);
    background: rgba(255, 255, 255, 0.1);
    color: white;
    text-decoration: none;
    transition: var(--transition);
  }
  
  .page-link:hover,
  .page-link.active {
    background: linear-gradient(135deg, var(--accent), var(--secondary));
    transform: scale(1.05);
  }
  
  .no-books {
    text-align: center;
    padding: 3rem;
    background: rgba(0, 0, 0, 0.2);
    border-radius: var(--radius-lg);
    margin: 2rem 0;
  }
  
  /* ===== АДАПТИВНОСТЬ ===== */
  @media (max-width: 1200px) {
    .books-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }
  
  @media (max-width: 900px) {
    .catalog-layout {
      grid-template-columns: 1fr;
    }
    
    .filters-sidebar {
      position: relative;
      top: 0;
    }
    
    .books-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }
  
  @media (max-width: 600px) {
    .books-grid {
      grid-template-columns: 1fr;
    }
    
    .catalog-header {
      flex-direction: column;
      text-align: center;
      gap: 1rem;
    }
    
    .sort-bar {
      justify-content: center;
    }
  }
</style>