    border: 1px solid rgba(255, 255, 255, 0.2);
    padding: 0.5rem 1rem;
    border-radius: var(--radius);
    color: white;
    cursor: pointer;
    transition: var(--transition);
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }
  
  .btn-like:hover {
    background: var(--success);
  }
  
  .btn-dislike:hover {
    background: var(--danger);
  }
  
  .btn-like.active {
    background: var(--success);
    border-color: var(--success);
  }
  
  .btn-dislike.active {
    background: var(--danger);
    border-color: var(--danger);
  }
  
  .review-owner-actions {
    display: flex;
    gap: 0.5rem;
    margin-left: auto;
  }
  
  .btn-small {
    display: inline-flex;
    align-items: center;
    gap: 0.25rem;
    padding: 0.4rem 0.8rem;
    border-radius: var(--radius);
    font-size: 0.9rem;
    text-decoration: none;
    color: white;
    transition: var(--transition);
