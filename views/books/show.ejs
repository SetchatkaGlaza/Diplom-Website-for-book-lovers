    height: 100%;
    background: linear-gradient(90deg, #fbbf24, #f59e0b);
    border-radius: 4px;
    transition: width 0.3s;
  }
  
  .rating-value {
    width: 80px;
    font-size: 0.85rem;
    opacity: 0.8;
  }
  
  /* ===== ДЕЙСТВИЯ С КНИГОЙ ===== */
  .book-actions {
    display: flex;
    gap: 1rem;
    margin-bottom: 1rem;
    flex-wrap: wrap;
  }
  
  .book-status-message {
    background: rgba(255, 255, 255, 0.1);
    padding: 0.75rem 1rem;
    border-radius: var(--radius);
    margin-bottom: 1.5rem;
    display: flex;
    align-items: center;
    gap: 0.5rem;
    border-left: 4px solid var(--success);
  }
  
  .write-review-btn {
    margin: 1.5rem 0;
  }
  
  .login-to-action {
    background: rgba(255, 255, 255, 0.1);
    padding: 1rem;
    border-radius: var(--radius);
    margin: 1.5rem 0;
  }
  
  .login-to-action a {
    color: white;
    font-weight: 600;
    text-decoration: underline;
  }
  
  /* ===== АННОТАЦИЯ ===== */
  .book-description {
    margin-top: 2rem;
  }
  
  .book-description h3 {
