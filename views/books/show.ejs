    display: flex;
    flex-wrap: wrap;
    gap: 1.5rem;
    margin-bottom: 2rem;
    padding: 1rem 0;
    border-top: 1px solid rgba(255, 255, 255, 0.2);
    border-bottom: 1px solid rgba(255, 255, 255, 0.2);
  }
  
  .book-meta-large span {
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }
  
  /* ===== НОВЫЙ БЛОК С РЕЙТИНГОМ ===== */
  .book-rating-section {
    background: rgba(0, 0, 0, 0.2);
    border-radius: var(--radius-lg);
    padding: 1.5rem;
    margin: 1.5rem 0;
    display: grid;
    grid-template-columns: auto 1fr;
    gap: 2rem;
    align-items: center;
  }
  
  .rating-main {
    text-align: center;
    min-width: 150px;
  }
  
  .rating-number {
    font-size: 3.5rem;
    font-weight: 700;
    color: #fbbf24;
    line-height: 1;
  }
  
  .rating-number small {
    font-size: 1.2rem;
    color: rgba(255, 255, 255, 0.5);
  }
  
  .rating-stars-large {
    font-size: 1.3rem;
    color: #fbbf24;
    margin: 0.5rem 0;
  }
  
  .rating-count {
    font-size: 0.9rem;
    opacity: 0.8;
  }
  
  .rating-distribution {
    flex: 1;
  }
  
  .rating-row {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin-bottom: 0.5rem;
  }
  
  .rating-label {
    width: 40px;
    font-size: 0.9rem;
    display: flex;
    align-items: center;
    gap: 0.25rem;
  }
  
  .rating-label i {
    color: #fbbf24;
    font-size: 0.8rem;
  }
  
  .rating-bar-container {
    flex: 1;
    height: 8px;
    background: rgba(255, 255, 255, 0.2);
    border-radius: 4px;
    overflow: hidden;
  }
  
