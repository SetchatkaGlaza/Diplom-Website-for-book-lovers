  }
  
  .reviewer-name {
    font-weight: 600;
  }
  
  .review-badge {
    display: inline-block;
    padding: 0.2rem 0.5rem;
    border-radius: var(--radius-sm);
    font-size: 0.75rem;
    font-weight: 500;
    margin-left: 0.5rem;
  }
  
  .review-badge.pending {
    background: #f59e0b;
    color: white;
  }
  
  .review-rating {
    display: flex;
    gap: 0.25rem;
    color: #fbbf24;
  }
  
  .review-date {
    font-size: 0.9rem;
    opacity: 0.7;
    display: flex;
    align-items: center;
    gap: 0.25rem;
  }
  
  .review-content {
    margin-bottom: 1rem;
    line-height: 1.8;
  }
  
  .review-footer {
    display: flex;
    gap: 1rem;
    align-items: center;
    flex-wrap: wrap;
