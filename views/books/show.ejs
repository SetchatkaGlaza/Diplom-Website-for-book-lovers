    padding: 2rem;
    margin: 2rem 0;
    color: white;
  }
  
  .book-main {
    display: grid;
    grid-template-columns: 300px 1fr;
    gap: 2rem;
    margin-bottom: 3rem;
  }
  
  .book-cover-large {
    border-radius: var(--radius-lg);
    overflow: hidden;
    box-shadow: var(--shadow-xl);
  }
  
  .book-cover-large img {
    width: 100%;
    height: auto;
    display: block;
