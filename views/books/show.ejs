  .btn-small:hover {
    transform: translateY(-2px);
  }
  
  .btn-small.btn-danger {
    background: var(--danger);
  }
  
  .moderation-message {
    color: #f59e0b;
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }
  
  .no-reviews {
    text-align: center;
    padding: 3rem;
    background: rgba(0, 0, 0, 0.2);
    border-radius: var(--radius-lg);
  }
  
  .no-reviews i {
    opacity: 0.5;
    margin-bottom: 1rem;
  }
  
  .no-reviews p {
    margin-bottom: 1.5rem;
    font-size: 1.1rem;
  }
  
  .inline-form {
    display: inline;
  }
  
  /* ===== ПОХОЖИЕ КНИГИ ===== */
  .similar-books {
    margin-top: 3rem;
  }
  
  .similar-books h3 {
    font-size: 1.5rem;
    margin-bottom: 1.5rem;
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }
  
  .books-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(150px, 1fr));
    gap: 1rem;
  }

  .similar-books .book-rating {
    text-align: center;
  }
  
  .book-card.small .book-cover {
    height: 180px;
  }
  
  .book-card.small .book-title {
    font-size: 0.9rem;
  }
  
  .book-card.small .book-author {
    font-size: 0.8rem;
  }
  
  /* ===== АДАПТИВНОСТЬ ===== */
  @media (max-width: 768px) {
    .book-main {
      grid-template-columns: 1fr;
    }
    
    .book-cover-large {
      max-width: 250px;
      margin: 0 auto;
    }
    
    .book-actions {
      flex-direction: column;
    }
    
    .review-header {
      flex-direction: column;
      align-items: flex-start;
    }
    
    .review-owner-actions {
      margin-left: 0;
      width: 100%;
    }
    
    .book-rating-section {
      grid-template-columns: 1fr;
      gap: 1rem;
    }
    
    .rating-row {
      flex-wrap: wrap;
    }
    
    .rating-value {
      width: auto;
    }

    .similar-books .books-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 0.85rem;
    }

    .similar-books .book-card.small .book-cover {
      height: 170px;
    }

    .similar-books .book-title,
    .similar-books .book-author {
      text-align: center;
    }
  }

  @media (max-width: 480px) {
    .similar-books .books-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }

    .similar-books .book-card.small .book-cover {
      height: 150px;
    }
  }
</style>

<script>
  // Обработка кнопок "Хочу прочитать" и т.д.
  document.querySelectorAll('.book-actions .btn').forEach(button => {
    button.addEventListener('click', async function() {
      const bookId = this.dataset.bookId;
      const status = this.dataset.status;
      
      try {
        const response = await fetch('/profile/books/status', {
          method: 'POST',
          headers: {
            'Content-Type': 'application/json'
          },
          body: JSON.stringify({ book_id: bookId, status })
        });
        
        if (response.ok) {
          // Обновляем стили кнопок
          document.querySelectorAll('.book-actions .btn').forEach(btn => {
            btn.classList.remove('btn-primary');
            btn.classList.add('btn-outline');
          });
          
          this.classList.remove('btn-outline');
          this.classList.add('btn-primary');
          
          // Обновляем сообщение о статусе
          location.reload(); // Простой способ - перезагрузить страницу
        } else {
          alert('Ошибка при сохранении');
        }
      } catch (error) {
        console.error('Error:', error);
      }
    });
  });
  
  // Обработка лайков рецензий
  document.querySelectorAll('.btn-like, .btn-dislike').forEach(button => {
    button.addEventListener('click', async function() {
      const reviewId = this.dataset.reviewId;
      const type = this.dataset.type;
      
      try {
        const response = await fetch('/reviews/' + reviewId + '/rate', {
          method: 'POST',
          headers: {
            'Content-Type': 'application/json'
          },
          body: JSON.stringify({ type: type })
        });
        
        if (response.ok) {
          const data = await response.json();
          
          // Находим карточку рецензии
          const reviewCard = this.closest('.review-card');
          
          // Обновляем счётчики
          reviewCard.querySelector('.likes-count').textContent = data.likes;
          reviewCard.querySelector('.dislikes-count').textContent = data.dislikes;
          
          // Обновляем классы активных кнопок
          const likeBtn = reviewCard.querySelector('.btn-like');
          const dislikeBtn = reviewCard.querySelector('.btn-dislike');
          
          if (likeBtn) {
            likeBtn.classList.remove('active');
            const likeIcon = likeBtn.querySelector('i');
            likeIcon.className = 'far fa-thumbs-up';
          }
          
          if (dislikeBtn) {
            dislikeBtn.classList.remove('active');
            const dislikeIcon = dislikeBtn.querySelector('i');
            dislikeIcon.className = 'far fa-thumbs-down';
          }
          
          // Активируем нужную кнопку
          if (data.userReaction === 'like') {
            likeBtn.classList.add('active');
            likeBtn.querySelector('i').className = 'fas fa-thumbs-up';
          } else if (data.userReaction === 'dislike') {
            dislikeBtn.classList.add('active');
            dislikeBtn.querySelector('i').className = 'fas fa-thumbs-down';
          }
          
        } else {
          const error = await response.json();
          alert(error.error || 'Ошибка при оценке');
        }
      } catch (error) {
        console.error('Error:', error);
      }
    });
  });
</script>