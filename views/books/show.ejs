<div class="book-page">
  <div class="book-main">
    <!-- Обложка -->
    <div class="book-cover-large">
      <img src="/images/covers/<%= book.cover_image %>" alt="<%= book.title %>">
    </div>
    
    <!-- Информация о книге -->
    <div class="book-details">
      <h1 class="book-title"><%= book.title %></h1>
      <h2 class="book-author"><%= book.author %></h2>
      
      <div class="book-meta-large">
        <% if (book.genre) { %>
          <span><i class="fas fa-tag"></i> <%= book.genre.name %></span>
        <% } %>
        <% if (book.year) { %>
          <span><i class="fas fa-calendar"></i> <%= book.year %></span>
        <% } %>
        <% if (book.pages) { %>
          <span><i class="fas fa-book"></i> <%= book.pages %> стр.</span>
        <% } %>
        <% if (book.publisher) { %>
          <span><i class="fas fa-building"></i> <%= book.publisher %></span>
        <% } %>
      </div>
      
      <!-- НОВЫЙ БЛОК С РЕЙТИНГОМ -->
      <div class="book-rating-section">
        <div class="rating-main">
          <div class="rating-number">
            <%= ratingInfo.average %>
            <small>/5</small>
          </div>
          <div class="rating-stars-large">
            <% for(let i = 1; i <= 5; i++) { %>
              <% if (i <= Math.floor(ratingInfo.average)) { %>
                <i class="fas fa-star"></i>
              <% } else if (i - 0.5 <= ratingInfo.average) { %>
                <i class="fas fa-star-half-alt"></i>
              <% } else { %>
                <i class="far fa-star"></i>
              <% } %>
            <% } %>
          </div>
          <div class="rating-count">
            <%= ratingInfo.count %> 
            <% if (ratingInfo.count === 1) { %>
              оценка
            <% } else if (ratingInfo.count >= 2 && ratingInfo.count <= 4) { %>
              оценки
            <% } else { %>
              оценок
            <% } %>
          </div>
        </div>
        
        <% if (ratingInfo.count > 0) { %>
          <div class="rating-distribution">
            <% for(let star = 5; star >= 1; star--) { %>
              <% 
                const percent = (ratingInfo.distribution[star] / ratingInfo.count * 100).toFixed(1);
                const barWidth = percent + '%';
              %>
              <div class="rating-row">
                <div class="rating-label">
                  <%= star %> <i class="fas fa-star"></i>
                </div>
                <div class="rating-bar-container">
                  <div class="rating-bar" style="width: <%= barWidth %>"></div>
                </div>
                <div class="rating-value">
                  <%= ratingInfo.distribution[star] %> (<%= percent %>%)
                </div>
              </div>
            <% } %>
          </div>
        <% } %>
      </div>
      
      <!-- Действия с книгой (только для авторизованных) -->
      <% if (user) { %>
        <div class="book-actions">
          <button class="btn <%= userBookStatus === 'want_to_read' ? 'btn-primary' : 'btn-outline' %>" 
                  id="want-to-read" 
                  data-status="want_to_read"
                  data-book-id="<%= book.id %>">
            <i class="fas fa-bookmark"></i>
            <span>Хочу прочитать</span>
          </button>
          
          <button class="btn <%= userBookStatus === 'reading' ? 'btn-primary' : 'btn-outline' %>" 
                  id="reading" 
                  data-status="reading"
                  data-book-id="<%= book.id %>">
            <i class="fas fa-book-open"></i>
            <span>Читаю сейчас</span>
          </button>
          
          <button class="btn <%= userBookStatus === 'read' ? 'btn-primary' : 'btn-outline' %>" 
                  id="read" 
                  data-status="read"
                  data-book-id="<%= book.id %>">
            <i class="fas fa-check-circle"></i>
            <span>Прочитано</span>
          </button>
        </div>
        
        <!-- Текущий статус -->
        <% if (userBookStatus) { %>
          <div class="book-status-message">
            <i class="fas fa-info-circle"></i>
            <% if (userBookStatus === 'want_to_read') { %>
              Эта книга в вашем списке "Хочу прочитать"
            <% } else if (userBookStatus === 'reading') { %>
              Вы читаете эту книгу сейчас
            <% } else if (userBookStatus === 'read') { %>
              Вы уже прочитали эту книгу
            <% } %>
          </div>
        <% } %>
        
        <!-- Кнопка написания рецензии -->
        <% if (!userReview) { %>
          <div class="write-review-btn">
            <a href="/reviews/new/<%= book.id %>" class="btn btn-primary btn-large">
              <i class="fas fa-pen"></i> Написать рецензию
            </a>
          </div>
        <% } %>
        
      <% } else { %>
        <div class="login-to-action">
          <p><i class="fas fa-lock"></i> <a href="/auth/login">Войдите</a>, чтобы добавить книгу на полку или написать рецензию</p>
        </div>
      <% } %>
      
      <!-- Аннотация -->
      <% if (book.description) { %>
        <div class="book-description">
          <h3><i class="fas fa-align-left"></i> Аннотация</h3>
          <p><%= book.description %></p>
        </div>
      <% } %>
    </div>
  </div>
  
  <!-- Блок рецензий -->
  <div class="book-reviews">
    <h3><i class="fas fa-star"></i> Рецензии читателей 
      <% if (reviews.length > 0) { %>
        <span class="reviews-count">(<%= reviews.length %>)</span>
      <% } %>
    </h3>
    
    <% if (reviews.length > 0) { %>
      <div class="reviews-list">
        <% reviews.forEach(review => { %>
          <div class="review-card" data-review-id="<%= review.id %>">
            <div class="review-header">
              <div class="reviewer-info">
                <img src="/images/avatars/<%= review.user.avatar %>" alt="<%= review.user.name %>" class="reviewer-avatar">
                <div>
                  <span class="reviewer-name"><%= review.user.name %></span>
                  <% if (!review.is_moderated) { %>
                    <span class="review-badge pending">На модерации</span>
                  <% } %>
                </div>
              </div>
              <div class="review-rating">
                <% for(let i = 1; i <= 5; i++) { %>
                  <% if (i <= review.rating) { %>
                    <i class="fas fa-star"></i>
                  <% } else { %>
                    <i class="far fa-star"></i>
                  <% } %>
                <% } %>
              </div>
              <span class="review-date">
                <i class="far fa-calendar-alt"></i> <%= new Date(review.createdAt).toLocaleDateString('ru-RU') %>
              </span>
            </div>
            
            <div class="review-content">
              <p><%= review.content %></p>
            </div>
            
            <% if (review.is_moderated) { %>
              <div class="review-footer">
                <button class="btn-like <%= review.userReaction === 'like' ? 'active' : '' %>" 
                        data-review-id="<%= review.id %>" 
                        data-type="like">
                  <i class="<%= review.userReaction === 'like' ? 'fas' : 'far' %> fa-thumbs-up"></i> 
                  <span class="likes-count"><%= review.likes_count || 0 %></span>
                </button>
                
                <button class="btn-dislike <%= review.userReaction === 'dislike' ? 'active' : '' %>" 
                        data-review-id="<%= review.id %>" 
                        data-type="dislike">
                  <i class="<%= review.userReaction === 'dislike' ? 'fas' : 'far' %> fa-thumbs-down"></i> 
                  <span class="dislikes-count"><%= review.dislikes_count || 0 %></span>
                </button>
                
                <% if (user && user.id === review.user_id) { %>
                  <div class="review-owner-actions">
                    <a href="/reviews/<%= review.id %>/edit" class="btn-small">
                      <i class="fas fa-edit"></i> Редактировать
                    </a>
                    <form action="/reviews/<%= review.id %>?_method=DELETE" method="POST" class="inline-form">
                      <button type="submit" class="btn-small btn-danger" onclick="return confirm('Удалить рецензию?')">
                        <i class="fas fa-trash"></i> Удалить
                      </button>
                    </form>
                  </div>
                <% } %>
              </div>
            <% } else if (user && user.id === review.user_id) { %>
              <div class="review-footer">
                <p class="moderation-message"><i class="fas fa-clock"></i> Рецензия ожидает модерации</p>
                <div class="review-owner-actions">
                  <a href="/reviews/<%= review.id %>/edit" class="btn-small">
                    <i class="fas fa-edit"></i> Редактировать
                  </a>
                  <form action="/reviews/<%= review.id %>?_method=DELETE" method="POST" class="inline-form">
                    <button type="submit" class="btn-small btn-danger" onclick="return confirm('Удалить рецензию?')">
                      <i class="fas fa-trash"></i> Удалить
                    </button>
                  </form>
                </div>
              </div>
            <% } %>
          </div>
        <% }) %>
      </div>
    <% } else { %>
      <div class="no-reviews">
        <i class="fas fa-star fa-3x"></i>
        <p>Пока нет рецензий. Будьте первым, кто поделится мнением!</p>
        <% if (user) { %>
          <a href="/reviews/new/<%= book.id %>" class="btn btn-primary">
            <i class="fas fa-pen"></i> Написать рецензию
          </a>
        <% } %>
      </div>
    <% } %>
  </div>
  
  <!-- Похожие книги -->
  <% if (similarBooks && similarBooks.length > 0) { %>
    <div class="similar-books">
      <h3><i class="fas fa-bookmark"></i> Похожие книги</h3>
      <div class="books-grid">
        <% similarBooks.forEach(book => { %>
          <div class="book-card small">
            <a href="/books/<%= book.id %>" class="book-link">
              <div class="book-cover">
                <img src="/images/covers/<%= book.cover_image %>" alt="<%= book.title %>">
              </div>
              <div class="book-info">
                <h4 class="book-title"><%= book.title %></h4>
                <p class="book-author"><%= book.author %></p>
                <div class="book-rating">
                  <% if (book.averageRating > 0) { %>
                    <span class="rating-value"><%= book.averageRating %> ★</span>
                  <% } %>
                </div>
              </div>
            </a>
          </div>
        <% }) %>
      </div>
    </div>
  <% } %>
</div>

<style>
