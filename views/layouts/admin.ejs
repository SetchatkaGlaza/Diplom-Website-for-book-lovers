<!DOCTYPE html>
<html lang="ru">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title ? title + ' | ' : '' %>Админ-панель - Книгоманы</title>
  <link rel="icon" href="/favicon.ico" sizes="any">
  <link rel="icon" type="image/png" sizes="32x32" href="/images/icons/favicon-32x32.png">
  <link rel="icon" type="image/png" sizes="16x16" href="/images/icons/favicon-16x16.png">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
  <link rel="stylesheet" href="/css/style.css">
  <link rel="stylesheet" href="/css/admin.css">
</head>
<body class="admin-body">
  <div class="admin-wrapper">
    <!-- Боковое меню админки -->
    <aside class="admin-sidebar">
      <div class="admin-logo">
        <i class="fas fa-book-open"></i>
        <span>Книгоманы</span>
        <small>Админ-панель</small>
      </div>
      
      <nav class="admin-nav">
        <a href="/admin" class="admin-nav-item">
          <i class="fas fa-tachometer-alt"></i> Дашборд
        </a>
        
        <!-- Книги с подменю -->
        <div class="admin-nav-group">
          <div class="admin-nav-group-title">
            <i class="fas fa-book"></i> Книги
          </div>
          <a href="/admin/books" class="admin-nav-item sub-item">
            <i class="fas fa-list"></i> Все книги
          </a>
          <a href="/admin/books/add" class="admin-nav-item sub-item">
            <i class="fas fa-plus"></i> Добавить книгу
          </a>
          <a href="/admin/import" class="admin-nav-item sub-item">
            <i class="fas fa-file-upload"></i> Импорт книг
          </a>
        </div>
        
        <a href="/admin/users" class="admin-nav-item">
          <i class="fas fa-users"></i> Пользователи
        </a>
        
        <a href="/admin/genres" class="admin-nav-item">
          <i class="fas fa-tags"></i> Жанры
        </a>
        
        <a href="/admin/reviews" class="admin-nav-item">
          <i class="fas fa-star"></i> Рецензии
        </a>

        <a href="/admin/forum" class="admin-nav-item <%= (locals.path && path.includes('/admin/forum')) ? 'active' : '' %>">
  <i class="fas fa-comments"></i> Форум
</a>
        
        <a href="/admin/statistics" class="admin-nav-item">
          <i class="fas fa-chart-bar"></i> Статистика
        </a>
        
        <div class="admin-nav-divider"></div>
        
        <a href="/" class="admin-nav-item" target="_blank">
          <i class="fas fa-external-link-alt"></i> На сайт
        </a>
        <a href="/auth/logout" class="admin-nav-item">
          <i class="fas fa-sign-out-alt"></i> Выйти
        </a>
      </nav>
      
      <div class="admin-user">
        <img src="/images/avatars/<%= user.avatar %>" alt="<%= user.name %>">
        <div>
          <div><%= user.name %></div>
          <small><%= user.role === 'admin' ? 'Администратор' : 'Модератор' %></small>
        </div>
      </div>
    </aside>
    
    <!-- Основной контент -->
    <main class="admin-main">
      <% if (success_msg && success_msg.length > 0) { %>
        <div class="alert alert-success">
          <i class="fas fa-check-circle"></i>
          <%= success_msg %>
        </div>
      <% } %>
      
      <% if (error_msg && error_msg.length > 0) { %>
        <div class="alert alert-danger">
          <i class="fas fa-exclamation-circle"></i>
          <%= error_msg %>
        </div>
      <% } %>
      
      <div class="admin-content">
        <%- body %>
      </div>
    </main>
  </div>
</body>
</html>
