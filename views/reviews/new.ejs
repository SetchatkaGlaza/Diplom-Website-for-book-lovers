<div class="new-review">
  <div class="review-header">
    <a href="/books/<%= book.id %>" class="back-link">
      <i class="fas fa-arrow-left"></i> Вернуться к книге
    </a>
    <h1><i class="fas fa-pen"></i> Новая рецензия</h1>
  </div>
  
  <div class="review-book-info">
    <img src="/images/covers/<%= book.cover_image %>" alt="<%= book.title %>" class="review-book-cover">
    <div>
      <h2><%= book.title %></h2>
      <p class="book-author"><%= book.author %></p>
    </div>
  </div>
  
  <% if (warning) { %>
    <div class="alert alert-warning">
      <i class="fas fa-exclamation-triangle"></i>
      <%= warning %>
    </div>
  <% } %>
  
  <% if (errors && errors.length > 0) { %>
    <div class="alert alert-danger">
      <ul>
        <% errors.forEach(error => { %>
          <li><%= error.msg %></li>
        <% }) %>
      </ul>
    </div>
  <% } %>
  
  <form action="/reviews/new/<%= book.id %>" method="POST" class="review-form">
    <div class="form-group">
      <label>Ваша оценка <span class="required">*</span></label>
      <div class="rating-input">
        <% for(let i = 5; i >= 1; i--) { %>
          <input 
            type="radio" 
            name="rating" 
            id="star<%= i %>" 
            value="<%= i %>"
            <%= (rating == i) ? 'checked' : '' %>
            required
          >
          <label for="star<%= i %>" class="star-label" title="<%= i %> звезд">
            <i class="fas fa-star"></i>
          </label>
        <% } %>
      </div>
    </div>
    
    <!-- ⭐ НОВЫЙ БЛОК: Подсказки по оценкам -->
    <div class="rating-guide">
      <h4><i class="fas fa-info-circle"></i> Что означают оценки:</h4>
      <div class="rating-guide-items">
        <div class="rating-guide-item">
          <span class="rating-guide-stars">★★★★★</span>
          <span class="rating-guide-text">Шедевр, обязателен к прочтению</span>
        </div>
        <div class="rating-guide-item">
          <span class="rating-guide-stars">★★★★☆</span>
          <span class="rating-guide-text">Отличная книга, очень понравилась</span>
        </div>
        <div class="rating-guide-item">
          <span class="rating-guide-stars">★★★☆☆</span>
          <span class="rating-guide-text">Хорошая книга, но не без недостатков</span>
        </div>
        <div class="rating-guide-item">
          <span class="rating-guide-stars">★★☆☆☆</span>
          <span class="rating-guide-text">Средняя книга, могло быть лучше</span>
        </div>
        <div class="rating-guide-item">
          <span class="rating-guide-stars">★☆☆☆☆</span>
          <span class="rating-guide-text">Не понравилось, зря потратил время</span>
        </div>
      </div>
    </div>
    
    <div class="form-group">
      <label for="content">Текст рецензии <span class="required">*</span></label>
      <textarea 
        id="content" 
        name="content" 
        rows="12"
        required
        minlength="10"
        maxlength="5000"
        placeholder="Поделитесь своим мнением о книге... Что понравилось? Что не понравилось? Кому бы вы её порекомендовали?"
      ><%= content ? content : '' %></textarea>
      <div class="textarea-counter">
        <span id="charCount">0</span>/5000 символов
        <span id="charWarning" class="char-warning" style="display: none;"> (минимум 10)</span>
      </div>
    </div>
    
    <div class="review-guidelines">
      <h4><i class="fas fa-info-circle"></i> Правила написания рецензий</h4>
      <ul>
        <li><i class="fas fa-check-circle"></i> Рецензия должна быть написана по-русски</li>
        <li><i class="fas fa-check-circle"></i> Минимальная длина — 10 символов</li>
        <li><i class="fas fa-check-circle"></i> Запрещены оскорбления и нецензурная лексика</li>
        <li><i class="fas fa-check-circle"></i> Рецензия проходит модерацию перед публикацией</li>
        <li><i class="fas fa-check-circle"></i> Вы можете редактировать свою рецензию после публикации</li>
      </ul>
    </div>
    
    <div class="form-actions">
      <button type="submit" class="btn btn-primary btn-large">
        <i class="fas fa-paper-plane"></i> Опубликовать рецензию
      </button>
      <a href="/books/<%= book.id %>" class="btn btn-outline">
        <i class="fas fa-times"></i> Отмена
      </a>
    </div>
  </form>
</div>

<style>
