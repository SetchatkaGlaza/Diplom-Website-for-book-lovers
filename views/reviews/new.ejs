    backdrop-filter: blur(10px);
    -webkit-backdrop-filter: blur(10px);
    border: 1px solid rgba(255, 255, 255, 0.2);
    border-radius: var(--radius-lg);
    padding: 2rem;
    margin: 2rem 0;
    color: white;
    max-width: 800px;
    margin-left: auto;
    margin-right: auto;
  }
  
  .review-header {
    margin-bottom: 2rem;
  }
  
  .back-link {
    color: white;
    text-decoration: none;
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    margin-bottom: 1rem;
    opacity: 0.8;
    transition: var(--transition);
  }
  
  .back-link:hover {
    opacity: 1;
    transform: translateX(-5px);
  }
  
  .review-header h1 {
    display: flex;
    align-items: center;
    gap: 1rem;
    font-size: 2rem;
    margin: 0;
  }
  
  .review-header h1 i {
    color: var(--accent);
  }
  
  .review-book-info {
    display: flex;
    gap: 2rem;
    align-items: center;
    background: rgba(0, 0, 0, 0.3);
    border-radius: var(--radius-lg);
    padding: 1.5rem;
    margin-bottom: 2rem;
  }
  
  .review-book-cover {
    width: 100px;
    height: 150px;
    object-fit: cover;
    border-radius: var(--radius);
    box-shadow: var(--shadow-lg);
    border: 2px solid rgba(255, 255, 255, 0.1);
  }
  
  .review-book-info h2 {
    margin-bottom: 0.5rem;
    font-size: 1.8rem;
  }
  
  .book-author {
    opacity: 0.8;
    font-size: 1.1rem;
  }
  
  .required {
    color: #ef4444;
    margin-left: 0.25rem;
  }
  
  .alert-warning {
    background: rgba(245, 158, 11, 0.2);
    border: 1px solid #f59e0b;
    color: #f59e0b;
    padding: 1rem;
    border-radius: var(--radius);
    margin-bottom: 1.5rem;
    display: flex;
    align-items: center;
    gap: 1rem;
  }
  
  .alert-warning i {
    font-size: 1.2rem;
  }
  
  .alert-danger {
    background: rgba(239, 68, 68, 0.2);
    border: 1px solid #ef4444;
    color: #ef4444;
    padding: 1rem;
    border-radius: var(--radius);
    margin-bottom: 1.5rem;
  }
  
  .alert-danger ul {
    margin: 0 0 0 1.5rem;
  }
  
  .alert-danger li {
    margin-bottom: 0.25rem;
  }
  
  /* Стили для выбора оценки */
  .rating-input {
    display: flex;
    flex-direction: row-reverse;
    justify-content: flex-end;
    gap: 0.5rem;
    margin: 0.5rem 0;
  }
  
  .rating-input input {
    display: none;
  }
  
  .star-label {
    font-size: 2.5rem;
    color: rgba(255, 255, 255, 0.3);
    cursor: pointer;
    transition: all 0.2s ease;
  }
  
  .rating-input input:checked ~ .star-label,
  .rating-input .star-label:hover,
  .rating-input .star-label:hover ~ .star-label {
    color: #fbbf24;
    transform: scale(1.1);
    text-shadow: 0 0 10px rgba(251, 191, 36, 0.5);
  }
  
  /* ⭐ НОВЫЕ СТИЛИ: Подсказки по оценкам */
  .rating-guide {
    background: rgba(0, 0, 0, 0.3);
    border-radius: var(--radius-lg);
    padding: 1.5rem;
    margin: 1.5rem 0;
    border-left: 4px solid var(--accent);
  }
  
  .rating-guide h4 {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    margin-bottom: 1.2rem;
    color: var(--accent);
    font-size: 1.1rem;
  }
  
  .rating-guide h4 i {
    font-size: 1.2rem;
  }
  
  .rating-guide-items {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    gap: 1rem;
  }
  
  .rating-guide-item {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    padding: 0.75rem;
    background: rgba(255, 255, 255, 0.05);
    border-radius: var(--radius);
    transition: transform 0.2s;
  }
  
  .rating-guide-item:hover {
    transform: translateY(-3px);
    background: rgba(255, 255, 255, 0.1);
  }
  
  .rating-guide-stars {
    color: #fbbf24;
    font-size: 1.2rem;
    margin-bottom: 0.5rem;
    letter-spacing: 2px;
    font-weight: 600;
  }
  
  .rating-guide-text {
    font-size: 0.9rem;
    opacity: 0.9;
    line-height: 1.4;
  }
  
  /* Стили для текстового поля */
  .form-group {
    margin-bottom: 1.5rem;
  }
  
  .form-group label {
    display: block;
    margin-bottom: 0.5rem;
    font-weight: 500;
    font-size: 1.1rem;
  }
  
  .form-group textarea {
    width: 100%;
    padding: 1rem;
    border: 2px solid rgba(255, 255, 255, 0.2);
    border-radius: var(--radius);
    background: rgba(255, 255, 255, 0.1);
    color: white;
    font-size: 1rem;
    line-height: 1.6;
    resize: vertical;
    transition: all 0.3s;
  }
  
  .form-group textarea:focus {
    outline: none;
    border-color: var(--accent);
    background: rgba(255, 255, 255, 0.15);
    box-shadow: 0 0 0 3px rgba(99, 102, 241, 0.3);
  }
  
  .form-group textarea::placeholder {
    color: rgba(255, 255, 255, 0.5);
    font-style: italic;
  }
  
  .textarea-counter {
    text-align: right;
    font-size: 0.9rem;
    opacity: 0.8;
    margin-top: 0.5rem;
    display: flex;
    justify-content: space-between;
    align-items: center;
  }
  
  .char-warning {
    color: #f59e0b;
  }
  
  /* Стили для правил */
  .review-guidelines {
    background: rgba(0, 0, 0, 0.3);
    border-radius: var(--radius-lg);
    padding: 1.5rem;
    margin: 2rem 0;
  }
  
  .review-guidelines h4 {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    margin-bottom: 1rem;
    color: var(--accent);
    font-size: 1.1rem;
  }
  
  .review-guidelines ul {
    list-style: none;
    margin: 0;
    padding: 0;
  }
  
  .review-guidelines li {
    margin-bottom: 0.75rem;
    opacity: 0.9;
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }
  
  .review-guidelines li i {
    color: var(--success);
    font-size: 0.9rem;
  }
  
  /* Стили для кнопок */
  .form-actions {
    display: flex;
    gap: 1rem;
    margin-top: 2rem;
  }
  
  .btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    padding: 0.75rem 1.5rem;
    border: none;
    border-radius: var(--radius-lg);
    font-size: 1rem;
    font-weight: 500;
    cursor: pointer;
    text-decoration: none;
    transition: all 0.3s;
  }
  
  .btn-primary {
    background: linear-gradient(135deg, var(--accent), var(--secondary));
    color: white;
    box-shadow: var(--shadow);
  }
  
  .btn-primary:hover {
    transform: translateY(-2px);
    box-shadow: var(--shadow-lg);
  }
  
  .btn-outline {
    background: transparent;
    border: 2px solid rgba(255, 255, 255, 0.3);
    color: white;
  }
  
  .btn-outline:hover {
    border-color: white;
    background: rgba(255, 255, 255, 0.1);
    transform: translateY(-2px);
  }
  
  .btn-large {
    padding: 1rem 2rem;
    font-size: 1.1rem;
  }
  
  /* Адаптивность */
  @media (max-width: 768px) {
    .new-review {
      padding: 1.5rem;
    }
    
    .review-book-info {
      flex-direction: column;
      text-align: center;
    }
    
    .review-book-cover {
      width: 120px;
      height: 180px;
    }
    
    .form-actions {
      flex-direction: column;
    }
    
    .rating-guide-items {
      grid-template-columns: 1fr;
    }
    
    .rating-guide-item {
      flex-direction: row;
      justify-content: space-between;
      text-align: left;
      gap: 1rem;
    }
    
    .rating-guide-stars {
      margin-bottom: 0;
    }
  }
</style>

<script>
  // Счётчик символов
  const textarea = document.getElementById('content');
  const charCount = document.getElementById('charCount');
  const charWarning = document.getElementById('charWarning');
  
  if (textarea && charCount) {
    function updateCharCount() {
      const count = textarea.value.length;
      charCount.textContent = count;
      
      // Визуальное предупреждение о минимальной длине
      if (count < 10) {
        charCount.style.color = '#f59e0b';
        if (charWarning) charWarning.style.display = 'inline';
      } else if (count > 5000) {
        charCount.style.color = '#ef4444';
        if (charWarning) charWarning.style.display = 'none';
      } else {
        charCount.style.color = 'inherit';
        if (charWarning) charWarning.style.display = 'none';
      }
      
      // Валидация в реальном времени
      if (count > 5000) {
        textarea.value = textarea.value.substring(0, 5000);
        charCount.textContent = 5000;
      }
    }
    
    textarea.addEventListener('input', updateCharCount);
    
    // Инициализация
    updateCharCount();
  }
  
  // Анимация выбора оценки
  document.querySelectorAll('.rating-input input').forEach(input => {
    input.addEventListener('change', function() {
      // Можно добавить звуковой или визуальный эффект
      console.log('Выбрана оценка:', this.value);
    });
  });
  
  // Предупреждение перед отправкой, если текст слишком короткий
  document.querySelector('form').addEventListener('submit', function(e) {
    const rating = document.querySelector('input[name="rating"]:checked');
    const content = document.getElementById('content').value.trim();
    
    if (!rating) {
      e.preventDefault();
      alert('Пожалуйста, поставьте оценку книге');
      return;
    }
    
    if (content.length < 10) {
      e.preventDefault();
      alert('Рецензия должна содержать минимум 10 символов');
      document.getElementById('content').focus();
      return;
    }
  });
</script>