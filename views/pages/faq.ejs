<div class="page-content">
  <h1><i class="fas fa-question-circle"></i> Часто задаваемые вопросы</h1>
  
  <div class="faq-search">
    <input type="text" id="faq-search" placeholder="Поиск по вопросам..." class="faq-search-input">
  </div>
  
  <div class="faq-list">
    <% faqItems.forEach((item, index) => { %>
      <div class="faq-item" data-search="<%= item.question.toLowerCase() %>">
        <div class="faq-question" onclick="toggleFaq(this)">
          <h3><%= item.question %></h3>
          <i class="fas fa-chevron-down"></i>
        </div>
        <div class="faq-answer" id="<%= item.id %>">
          <p><%= item.answer %></p>
        </div>
      </div>
    <% }) %>
  </div>
  
  <div class="faq-not-found" style="display: none;">
    <i class="fas fa-search fa-3x"></i>
    <h3>Ничего не найдено</h3>
    <p>Попробуйте изменить поисковый запрос</p>
  </div>
  
  <div class="faq-contact">
    <h3>Не нашли ответ?</h3>
    <p>Свяжитесь с нами, и мы поможем!</p>
    <a href="/contact" class="btn btn-primary">
      <i class="fas fa-envelope"></i> Написать нам
    </a>
  </div>
</div>

<style>
  .page-content {
    background: rgba(255, 255, 255, 0.1);
    backdrop-filter: blur(10px);
    -webkit-backdrop-filter: blur(10px);
    border: 1px solid rgba(255, 255, 255, 0.2);
    border-radius: var(--radius-lg);
    padding: 2rem;
    margin: 2rem 0;
    color: white;
  }
  
  .page-content h1 {
    margin-bottom: 2rem;
    display: flex;
    align-items: center;
    gap: 1rem;
  }
  
  .faq-search {
    margin-bottom: 2rem;
  }
  
  .faq-search-input {
    width: 100%;
    padding: 1rem;
    border: 2px solid rgba(255, 255, 255, 0.2);
    border-radius: var(--radius-lg);
    background: rgba(255, 255, 255, 0.1);
    color: white;
    font-size: 1rem;
  }
  
  .faq-search-input:focus {
    outline: none;
    border-color: var(--accent);
  }
  
  .faq-list {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }
  
  .faq-item {
    background: rgba(0, 0, 0, 0.3);
    border-radius: var(--radius);
    overflow: hidden;
  }
  
  .faq-question {
    padding: 1.5rem;
    cursor: pointer;
    display: flex;
    justify-content: space-between;
    align-items: center;
    transition: var(--transition);
  }
  
  .faq-question:hover {
    background: rgba(255, 255, 255, 0.1);
  }
  
  .faq-question h3 {
    font-size: 1.1rem;
    margin: 0;
  }
  
  .faq-question i {
    transition: transform 0.3s;
  }
  
  .faq-item.active .faq-question i {
    transform: rotate(180deg);
  }
  
  .faq-answer {
    max-height: 0;
    padding: 0 1.5rem;
    overflow: hidden;
    transition: all 0.3s;
    background: rgba(0, 0, 0, 0.2);
  }
  
  .faq-item.active .faq-answer {
    max-height: 500px;
    padding: 1.5rem;
  }
  
  .faq-answer p {
    margin: 0;
    line-height: 1.8;
  }
  
  .faq-not-found {
    text-align: center;
    padding: 3rem;
    opacity: 0.7;
  }
  
  .faq-contact {
    text-align: center;
    margin-top: 3rem;
    padding: 2rem;
    background: rgba(255, 255, 255, 0.1);
    border-radius: var(--radius-lg);
  }
  
  .faq-contact h3 {
    margin-bottom: 0.5rem;
  }
  
  .faq-contact p {
    margin-bottom: 1.5rem;
  }
</style>

<script>
  function toggleFaq(element) {
    const faqItem = element.closest('.faq-item');
    faqItem.classList.toggle('active');
  }
  
  // Поиск по FAQ
  document.getElementById('faq-search').addEventListener('input', function(e) {
    const searchTerm = e.target.value.toLowerCase();
    const faqItems = document.querySelectorAll('.faq-item');
    let visibleCount = 0;
    
    faqItems.forEach(item => {
      const searchText = item.dataset.search;
      if (searchText.includes(searchTerm) || searchTerm === '') {
        item.style.display = 'block';
        visibleCount++;
      } else {
        item.style.display = 'none';
      }
    });
    
    document.querySelector('.faq-not-found').style.display = 
      visibleCount === 0 ? 'block' : 'none';
  });
  
  // Открытие по якорю
  if (window.location.hash) {
    const targetId = window.location.hash.substring(1);
    const targetElement = document.getElementById(targetId);
    if (targetElement) {
      const faqItem = targetElement.closest('.faq-item');
      faqItem.classList.add('active');
      faqItem.scrollIntoView({ behavior: 'smooth' });
    }
  }
</script>